{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@different-ai/opencode-browser",
    "@plannotator/opencode@latest",
    "opencode-plugin-openspec",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-session-handoff",
    "opencode-agent-memory",
    "opencode-ignore",
    "opencode-snip@latest"
  ],
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "--quiet",
        "mcp-server-fetch"
      ],
      "environment": {
        "PYTHONIOENCODING": "utf-8"
      },
      "enabled": true,
      "timeout": 30000
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--isolated",
        "--headless"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "time": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-time",
        "--local-timezone=Europe/Madrid"
      ],
      "enabled": false,
      "timeout": 30000
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": false,
      "timeout": 30000
    }
  }
}
