#!/usr/bin/env bash

# scoder-git - policy-enforcing git wrapper for scoder sandboxes.
# Intended to be mounted over /usr/bin/git inside scoder, with the real git
# binary provided through SCODER_REAL_GIT.

set -Eeuo pipefail

readonly PROGRAM_NAME="scoder-git"
readonly PROGRAM_VERSION="0.1.0"

error() {
    printf '%s: %s\n' "${PROGRAM_NAME}" "$*" >&2
}

deny() {
    local message="${PROGRAM_NAME}: Denied $*"
    printf '%s\n' "${message}" >&2
    printf '%s\n' "${message}"
    exit 126
}

deny_run_outside_scoder() {
    local command_text="$1"
    local -a lines=(
        "fatal: scoder blocked ${command_text}; no ${command_text#git } was performed"
        "fatal: run ${command_text} outside scoder if you really want to ${command_text#git }"
    )
    printf '%s\n' "${lines[@]}" >&2
    printf '%s\n' "${lines[@]}"
    exit 128
}

find_real_git() {
    if [[ -n "${SCODER_REAL_GIT:-}" ]]; then
        if [[ -x "${SCODER_REAL_GIT}" ]]; then
            printf '%s\n' "${SCODER_REAL_GIT}"
            return 0
        fi

        error "SCODER_REAL_GIT is not executable: ${SCODER_REAL_GIT}"
        exit 127
    fi

    local candidate
    for candidate in /usr/libexec/scoder/real-git /usr/bin/git /bin/git; do
        if [[ -x "${candidate}" && "$(realpath "$candidate")" != "$(realpath "$0")" ]]; then
            printf '%s\n' "${candidate}"
            return 0
        fi
    done

    error "real git binary not found"
    exit 127
}

arg_present() {
    local needle="$1"
    shift

    local arg
    for arg in "$@"; do
        if [[ "${arg}" == "${needle}" ]]; then
            return 0
        fi
    done

    return 1
}

split_global_options() {
    GLOBAL_GIT_ARGS=()
    REMAINING_GIT_ARGS=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
        -C)
            if [[ $# -lt 2 ]]; then
                deny "git -C without path"
            fi
            GLOBAL_GIT_ARGS+=("$1" "$2")
            shift 2
            ;;
        --git-dir | --work-tree | --namespace | --super-prefix)
            if [[ $# -lt 2 ]]; then
                deny "git global option ${1} without value"
            fi
            GLOBAL_GIT_ARGS+=("$1" "$2")
            shift 2
            ;;
        --git-dir=* | --work-tree=* | --namespace=* | --super-prefix=*)
            GLOBAL_GIT_ARGS+=("$1")
            shift
            ;;
        -c)
            if [[ $# -lt 2 ]]; then
                deny "git -c without key=value"
            fi
            case "$2" in
            user.name=* | user.email=* | author.name=* | author.email=* | committer.name=* | committer.email=*)
                GLOBAL_GIT_ARGS+=("$1" "$2")
                shift 2
                ;;
            core.hooksPath=* | commit.gpgsign=* | core.editor=*)
                deny "git global config override blocked: $2"
                ;;
            *)
                deny "git global config not allowlisted: $2"
                ;;
            esac
            ;;
        --config=*)
            case "${1#--config=}" in
            user.name=* | user.email=* | author.name=* | author.email=* | committer.name=* | committer.email=*)
                GLOBAL_GIT_ARGS+=("$1")
                shift
                ;;
            core.hooksPath=* | commit.gpgsign=* | core.editor=*)
                deny "git global config override blocked: ${1#--config=}"
                ;;
            *)
                deny "git global config not allowlisted: ${1#--config=}"
                ;;
            esac
            ;;
        --)
            shift
            REMAINING_GIT_ARGS+=("$@")
            return 0
            ;;
        *)
            REMAINING_GIT_ARGS=("$@")
            return 0
            ;;
        esac
    done
}

 
 
 



is_identity_config_key() {
    case "$1" in
    user.name | user.email | author.name | author.email | committer.name | committer.email)
        return 0
        ;;
    *)
        return 1
        ;;
    esac
}

validate_config_args() {
    if [[ $# -eq 0 ]]; then
        deny "git config without key"
    fi

    case "$1" in
    --global | --system | --file | --blob | --includes | --edit | -e)
        deny "git config option blocked: $1"
        ;;
    --file=* | --blob=*)
        deny "git config option blocked: ${1%%=*}"
        ;;
    --local)
        shift
        ;;
    --get)
        shift
        if [[ $# -ne 1 ]] || ! is_identity_config_key "$1"; then
            deny "git config --get only allows identity keys"
        fi
        return 0
        ;;
    esac

    if [[ $# -lt 1 ]] || ! is_identity_config_key "$1"; then
        deny "git config only allows local identity keys"
    fi
}

validate_switch_args() {
    local create_mode=0
    local branch_count=0
    local arg

    if [[ $# -eq 0 ]]; then
        deny "git switch without branch"
    fi

    while [[ $# -gt 0 ]]; do
        arg="$1"
        case "${arg}" in
        -)
            branch_count=$((branch_count + 1))
            shift
            ;;
        -c | --create)
            if [[ "${create_mode}" -eq 1 ]]; then
                deny "git switch duplicate create option"
            fi
            if [[ $# -lt 2 ]]; then
                deny "git switch ${arg} without branch"
            fi
            create_mode=1
            branch_count=$((branch_count + 1))
            shift 2
            ;;
        --create=*)
            if [[ "${create_mode}" -eq 1 ]]; then
                deny "git switch duplicate create option"
            fi
            if [[ -z "${arg#--create=}" ]]; then
                deny "git switch --create without branch"
            fi
            create_mode=1
            branch_count=$((branch_count + 1))
            shift
            ;;
        --quiet)
            shift
            ;;
        --discard-changes | --force | -f | --detach | --merge | -m | --orphan | --guess | --no-guess | --ignore-other-worktrees | --recurse-submodules | --no-recurse-submodules)
            deny "git switch unsafe option: ${arg}"
            ;;
        --*)
            deny "git switch option not allowlisted: ${arg}"
            ;;
        -*)
            deny "git switch option not allowlisted: ${arg}"
            ;;
        *)
            branch_count=$((branch_count + 1))
            shift
            ;;
        esac
    done

    if [[ "${branch_count}" -ne 1 ]]; then
        deny "git switch expects exactly one branch"
    fi
}

validate_add_paths() {
    local real_git="$1"
    shift

    local -a scoped_git_args=()
    local -a scoped_cwd=("${PWD}")
    while [[ $# -gt 0 ]]; do
        if [[ "$1" == "--" ]]; then
            shift
            break
        fi

        scoped_git_args+=("$1")
        shift
    done

    local cwd_arg="${scoped_cwd[@]}"
    local i=0
    local scoped_arg
    while [[ ${i} -lt ${#scoped_git_args[@]} ]]; do
        scoped_arg="${scoped_git_args[${i}]}"
        if [[ "${scoped_arg}" == "-C" ]]; then
            i=$((i + 1))
            if [[ ${i} -lt ${#scoped_git_args[@]} ]]; then
                cwd_arg="${scoped_git_args[${i}]}"
            fi
        fi
        i=$((i + 1))
    done

    local check_base="${cwd_arg}"
    if [[ "${cwd_arg}" = /* ]]; then
        check_base="$(realpath -m -- "${cwd_arg}")"
    else
        check_base="$(realpath -m -- "${PWD}/${cwd_arg}")"
    fi

    local repo_root
    if ! repo_root="$(${real_git} "${scoped_git_args[@]}" rev-parse --show-toplevel 2>/dev/null)"; then
        deny "git add outside a repository"
    fi

    local arg
    local resolved_path
    for arg in "$@"; do
        case "${arg}" in
        -A | --all | -u | --update | . | :/*)
            continue
            ;;
        --)
            continue
            ;;
        -*)
            continue
            ;;
        esac

        if [[ "${arg}" = /* ]]; then
            resolved_path="$(realpath -m -- "${arg}")"
        else
            resolved_path="$(realpath -m -- "${check_base}/${arg}")"
        fi

        if [[ "${resolved_path}" != "${repo_root}" && "${resolved_path}" != "${repo_root}"/* ]]; then
            deny "git add path outside repo: ${arg}"
        fi
    done
}

validate_commit_file_paths() {
    local real_git="$1"
    shift

    local -a scoped_git_args=()
    local -a scoped_cwd=("${PWD}")
    while [[ $# -gt 0 ]]; do
        if [[ "$1" == "--" ]]; then
            shift
            break
        fi

        scoped_git_args+=("$1")
        shift
    done

    local cwd_arg="${scoped_cwd[@]}"
    local i=0
    local scoped_arg
    while [[ ${i} -lt ${#scoped_git_args[@]} ]]; do
        scoped_arg="${scoped_git_args[${i}]}"
        if [[ "${scoped_arg}" == "-C" ]]; then
            i=$((i + 1))
            if [[ ${i} -lt ${#scoped_git_args[@]} ]]; then
                cwd_arg="${scoped_git_args[${i}]}"
            fi
        fi
        i=$((i + 1))
    done

    local check_base="${cwd_arg}"
    if [[ "${cwd_arg}" = /* ]]; then
        check_base="$(realpath -m -- "${cwd_arg}")"
    else
        check_base="$(realpath -m -- "${PWD}/${cwd_arg}")"
    fi

    local repo_root
    if ! repo_root="$(${real_git} "${scoped_git_args[@]}" rev-parse --show-toplevel 2>/dev/null)"; then
        deny "git commit -F outside a repository"
    fi

    local index=1
    local arg
    local message_file
    local resolved_path
    while [[ ${index} -le $# ]]; do
        arg="${!index}"
        case "${arg}" in
        -F | --file)
            index=$((index + 1))
            if [[ ${index} -gt $# ]]; then
                deny "git commit ${arg} without a message file"
            fi
            message_file="${!index}"
            if [[ "${message_file}" = /* ]]; then
                resolved_path="$(realpath -m -- "${message_file}")"
            else
                resolved_path="$(realpath -m -- "${check_base}/${message_file}")"
            fi
            if [[ "${resolved_path}" != "${repo_root}" && "${resolved_path}" != "${repo_root}"/* ]]; then
                deny "git commit message file outside repo: ${message_file}"
            fi
            ;;
        --file=*)
            message_file="${arg#--file=}"
            if [[ "${message_file}" = /* ]]; then
                resolved_path="$(realpath -m -- "${message_file}")"
            else
                resolved_path="$(realpath -m -- "${check_base}/${message_file}")"
            fi
            if [[ "${resolved_path}" != "${repo_root}" && "${resolved_path}" != "${repo_root}"/* ]]; then
                deny "git commit message file outside repo: ${message_file}"
            fi
            ;;
        esac
        index=$((index + 1))
    done
}

main() {
    if [[ "${1:-}" == "--scoder-git-version" ]]; then
        printf '%s %s\n' "${PROGRAM_NAME}" "${PROGRAM_VERSION}"
        return 0
    fi

    local real_git
    real_git="$(find_real_git)"

    local -a GLOBAL_GIT_ARGS=()
    local -a REMAINING_GIT_ARGS=()
    split_global_options "$@"
    set -- "${REMAINING_GIT_ARGS[@]}"

    local subcommand="${1:-}"
    if [[ -z "${subcommand}" ]]; then
        exec "${real_git}"
    fi

    case "${subcommand}" in
    init)
        exec "${real_git}" "${GLOBAL_GIT_ARGS[@]}" "$@"
        ;;
    config)
        validate_config_args "${@:2}"
        exec "${real_git}" "${GLOBAL_GIT_ARGS[@]}" "$@"
        ;;
    status | diff | log | show | branch | rev-parse | merge-base | for-each-ref | symbolic-ref | cat-file | name-rev | ls-files)
        exec "${real_git}" "${GLOBAL_GIT_ARGS[@]}" "$@"
        ;;
    remote)
        case "${2:-}" in
        "" | -v)
            exec "${real_git}" "${GLOBAL_GIT_ARGS[@]}" "$@"
            ;;
        *)
            deny "git remote ${2:-}"
            ;;
        esac
        ;;
    worktree)
        case "${2:-}" in
        list | add | remove | move | prune | repair | lock | unlock)
            exec "${real_git}" "${GLOBAL_GIT_ARGS[@]}" "$@"
            ;;
        *)
            deny "git worktree ${2:-}"
            ;;
        esac
        ;;
    maintenance)
        case "${2:-}" in
        run)
            exec "${real_git}" "${GLOBAL_GIT_ARGS[@]}" "$@"
            ;;
        *)
            deny "git maintenance ${2:-}"
            ;;
        esac
        ;;
    add)
        validate_add_paths "${real_git}" "${GLOBAL_GIT_ARGS[@]}" -- "${@:2}"
        exec "${real_git}" "${GLOBAL_GIT_ARGS[@]}" "$@"
        ;;
    commit)
        if arg_present --amend "${@:2}" || arg_present -c "${@:2}" || arg_present -C "${@:2}"; then
            deny "git commit history rewrite/reuse options"
        fi

        if ! arg_present -m "${@:2}" && ! arg_present -F "${@:2}"; then
            deny "git commit without explicit -m or -F"
        fi

        validate_commit_file_paths "${real_git}" "${GLOBAL_GIT_ARGS[@]}" -- "${@:2}"

        exec "${real_git}" \
            "${GLOBAL_GIT_ARGS[@]}" \
            -c core.hooksPath=/dev/null \
            -c commit.gpgsign=false \
            -c core.editor=true \
            "$@"
        ;;
    switch)
        validate_switch_args "${@:2}"
        exec "${real_git}" "${GLOBAL_GIT_ARGS[@]}" "$@"
        ;;
    push | pull | fetch | rebase | reset | clean | merge | cherry-pick | revert | tag | checkout)
        deny_run_outside_scoder "git ${subcommand}"
        ;;
    *)
        deny "unknown git command: git ${subcommand}"
        ;;
    esac
}

main "$@"
