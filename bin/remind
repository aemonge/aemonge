#!/usr/bin/env bash
# remind - Quick reference for commonly forgotten commands
# Usage: remind [category|file]
# Categories: markdown, db, pdf, zsh, containers, security, cloud, network

set -euo pipefail

VERSION="2.2.1"
SCRIPT_NAME="$(basename "$0")"

# Colors for output
if [[ -t 1 ]]; then
    DIM='\033[2m'
    RESET='\033[0m'
    BLUE='\033[34m'
    GREEN='\033[32m'
    YELLOW='\033[33m'
    RED='\033[31m'
else
    DIM='' RESET='' BLUE='' GREEN='' YELLOW='' RED=''
fi

show_version() {
    echo "$SCRIPT_NAME version $VERSION"
}

show_help() {
    cat <<EOF
Usage: $SCRIPT_NAME [OPTIONS] [category|file]

Quick reference for commonly forgotten commands.

Options:
  -h, --help       Show this help message
  -v, --version    Show version information
  -i, --install    Show installation commands for a category

Examples:
  $SCRIPT_NAME             # Show all categories
  $SCRIPT_NAME db          # Show database commands
  $SCRIPT_NAME -i db       # Show database install commands
  $SCRIPT_NAME file.db     # Auto-detect category from file extension
EOF
}

# ============================================================================
# MARKDOWN CATEGORY
# ============================================================================

show_markdown_help() {
    echo -e "${BLUE}pandoc input.md -o output.pdf${RESET}"
    echo -e "${DIM}# Convert Markdown to PDF via LaTeX${RESET}"
    echo ""
    echo -e "${BLUE}pandoc input.md -o output.pdf --pdf-engine=weasyprint${RESET}"
    echo -e "${DIM}# Convert using WeasyPrint (CSS-based, no LaTeX)${RESET}"
    echo ""
    echo -e "${BLUE}pandoc input.md -o output.html${RESET}"
    echo -e "${DIM}# Convert to HTML${RESET}"
}

show_markdown_install() {
    echo -e "${GREEN}Install pandoc:${RESET}"
    echo -e "  ${BLUE}pamac install pandoc${RESET}"
    echo ""
    echo -e "${DIM}For WeasyPrint backend:${RESET}"
    echo -e "  ${BLUE}pip install weasyprint${RESET}"
}

# ============================================================================
# DB CATEGORY
# ============================================================================

show_db_help() {
    echo -e "${BLUE}sqlit file.db${RESET}"
    echo -e "${DIM}# Open a SQLite database in a TUI browser${RESET}"
    echo ""
    echo -e "${BLUE}sqlite3 file.db${RESET}"
    echo -e "${DIM}# Open raw SQLite3 shell${RESET}"
    echo ""
    echo -e "${BLUE}sqlite3 file.db .tables${RESET}"
    echo -e "${DIM}# List tables${RESET}"
    echo ""
    echo -e "${BLUE}sqlite3 file.db .dump${RESET}"
    echo -e "${DIM}# Dump full SQL${RESET}"
}

show_db_install() {
    echo -e "${GREEN}Install sqlit (TUI browser):${RESET}"
    echo -e "  ${BLUE}cargo install sqlit${RESET}"
    echo ""
    echo -e "${GREEN}Install sqlite3 CLI:${RESET}"
    echo -e "  ${BLUE}pamac install sqlite${RESET}"
}

# ============================================================================
# PDF CATEGORY
# ============================================================================

show_pdf_help() {
    echo -e "${BLUE}pdftk input1.pdf input2.pdf cat output merged.pdf${RESET}"
    echo -e "${DIM}# Merge PDFs${RESET}"
    echo ""
    echo -e "${BLUE}pdftk input.pdf burst${RESET}"
    echo -e "${DIM}# Split into individual pages${RESET}"
    echo ""
    echo -e "${BLUE}gs -sDEVICE=pdfwrite -dNOPAUSE -dBATCH -dSAFER -sOutputFile=out.pdf in.pdf${RESET}"
    echo -e "${DIM}# Compress PDF with Ghostscript${RESET}"
    echo ""
    echo -e "${BLUE}pdftotext input.pdf -${RESET}"
    echo -e "${DIM}# Extract text to stdout${RESET}"
}

show_pdf_install() {
    echo -e "${GREEN}Install PDF tools:${RESET}"
    echo -e "  ${BLUE}pamac install pdftk ghostscript poppler${RESET}"
}

# ============================================================================
# ZSH / SHELL CATEGORY
# ============================================================================

show_zsh_help() {
    echo -e "${BLUE}atuin search ${RESET}"
    echo -e "${DIM}# Search shell history (sync optional)${RESET}"
    echo ""
    echo -e "${BLUE}zoxide query ${RESET}"
    echo -e "${DIM}# Smarter cd${RESET}"
    echo ""
    echo -e "${BLUE}eza -lah --git${RESET}"
    echo -e "${DIM}# Modern ls replacement${RESET}"
    echo ""
    echo -e "${BLUE}bat file.txt${RESET}"
    echo -e "${DIM}# cat with syntax highlighting${RESET}"
    echo ""
    echo -e "${BLUE}sem diff HEAD~1${RESET}"
    echo -e "${DIM}# Semantic diff with entity-level changes${RESET}"
}

show_zsh_install() {
    echo -e "${GREEN}Install modern CLI tools:${RESET}"
    echo -e "  ${BLUE}pamac install atuin zoxide eza bat fd ripgrep fzf${RESET}"
    echo -e "  ${BLUE}cargo install sem${RESET} ${DIM}# Semantic diff CLI${RESET}"
}

# ============================================================================
# CONTAINERS CATEGORY
# ============================================================================

show_containers_help() {
    echo -e "${BLUE}podman ps -a${RESET}"
    echo -e "${DIM}# List containers${RESET}"
    echo ""
    echo -e "${BLUE}podman images${RESET}"
    echo -e "${DIM}# List images${RESET}"
    echo ""
    echo -e "${BLUE}podman compose up -d${RESET}"
    echo -e "${DIM}# Bring up a compose stack${RESET}"
}

show_containers_install() {
    echo -e "${GREEN}Install Podman stack:${RESET}"
    echo -e "  ${BLUE}pamac install podman podman-compose buildah${RESET}"
}

# ============================================================================
# SECURITY CATEGORY
# ============================================================================

show_security_help() {
    echo -e "${BLUE}bwrap --ro-bind /usr /usr --ro-bind /lib /lib --ro-bind /lib64 /lib64 --proc /proc --dev /dev --tmpfs /tmp --unshare-all --die-with-parent --new-session ${RESET}"
    echo -e "${DIM}# Bubblewrap sandbox example${RESET}"
    echo ""
    echo -e "${BLUE}landrun --config ${RESET}"
    echo -e "${DIM}# Landrun (Landlock) sandbox with a config profile${RESET}"
}

show_security_install() {
    echo -e "${GREEN}Bubblewrap:${RESET}"
    echo -e "  ${BLUE}pamac install bubblewrap${RESET}"
    echo ""
    echo -e "${DIM}Note: Some hardened setups may need bubblewrap-suid (if available).${RESET}"
    echo ""
    echo -e "${GREEN}Landrun:${RESET}"
    echo -e "  ${BLUE}yay -S landrun${RESET} ${DIM}# From AUR${RESET}"
    echo ""
    echo -e "${DIM}Or install from source:${RESET}"
    echo -e "  ${BLUE}git clone https://github.com/Zouuup/landrun${RESET}"
    echo -e "  ${BLUE}cd landrun && go build && sudo cp landrun /usr/local/bin/${RESET}"
    echo ""
    echo -e "${DIM}Requirements: Linux kernel >= 5.13 (for Landlock support)${RESET}"
}

# ============================================================================
# CLOUD CATEGORY
# ============================================================================

show_cloud_help() {
    echo -e "${BLUE}pcloud-drive${RESET}"
    echo -e "${DIM}# Official pCloud client (set-and-forget daemon with Crypto support)${RESET}"
}

show_cloud_install() {
    echo -e "${GREEN}Install pCloud Drive:${RESET}"
    echo -e "  ${BLUE}pamac build pcloud-drive${RESET}"
}

# ============================================================================
# NETWORK CATEGORY
# ============================================================================

show_network_help() {
    echo -e "${BLUE}sudo systemctl restart NetworkManager${RESET}"
    echo -e "${DIM}# Restart NetworkManager (drops active connections briefly)${RESET}"
    echo ""
    echo -e "${BLUE}sudo systemctl reload NetworkManager${RESET}"
    echo -e "${DIM}# Reload config without full restart${RESET}"
    echo ""
    echo -e "${BLUE}systemctl status NetworkManager${RESET}"
    echo -e "${DIM}# Check NetworkManager status${RESET}"
    echo ""
    echo -e "${BLUE}sudo systemctl restart systemd-networkd${RESET}"
    echo -e "${DIM}# If using systemd-networkd instead of NetworkManager${RESET}"
    echo ""
    echo -e "${BLUE}sudo resolvectl flush-caches${RESET}"
    echo -e "${DIM}# Flush DNS resolver cache (/etc/resolv.conf stale)${RESET}"
    echo ""
    echo -e "${DIM}Note: restart drops active connections — avoid over SSH${RESET}"
}

show_network_install() {
    echo -e "${GREEN}NetworkManager is installed by default on Manjaro desktops.${RESET}"
    echo -e "  ${BLUE}pamac install networkmanager${RESET}"
}

# ============================================================================
# MAIN LOGIC
# ============================================================================

show_all_categories() {
    echo "Categories:"
    echo -e "  ${YELLOW}markdown${RESET}, ${YELLOW}md${RESET}               Markdown to PDF conversion"
    echo -e "  ${YELLOW}cloud${RESET}                    Cloud storage tools (pCloud)"
    echo -e "  ${YELLOW}db${RESET}, ${YELLOW}sql${RESET}, ${YELLOW}sqlite${RESET}          Database browser (sqlit)"
    echo -e "  ${YELLOW}pdf${RESET}                      PDF manipulation (merge/split/etc)"
    echo -e "  ${YELLOW}zsh${RESET}, ${YELLOW}shell${RESET}               Modern shell utilities & CLI tools"
    echo -e "  ${YELLOW}containers${RESET}               Container management (Podman)"
    echo -e "  ${YELLOW}security${RESET}                 Sandboxing tools (bubblewrap, landrun)"
    echo -e "  ${YELLOW}network${RESET}, ${YELLOW}net${RESET}, ${YELLOW}nm${RESET}         Network/DNS management (NetworkManager)"
    echo ""
    echo "Usage:"
    echo "  $SCRIPT_NAME [category]"
    echo "  $SCRIPT_NAME -i [category]  # Show installation commands"
}

detect_category() {
    local input="$1"

    case "$input" in
    cloud | pcloud)
        echo "cloud"
        ;;
    db | sql | sqlite | sqlit | *.db | *.sqlite | *.sqlite3)
        echo "db"
        ;;
    network | net | nm | dns | resolv | networkmanager | systemd-networkd)
        echo "network"
        ;;
    *.md | markdown | md)
        echo "markdown"
        ;;
    *.pdf | pdf)
        echo "pdf"
        ;;
    zsh | shell | cli)
        echo "zsh"
        ;;
    containers | podman | docker)
        echo "containers"
        ;;
    security | sandbox | bwrap | bubblewrap | landrun)
        echo "security"
        ;;
    *)
        echo "$input"
        ;;
    esac
}

main() {
    local category=""
    local show_install=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
        -h | --help)
            show_help
            exit 0
            ;;
        -v | --version)
            show_version
            exit 0
            ;;
        -i | --install)
            show_install=true
            shift
            ;;
        -*)
            echo "Error: Unknown option: $1" >&2
            echo "Run '$SCRIPT_NAME --help' for usage information" >&2
            exit 1
            ;;
        *)
            category="$1"
            shift
            ;;
        esac
    done

    # If no category provided, show all
    if [[ -z "$category" ]]; then
        show_all_categories
        exit 0
    fi

    # Detect category from input
    category="$(detect_category "$category")"

    case "$category" in
    db)
        if [[ "$show_install" == true ]]; then
            show_db_install
        else
            show_db_help
        fi
        ;;
    markdown | md)
        if [[ "$show_install" == true ]]; then
            show_markdown_install
        else
            show_markdown_help
        fi
        ;;
    network)
        if [[ "$show_install" == true ]]; then
            show_network_install
        else
            show_network_help
        fi
        ;;
    pdf)
        if [[ "$show_install" == true ]]; then
            show_pdf_install
        else
            show_pdf_help
        fi
        ;;
    zsh)
        if [[ "$show_install" == true ]]; then
            show_zsh_install
        else
            show_zsh_help
        fi
        ;;
    containers)
        if [[ "$show_install" == true ]]; then
            show_containers_install
        else
            show_containers_help
        fi
        ;;
    security)
        if [[ "$show_install" == true ]]; then
            show_security_install
        else
            show_security_help
        fi
        ;;
    cloud)
        if [[ "$show_install" == true ]]; then
            show_cloud_install
        else
            show_cloud_help
        fi
        ;;
    *)
        echo "Error: Unknown category '$category'" >&2
        echo "Run '$SCRIPT_NAME --help' for available categories" >&2
        exit 1
        ;;
    esac
}

main "$@"
