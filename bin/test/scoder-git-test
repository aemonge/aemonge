#!/usr/bin/env bash
set -Eeuo pipefail

readonly SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
readonly SCODER_GIT="$(cd -- "${SCRIPT_DIR}/.." && pwd -P)/scoder-git"

FAILED=0

fail() {
    printf '❌ %s\n' "$*" >&2
    FAILED=$((FAILED + 1))
}

pass() {
    printf '✅ %s\n' "$*"
}

run_scoder_git() {
    local tmpdir="$1"
    shift

    SCODER_REAL_GIT="${tmpdir}/fake-git" \
        SCODER_GIT_TEST_LOG="${tmpdir}/git.log" \
        "${SCODER_GIT}" "$@"
}

assert_denied() {
    local tmpdir="$1"
    local name="$2"
    shift 2

    local output=""
    if output="$(run_scoder_git "${tmpdir}" "$@" 2>&1)"; then
        fail "${name}: command unexpectedly succeeded"
        return
    fi

    if grep -qE 'Denied|BLOCKED|fatal: scoder blocked' <<<"${output}"; then
        pass "${name}"
    else
        fail "${name}: expected denial, got: ${output}"
    fi
}

assert_denied_stdout_visible() {
    local tmpdir="$1"
    local name="$2"
    shift 2

    local stdout_file="${tmpdir}/stdout.txt"
    local stderr_file="${tmpdir}/stderr.txt"
    local status=0

    run_scoder_git "${tmpdir}" "$@" >"${stdout_file}" 2>"${stderr_file}" || status=$?

    if [[ "${status}" -eq 0 ]]; then
        fail "${name}: command unexpectedly succeeded"
        return
    fi

    if grep -qE 'Denied|BLOCKED|fatal: scoder blocked' "${stdout_file}" && grep -qE 'Denied|BLOCKED|fatal: scoder blocked' "${stderr_file}"; then
        pass "${name}"
    else
        fail "${name}: denial not visible on both stdout and stderr (stdout=$(<"${stdout_file}"), stderr=$(<"${stderr_file}"))"
    fi
}

assert_push_denied_as_fatal() {
    local tmpdir="$1"
    local name="$2"

    local output=""
    local status=0
    output="$(run_scoder_git "${tmpdir}" push 2>&1)" || status=$?

    if [[ "${status}" -ne 128 ]]; then
        fail "${name}: expected exit 128, got ${status}; output=${output}"
        return
    fi

    if [[ "${output}" == *"fatal: scoder blocked git push"* && \
        "${output}" == *"no push was performed"* ]]; then
        pass "${name}"
    else
        fail "${name}: missing fatal blocked push message; output=${output}"
    fi
}

assert_allowed() {
    local tmpdir="$1"
    local name="$2"
    shift 2

    local output=""
    if ! output="$(run_scoder_git "${tmpdir}" "$@" 2>&1)"; then
        fail "${name}: command failed: ${output}"
        return
    fi

    if grep -q '^REAL_GIT ' "${tmpdir}/git.log"; then
        pass "${name}"
    else
        fail "${name}: real git was not invoked"
    fi
}

assert_commit_hardened() {
    local tmpdir="$1"
    local name="$2"
    shift 2

    : >"${tmpdir}/git.log"
    assert_allowed "${tmpdir}" "${name}" "$@"

    local log_content
    log_content="$(<"${tmpdir}/git.log")"
    if [[ "${log_content}" == *'-c core.hooksPath=/dev/null'* && \
        "${log_content}" == *'-c commit.gpgsign=false'* && \
        "${log_content}" == *'-c core.editor=true'* ]]; then
        pass "${name}: commit hardening flags present"
    else
        fail "${name}: missing commit hardening flags: ${log_content}"
    fi
}

main() {
    if [[ ! -x "${SCODER_GIT}" ]]; then
        fail "scoder-git executable is missing: ${SCODER_GIT}"
        return 1
    fi

    local tmpdir
    tmpdir="$(mktemp -d)"
    trap "rm -rf -- '${tmpdir}'" EXIT

    cat >"${tmpdir}/fake-git" <<'FAKE_GIT'
#!/usr/bin/env bash
set -Eeuo pipefail
printf 'REAL_GIT %q' "$0" >>"${SCODER_GIT_TEST_LOG}"
printf ' %q' "$@" >>"${SCODER_GIT_TEST_LOG}"
printf '\n' >>"${SCODER_GIT_TEST_LOG}"
    scope_dir=""
    first_arg="${1:-}"
    second_arg="${2:-}"

    if [[ "${first_arg}" == "-C" ]]; then
        scope_dir="${second_arg}"
        shift 2
        first_arg="${1:-}"
    fi

    case "${first_arg}" in
    rev-parse)
        if [[ "${2:-}" == "--show-toplevel" ]]; then
            if [[ -n "${scope_dir}" ]]; then
                if [[ "${scope_dir}" = /* ]]; then
                    realpath -m -- "${scope_dir}"
                else
                    realpath -m -- "${PWD}/${scope_dir}"
                fi
            else
                pwd
            fi
            exit 0
        fi
        ;;
    esac

    # Keep fake git permissive for all other invocations.
    :
exit 0
FAKE_GIT
    chmod +x "${tmpdir}/fake-git"
    : >"${tmpdir}/git.log"

    assert_allowed "${tmpdir}" "allows git status" status
    assert_allowed "${tmpdir}" "allows git diff" diff -- README.md
    assert_allowed "${tmpdir}" "allows git merge-base" merge-base main feature/test
    assert_allowed "${tmpdir}" "allows git merge-base --is-ancestor" merge-base --is-ancestor main feature/test
    assert_allowed "${tmpdir}" "allows git for-each-ref" for-each-ref refs/heads
    assert_allowed "${tmpdir}" "allows git symbolic-ref" symbolic-ref --short HEAD
    assert_allowed "${tmpdir}" "allows git cat-file" cat-file -e 'HEAD^{commit}'
    assert_allowed "${tmpdir}" "allows git name-rev" name-rev --name-only HEAD
    assert_allowed "${tmpdir}" "allows git worktree list" worktree list
    assert_allowed "${tmpdir}" "allows git worktree add" worktree add ../x
    assert_allowed "${tmpdir}" "allows git worktree remove" worktree remove ../x
    assert_allowed "${tmpdir}" "allows git worktree move" worktree move ../x ../y
    assert_allowed "${tmpdir}" "allows git worktree prune" worktree prune
    assert_allowed "${tmpdir}" "allows git worktree repair" worktree repair
    assert_allowed "${tmpdir}" "allows git worktree lock" worktree lock ../x
    assert_allowed "${tmpdir}" "allows git worktree unlock" worktree unlock ../x
    assert_allowed "${tmpdir}" "allows git maintenance run" maintenance run --auto
    assert_allowed "${tmpdir}" "allows git switch to branch" switch safe-target
    assert_allowed "${tmpdir}" "allows git switch --quiet to branch" switch --quiet safe-target
    assert_allowed "${tmpdir}" "allows git switch -c" switch -c safe-created
    assert_allowed "${tmpdir}" "allows git switch --quiet -c" switch --quiet -c safe-created-quiet
    assert_allowed "${tmpdir}" "allows git switch --create" switch --create safe-created-long
    assert_allowed "${tmpdir}" "allows git switch - to previous branch" switch -
    assert_allowed "${tmpdir}" "allows git add inside repo" add .
    assert_allowed "${tmpdir}" "allows git add with global -C" -C "${tmpdir}" add .
    assert_commit_hardened "${tmpdir}" "allows normal git commit" commit -m 'safe commit'
    assert_commit_hardened "${tmpdir}" "allows git global -c before commit" -c user.name=OpenAgent -c user.email=openagent@example.com commit -m 'safe commit'
    assert_allowed "${tmpdir}" "allows git commit -F with global -C" -C "${tmpdir}" commit -F commit-message.txt

    assert_denied "${tmpdir}" "denies git push" push
    assert_denied_stdout_visible "${tmpdir}" "denial is visible on stdout and stderr" push
    assert_push_denied_as_fatal "${tmpdir}" "git push is reported as fatal blocked failure"
    assert_denied "${tmpdir}" "denies git pull" pull
    assert_denied "${tmpdir}" "denies git rebase" rebase main
    assert_denied "${tmpdir}" "denies git reset" reset --hard
    assert_denied "${tmpdir}" "denies git clean" clean -fd
    assert_denied "${tmpdir}" "denies git commit --amend" commit --amend
    assert_denied "${tmpdir}" "denies git switch --force" switch --force safe-target
    assert_denied "${tmpdir}" "denies git switch --detach" switch --detach HEAD
    assert_denied "${tmpdir}" "denies git switch extra arg" switch safe-target extra
    assert_denied "${tmpdir}" "denies git switch without branch" switch
    assert_denied "${tmpdir}" "denies git commit -F outside repo" commit -F /tmp/scoder-outside-message
    assert_denied "${tmpdir}" "denies git global unsafe -c" -c core.hooksPath=.githooks commit -m unsafe
    assert_denied "${tmpdir}" "denies git maintenance register" maintenance register
    assert_denied "${tmpdir}" "denies unknown git worktree subcommand" worktree bogus
    assert_denied "${tmpdir}" "denies unknown git subcommand" daemon

    if [[ "${FAILED}" -eq 0 ]]; then
        printf '🎉 scoder-git focused tests passed\n'
        return 0
    fi

    printf '⚠️  %d scoder-git focused test(s) failed\n' "${FAILED}" >&2
    return 1
}

main "$@"
