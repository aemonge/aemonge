#!/usr/bin/env bash
set -Eeuo pipefail

readonly SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
readonly SCODER="${SCRIPT_DIR}/../scoder"

if grep -q '^ALLOW_GIT=1$' "${SCODER}"; then
    printf '✅ scoder defaults .git writable for scoder-git managed commands\n'
else
    printf '❌ scoder still defaults .git read-only; git add/commit cannot work by default\n' >&2
    exit 1
fi

if grep -q 'HOST_HOME}/\.gitconfig' "${SCODER}" && grep -q 'HOST_HOME}/\.config/git/config' "${SCODER}"; then
    printf '✅ scoder binds host git identity config read-only\n'
else
    printf '❌ scoder does not bind host git identity config\n' >&2
    exit 1
fi

if grep -q 'OPENSPEC_CONFIG_DIR="${HOME}/\.config/openspec"' "${SCODER}" && \
    grep -q 'SANDBOX_OPENSPEC_CONFIG_DIR="${SANDBOX_CONFIG_DIR}/openspec"' "${SCODER}" && \
    grep -q -- '--bind "${OPENSPEC_CONFIG_DIR}" "${SANDBOX_OPENSPEC_CONFIG_DIR}"' "${SCODER}" && \
    grep -q 'test -w "$HOME/\.config/openspec"' "${SCODER}"; then
    printf '✅ scoder binds OpenSpec config as writable runtime state\n'
else
    printf '❌ scoder does not bind OpenSpec config as writable runtime state\n' >&2
    exit 1
fi

if grep -q 'bind_symlink_targets_in_dir "${OPENCODE_CONFIG_DIR}/agent"' "${SCODER}" && \
    grep -q 'bind_symlink_targets_in_dir "${OPENCODE_CONFIG_DIR}/agents"' "${SCODER}"; then
    printf '✅ scoder binds symlink targets in global OpenCode agent directories\n'
else
    printf '❌ scoder does not bind symlink targets in global OpenCode agent directories\n' >&2
    exit 1
fi

if grep -q 'RUSTUP_HOME | CARGO_HOME | GOPATH | GOBIN' "${SCODER}" && \
    grep -q 'select_host_tool_home.*\.local/share/rustup.*\.rustup' "${SCODER}" && \
    grep -q 'select_host_tool_home.*\.local/share/cargo.*\.cargo' "${SCODER}" && \
    grep -q -- '--setenv CARGO_HOME' "${SCODER}"; then
    printf '✅ scoder auto-detects XDG Rust/Cargo/Go tool homes\n'
else
    printf '❌ scoder does not auto-detect XDG Rust/Cargo/Go tool homes\n' >&2
    exit 1
fi

if grep -q 'cargo locate-project --workspace --manifest-path' "${SCODER}" && \
    grep -q 'find_cargo_path_dependency_root' "${SCODER}" && \
    grep -q 'common_ancestor_path' "${SCODER}" && \
    grep -q 'workspace_root=""' "${SCODER}" && \
    grep -q 'workspace_root="${TARGET_PARENT_DIR}"' "${SCODER}" && \
    grep -q 'Detected Cargo workspace root' "${SCODER}" && \
    grep -q 'SANDBOX_WORKDIR="${TARGET_PATH}"' "${SCODER}" && \
    grep -q 'SANDBOX_PROJECT_ROOT}/${file}' "${SCODER}"; then
    printf '✅ scoder expands Cargo subcrate targets to workspace root\n'
else
    printf '❌ scoder does not expand Cargo subcrate targets to workspace root\n' >&2
    exit 1
fi

if grep -q 'SCODER_TMPDIR="/tmp/scoder-\$\$"' "${SCODER}" && \
    grep -q -- '--dir "${SCODER_TMPDIR}"' "${SCODER}" && \
    grep -q -- '--chmod 0700 "${SCODER_TMPDIR}"' "${SCODER}" && \
    grep -q -- '--setenv TMPDIR "${SCODER_TMPDIR}"' "${SCODER}"; then
    printf '✅ scoder sets a private per-run sandbox TMPDIR\n'
else
    printf '❌ scoder does not set a private per-run sandbox TMPDIR\n' >&2
    exit 1
fi

if grep -q 'OPENCODE_EDITOR_SCRIPT="${HOST_HOME}/\.config/nvim/scripts/opencode-editor"' "${SCODER}" && \
    grep -q 'SANDBOX_OPENCODE_EDITOR="${SANDBOX_HOME}/\.config/nvim/scripts/opencode-editor"' "${SCODER}" && \
    grep -q 'SANDBOX_EDITOR="v_quickedit_hover"' "${SCODER}" && \
    grep -q 'if \[\[ -f "${OPENCODE_EDITOR_SCRIPT}" \]\]; then' "${SCODER}" && \
    grep -q 'add_parent_dirs_once "$(dirname "${SANDBOX_OPENCODE_EDITOR}")"' "${SCODER}" && \
    grep -q -- '--ro-bind "${REPLY}" "${SANDBOX_OPENCODE_EDITOR}"' "${SCODER}" && \
    grep -q 'SANDBOX_EDITOR="${SANDBOX_OPENCODE_EDITOR}"' "${SCODER}" && \
    grep -q -- '--setenv EDITOR "${SANDBOX_EDITOR}"' "${SCODER}" && \
    grep -q -- '--setenv VISUAL "${SANDBOX_EDITOR}"' "${SCODER}"; then
    printf '✅ scoder uses opencode-editor script when present\n'
else
    printf '❌ scoder does not conditionally use opencode-editor for EDITOR/VISUAL\n' >&2
    exit 1
fi
