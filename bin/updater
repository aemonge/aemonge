#!/bin/zsh
# vim: ft=zsh

set -e
set -o pipefail

title() {
    if command -v "boxify" &>/dev/null; then
        boxify title "$@"
    else
        echo "$@"
    fi
}

subtitle() {
    if command -v "boxify" &>/dev/null; then
        boxify subtitle "$@"
    else
        echo "$@"
    fi
}

show_help() {
    echo "Usage: $SCRIPT_NAME [OPTION]"
    echo "Run system updates for various package managers."
    echo
    echo "Options:"
    echo "  -h, --help, help    Show this help message and exit"
    echo "  -q, --quiet         Disable info and verbose output, show only errors and warnings"
    echo "  --only LIST         Run only stages in comma list (e.g. cargo,go,pip)"
    echo "  --skip LIST         Skip stages in comma list (e.g. neovim,zinit)"
    echo "  --json              Print machine-readable stage summary"
    echo "  doctor              Check updater dependencies and local dev-tool paths"
    echo "  all                 Run all update stages (previous default behavior)"
    echo "  daily               Run low-risk daily update profile"
    echo "  weekly              Run attended weekly update profile"
    echo "  monthly             Run monthly maintenance profile"
    echo "  arch-check          Check official repo updates without upgrading"
    echo "  pamac               Update Arch/AUR packages using paru if available, else pamac"
    echo "  pacman-mirrors      Update Arch 'pacman-mirrors'"
    echo "  snap                Update using snap"
    echo "  flatpak             Update using flatpak"
    echo "  hardware            Update hardware firmware"
    echo "  clam                Update ClamAV database"
    echo "  clam-scan           Use preconfigured ClamAV scan settings"
    echo "  cargo               Update cargo packages"
    echo "  go                  Update go packages"
    echo "  gem                 Update ruby packages"
    echo "  pnpm                Update pnpm packages"
    echo "  bun                 Update bun runtime and global packages"
    echo "  pip                 Update pipx packages"
    echo "  zinit               Update zinit plugins"
    echo "  clean-dev           Clean (nvim, zinit, treesitter, mason) dev packages"
    echo "  neovim              Update Neovim plugins"
    echo "  bins                Update linked bins and sbins"
    echo "  completions         Generate Zsh completions and save to ~/.zfunc"
    echo "  and-shutdown        Run all updates and then shutdown the system"
}

QUIET=false
JSON_SUMMARY=false
LOCK_FD=9
STAGE_SKIPPED_EXIT=77
LOCK_FILE="${XDG_RUNTIME_DIR:-/tmp}/updater.lock"
SCRIPT_NAME="$(basename "$0")"

typeset -a ONLY_STAGES=()
typeset -a SKIP_STAGES=()
typeset -a ALL_STAGES=(
    arch-check
    pamac
    pacman-mirrors
    snap
    flatpak
    hardware
    clam
    clam-scan
    cargo
    go
    gem
    pnpm
    bun
    pip
    zinit
    clean-dev
    neovim
    bins
)

typeset -A STAGE_FUNCS=(
    arch-check check_arch_updates
    pamac update_pamac
    pacman-mirrors update_mirrors
    snap update_snap
    flatpak update_flatpak
    hardware update_hardware
    clam update_clam
    clam-scan clam_scan_and_quarantine
    cargo update_cargo
    go update_go
    gem update_gem
    pnpm update_pnpm
    bun update_bun
    pip update_pip
    zinit update_zinit
    clean-dev clean_dev
    neovim update_neovim
    bins link_bins
)

typeset -A STAGE_DESCRIPTIONS=(
    arch-check "Check official repo updates without upgrading"
    pamac "Update Arch/AUR packages using paru if available, else pamac"
    pacman-mirrors "Update pacman-mirrors"
    snap "Update using snap"
    flatpak "Update using flatpak"
    hardware "Update hardware firmware"
    clam "Update ClamAV database"
    clam-scan "Scan with pre-settings"
    cargo "Update cargo packages"
    go "Update go packages"
    gem "Update ruby packages"
    pnpm "Update pnpm packages"
    bun "Update bun runtime and global packages"
    pip "Update pipx packages"
    zinit "Update zinit plugins"
    clean-dev "Clean dev packages"
    neovim "Update Neovim plugins"
    bins "Update linked bins and sbins"
    completions "Generate Zsh completions"
    doctor "Check updater dependencies and local dev-tool paths"
    all "Run all update stages"
    daily "Run low-risk daily update profile"
    weekly "Run attended weekly update profile"
    monthly "Run monthly maintenance profile"
    and-shutdown "Run all updates and then shutdown"
)

typeset -a STAGES_SUCCESS=()
typeset -a STAGES_FAILED=()
typeset -a STAGES_SKIPPED=()
typeset -a NORMALIZED_STAGE_LIST=()
typeset -a DOCTOR_OK=()
typeset -a DOCTOR_WARN=()
typeset -a DOCTOR_ACTIONS=()

trim_whitespace() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s' "$value"
}

normalize_stage_list() {
    local mode="$1"
    shift

    local stage trimmed
    NORMALIZED_STAGE_LIST=()

    for stage in "$@"; do
        trimmed="$(trim_whitespace "$stage")"
        [[ -z "$trimmed" ]] && continue

        if list_contains "$trimmed" "${ALL_STAGES[@]}"; then
            NORMALIZED_STAGE_LIST+=("$trimmed")
        else
            subtitle "Warning: unknown stage '$trimmed' in --$mode. Ignoring it." >&2
        fi
    done
}

list_contains() {
    local needle="$1"
    shift
    local item
    for item in "$@"; do
        [[ "$item" == "$needle" ]] && return 0
    done
    return 1
}

stage_selected() {
    local stage="$1"

    if (( ${#ONLY_STAGES[@]} > 0 )) && ! list_contains "$stage" "${ONLY_STAGES[@]}"; then
        return 1
    fi

    if list_contains "$stage" "${SKIP_STAGES[@]}"; then
        return 1
    fi

    return 0
}

record_stage_success() {
    STAGES_SUCCESS+=("$1")
}

record_stage_failure() {
    STAGES_FAILED+=("$1")
}

record_stage_skipped() {
    STAGES_SKIPPED+=("$1")
}

run_stage() {
    local stage="$1"
    local func="$2"
    local stage_status=0

    if ! stage_selected "$stage"; then
        record_stage_skipped "$stage"
        return 0
    fi

    set +e
    if $QUIET; then
        "$func" >/dev/null
    else
        "$func"
    fi
    stage_status=$?
    set -e

    if [[ $stage_status -eq 0 ]]; then
        record_stage_success "$stage"
    elif [[ $stage_status -eq $STAGE_SKIPPED_EXIT ]]; then
        record_stage_skipped "$stage"
    else
        record_stage_failure "$stage"
        subtitle "Warning: stage '$stage' failed. Continuing..." >&2
    fi
}

run_named_stage() {
    local stage="$1"
    local func="${STAGE_FUNCS[$stage]}"

    if [[ -z "$func" ]]; then
        echo "Unknown update: $stage" >&2
        show_help
        exit 1
    fi

    run_stage "$stage" "$func"
}

print_stage_summary() {
    if $JSON_SUMMARY; then
        local success_json="$(array_to_json "${STAGES_SUCCESS[@]}")"
        local failed_json="$(array_to_json "${STAGES_FAILED[@]}")"
        local skipped_json="$(array_to_json "${STAGES_SKIPPED[@]}")"
        printf '{"success":[%s],"failed":[%s],"skipped":[%s]}\n' \
            "$success_json" \
            "$failed_json" \
            "$skipped_json"
        return 0
    fi

    $QUIET || title "Update summary"
    echo "  success: ${#STAGES_SUCCESS[@]} (${STAGES_SUCCESS[*]:-none})"
    echo "  failed:  ${#STAGES_FAILED[@]} (${STAGES_FAILED[*]:-none})"
    echo "  skipped: ${#STAGES_SKIPPED[@]} (${STAGES_SKIPPED[*]:-none})"
}

json_escape() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/\\n}"
    value="${value//$'\r'/\\r}"
    value="${value//$'\t'/\\t}"
    printf '%s' "$value"
}

array_to_json() {
    local item escaped
    local output=""
    local separator=""

    for item in "$@"; do
        escaped="$(json_escape "$item")"
        output+="$separator\"$escaped\""
        separator=","
    done

    printf '%s' "$output"
}

acquire_lock() {
    if ! command -v flock &>/dev/null; then
        subtitle "Warning: flock not found. Running without updater lock." >&2
        return 0
    fi

    exec 9>"$LOCK_FILE"
    if ! flock -n "$LOCK_FD"; then
        subtitle "Warning: another updater process is already running." >&2
        exit 1
    fi
}

check_command() {
    if ! command -v "$1" &>/dev/null; then
        subtitle "Warning: $1 not found. Skipping $2." >&2
        return 1
    fi
    return 0
}

skip_stage() {
    subtitle "Skipping: $1" >&2
    return $STAGE_SKIPPED_EXIT
}

require_command() {
    local command_name="$1"
    local description="$2"
    local install_hint="${3:-}"

    if command -v "$command_name" &>/dev/null; then
        return 0
    fi

    subtitle "Warning: $command_name not found. Skipping $description." >&2
    [[ -n "$install_hint" ]] && subtitle "Hint: $install_hint" >&2
    return $STAGE_SKIPPED_EXIT
}

require_root() {
    [[ $EUID -eq 0 ]] && return 0
    skip_stage "$1 requires root privileges."
}

require_user() {
    [[ $EUID -ne 0 ]] && return 0
    skip_stage "$1 should run as a regular user."
}

check_last_clean() {
    local cache_file="${XDG_CACHE_HOME:-$HOME/.cache}/updater_last_clean"
    local current_time=$(date +%s)
    local week_seconds=$((7 * 24 * 60 * 60))
    local month_seconds=$((30 * 24 * 60 * 60))

    if [[ -f "$cache_file" ]]; then
        local last_clean=$(cat "$cache_file")
        local time_diff=$((current_time - last_clean))

        if [[ $time_diff -ge $month_seconds ]]; then
            echo "⚠️  WARNING: System cache not cleaned in $((time_diff / 86400)) days" >&2
            echo "   Run: sudo updater clean-dev" >&2
        elif [[ $time_diff -ge $week_seconds ]]; then
            echo "ℹ️  INFO: System cache last cleaned $((time_diff / 86400)) days ago" >&2
            echo "   Consider running: sudo updater clean-dev" >&2
        fi
    else
        echo "ℹ️  INFO: No clean history found. Consider running: sudo updater clean-dev" >&2
    fi
}

check_arch_updates() {
    require_command "checkupdates" "official repository update check" "sudo pacman -S pacman-contrib" || return $?

    $QUIET || title "Checking official repository updates with 'checkupdates'"

    local updates check_status
    updates="$(checkupdates 2>/dev/null)"
    check_status=$?

    if [[ $check_status -eq 0 ]]; then
        if [[ -n "$updates" ]]; then
            echo "$updates"
        else
            $QUIET || echo "No official repository updates found."
        fi
        return 0
    fi

    if [[ $check_status -eq 2 ]]; then
        $QUIET || echo "No official repository updates found."
        return 0
    fi

    subtitle "Warning: checkupdates failed." >&2
    return $check_status
}

save_clean_timestamp() {
    local cache_file="${XDG_CACHE_HOME:-$HOME/.cache}/updater_last_clean"
    mkdir -p "$(dirname "$cache_file")"
    date +%s >"$cache_file"
    $QUIET || echo "✓ Clean timestamp saved"
}

update_flatpak() {
    require_user "flatpak update" || return $?
    require_command "flatpak" "flatpak update" || return $?

    $QUIET || title "Running: 'flatpak update -y'"
    flatpak update -y
}

update_pamac() {
    # Check if NOT running as root (sudo), and if so proceed
    require_user "Arch/AUR package update" || return $?

    if command -v "paru" &>/dev/null; then
        $QUIET || title "Running 'paru -Syu --noconfirm'"
        paru -Syu --noconfirm
        return $?
    fi

    require_command "pamac" "pamac update" || return $?
    $QUIET || title "Running 'pamac update --no-confirm --aur'"

    # Clear AUR build cache if update fails
    if ! pamac update --no-confirm --aur; then
        subtitle "⚠️  AUR update failed. Cleaning build cache and retrying..." >&2
        pamac clean --build-files --no-confirm
        pamac update --no-confirm --aur
    fi
}

update_mirrors() {
    require_root "mirror update" || return $?
    require_command "pacman-mirrors" "mirror update" || return $?

    $QUIET || title "Refreshing pacman mirrors"
    pacman-mirrors --fasttrack 5 && pacman -Syy
}

update_snap() {
    require_root "snap update" || return $?
    require_command "snap" "snap update" || return $?
    require_command "systemctl" "systemd operations" || return $?
    require_command "pamac" "pamac snap update" || return $?

    $QUIET || title "Running 'pamac upgrade --enable-snap --no-confirm'"

    local update_status=0
    local snap_services_started=false
    if systemctl start snapd.apparmor.service snapd.service; then
        snap_services_started=true
    else
        subtitle "Warning: failed to start snap services. Skipping snap updates." >&2
        return 1
    fi

    if ! pamac update --enable-snap --no-confirm; then
        subtitle "Warning: snap update failed." >&2
        update_status=1
    fi

    if [[ "$snap_services_started" == true ]]; then
        systemctl stop snapd.apparmor.service snapd.service snapd.socket || true
    fi

    return $update_status
}

update_hardware() {
    # Check if running as root (sudo), and if so proceed
    require_root "firmware update" || return $?
    require_command "fwupdmgr" "firmware update" || return $?

    $QUIET || title "Running 'fwupdmgr refresh,get-updates,update'"
    fwupdmgr refresh || true
    fwupdmgr get-updates || true
    fwupdmgr update
}

update_clam() {
    # Check if running as root (sudo), and if so proceed
    require_root "ClamAV database update" || return $?
    require_command "freshclam" "ClamAV update" || return $?

    $QUIET || title "Running 'freshclam'"
    freshclam
}

clam_scan_and_quarantine() {
    # Quarantine all infected files found by ClamAV
    local quarantine_dir="/var/quarantine"
    require_root "ClamAV quarantine scan" || return $?
    require_command "clamscan" "ClamAV scan" || return $?

    $QUIET || title "Scanning entire system with ClamAV and quarantining infected files to $quarantine_dir"
    mkdir -p "$quarantine_dir"
    clamscan --recursive --infected --exclude-dir='^/sys|^/dev' --move="$quarantine_dir" /
}

update_cargo() {
    # Check if running as user, and if so proceed
    # go install github.com/Gelio/go-global-update@latest
    require_user "cargo packages update" || return $?
    require_command "cargo" "cargo packages update" || return $?

    $QUIET || title "Running: 'rustup update && cargo install-update -a'"
    local update_status=0
    if command -v rustup &>/dev/null; then
        rustup update || update_status=1
    else
        subtitle "Warning: rustup not found. Skipping rustup update." >&2
    fi

    if ! cargo install-update -a; then
        subtitle "Warning: cargo install-update failed. Installing cargo-update..." >&2
        cargo install cargo-update || update_status=1
        if ! cargo install-update -a; then
            subtitle "Warning: cargo install-update failed again. Continuing with remaining updates." >&2
            update_status=1
        fi
    fi

    return $update_status
}

update_go() {
    # Check if running as user, and if so proceed
    require_user "go packages update" || return $?
    require_command "go" "go packages update" || return $?
    require_command "go-global-update" "go global package update" "go install github.com/Gelio/go-global-update@latest" || return $?

    $QUIET || title "Running: 'go-global-update'"
    go-global-update
}

update_gem() {
    # Check if running as user, and if so proceed
    require_user "gem update" || return $?
    require_command "gem" "gem update" || return $?

    $QUIET || title "Running: 'gem update'"
    gem update
}

update_pip() {
    # Check if running as user, and if so proceed
    require_user "uv tool updates" || return $?
    require_command "uv" "uv tool updates" || return $?

    local uv_path
    uv_path="$(command -v uv)"
    if [[ "$uv_path" == "$HOME"/* ]]; then
        $QUIET || title "Running: 'uv self update'"
        uv self update || subtitle "Warning: uv self update failed. Continuing with tool upgrades." >&2
    else
        $QUIET || subtitle "Skipping uv self update: uv is managed outside HOME at $uv_path." >&2
    fi

    $QUIET || title "Running: 'uv tool upgrade --all'"
    uv tool upgrade --all
}

update_pnpm() {
    # Check if running as user, and if so proceed
    require_user "pnpm packages update" || return $?
    require_command "pnpm" "pnpm packages update" || return $?

    $QUIET || title "Running: 'pnpm update -g'"
    pnpm update -g
}

update_bun() {
    require_user "bun update" || return $?
    require_command "bun" "bun update" || return $?

    local bun_path
    bun_path="$(command -v bun)"
    if [[ "$bun_path" == "$HOME"/* ]]; then
        $QUIET || title "Running: 'bun upgrade'"
        bun upgrade || subtitle "Warning: bun upgrade failed. Continuing with global package update." >&2
    else
        $QUIET || subtitle "Skipping bun upgrade: bun is managed outside HOME at $bun_path." >&2
    fi

    if [[ -d "$HOME/.bun/install/global" ]]; then
        $QUIET || title "Running: 'bun update' in global package directory"
        (cd "$HOME/.bun/install/global" && bun update)
    else
        skip_stage "bun global install directory not found."
    fi
}

update_zinit() {
    # Check if running as user, and if so proceed
    require_user "zinit update" || return $?
    require_command "zsh" "zinit update" || return $?

    local zinit_script="$HOME/.local/share/zinit/zinit.git/zinit.zsh"
    if [[ ! -f "$zinit_script" ]]; then
        skip_stage "zinit script not found at $zinit_script."
    fi

    $QUIET || title "Running: 'zsh -ic \"zinit self-update\",\"update -a\"'"
    if $QUIET; then
        zsh -f -ic "setopt no_monitor; source ${(q)zinit_script} && \
        zinit self-update --quiet  >/dev/null 2>&1 && \
        zinit update --all --parallel --quiet >/dev/null 2>&1 && \
        wait" >/dev/null 2>&1
    else
        zsh -f -ic "source ${(q)zinit_script} && \
        zinit self-update && \
        zinit update --all --parallel && \
        wait"
    fi
}

clean_dev() {
    if [[ $EUID -eq 0 ]]; then
        $QUIET || title "Cleaning system packages and logs"
        pamac clean --no-confirm
        pamac remove --orphans --no-confirm
        pamac clean --no-confirm --build-files
        journalctl --vacuum-time=2weeks
        find /var/log -type f -name '*.log' -delete
    else
        $QUIET || title "Removing cache and state data from development tools"
        local dirs_to_remove=(
            ~/.cache
            ~/.config/coc
            ~/.local/share/{coc,nvim,nvim-treesitter,zinit}
            ~/.vim/{bundle,plugged}
            ~/.zinit
        )
        rm -rf "${dirs_to_remove[@]}"

        if check_command "pnpm" "pnpm cache clean --force"; then
            $QUIET || echo "Cleaning pnpm cache"
            pnpm cache clean --force
        fi

        if check_command "bun" "bun pm cache rm"; then
            $QUIET || echo "Cleaning bun cache"
            bun pm cache rm
        fi

        if check_command "go" "go clean cache"; then
            $QUIET || echo "Cleaning go cache"
            GO111MODULE=off go clean -cache -modcache -i -r
        fi

    fi
    save_clean_timestamp
}

link_bins() {
    $QUIET || title "Linking binaries from ~/usr/[bin|sbin] to [~/.local|/usr/local]/[bin|sbin]"

    local user_home target_bin target_sbin
    if [[ $EUID -eq 0 && -n "$SUDO_USER" ]]; then
        user_home="/home/$SUDO_USER"
        target_bin="/usr/local/bin"
        target_sbin="/usr/local/sbin"
    else
        user_home="$HOME"
        target_bin="$HOME/.local/bin"
        target_sbin="$HOME/.local/sbin"
    fi

    local dirs=("$target_bin" "$target_sbin")
    for dir in "${dirs[@]}"; do
        [[ -d "$dir" ]] || mkdir -p "$dir"
        find "$dir" -xtype l -delete
    done

    local src_dirs=("$user_home/usr/bin" "$user_home/usr/sbin")
    local dest_dirs=("$target_bin" "$target_sbin")
    for i in {0..1}; do
        if [[ -d "${src_dirs[$i]}" ]]; then
            find "${src_dirs[$i]}" -type f -executable -print0 |
                xargs -0 -I {} ln -sf {} "${dest_dirs[$i]}/"
        fi
    done
}

update_neovim() {
    # Check if running as user, and if so proceed
    require_user "Neovim plugins update" || return $?
    require_command "nvim" "Neovim plugins update" || return $?

    $QUIET || title "Running: 'nvim Lazy update; TSUpdateSync' with 'timetout 20s'"
    if $QUIET; then
        nvim --headless \
            -c 'lua require("lazy").update():wait()' \
            -c 'Lazy load nvim-treesitter' \
            -c 'TSUpdateSync' \
            -c 'qa!' >/dev/null 2>&1
    else
        nvim --headless \
            -c 'lua require("lazy").update():wait()' \
            -c 'Lazy load nvim-treesitter' \
            -c 'TSUpdateSync' \
            -c 'qa!'
    fi
}

shutdown_system() {
    if check_command "shutdown" "system shutdown"; then
        $QUIET || title "All updates completed. Shutting down the system..."
        shutdown now
    fi
}

run_profile() {
    local profile="$1"
    shift

    $QUIET || title "Running '$profile' update profile"

    local stage
    for stage in "$@"; do
        run_named_stage "$stage"
    done
}

run_daily_updates() {
    run_profile daily \
        arch-check \
        flatpak \
        pip \
        pnpm \
        bun \
        bins
}

run_weekly_updates() {
    run_profile weekly \
        pamac \
        cargo \
        go \
        gem \
        zinit \
        neovim \
        bins
}

run_monthly_updates() {
    run_profile monthly \
        pacman-mirrors \
        hardware \
        clam \
        bins
}

run_user_updates() {
    $QUIET || title "Updating System (pamac, flatpak)"
    run_named_stage pamac
    run_named_stage flatpak

    $QUIET || title "Updating Libraries (cargo, go, gem, pnpm, bun, pip)"
    run_named_stage cargo
    run_named_stage go
    run_named_stage gem
    run_named_stage pnpm
    run_named_stage bun
    run_named_stage pip

    $QUIET || title "Updating terminal (zsh, nvim)"
    run_named_stage zinit
    run_named_stage neovim

    $QUIET || title "Re-linking local (s)binaries"
    run_named_stage bins
}

run_all_updates() {
    check_last_clean

    if [[ $EUID -eq 0 ]]; then
        # Root: hardware + clam + mirrors then regular updates
        $QUIET || title "Updating System (mirrors, hardware, clam, snap)"
        run_named_stage pacman-mirrors
        run_named_stage hardware
        run_named_stage clam
        run_named_stage snap

        # Now run user updates
        run_user_updates
    else
        # User mode: skip root stuff
        run_user_updates
    fi
}

doctor_ok() {
    DOCTOR_OK+=("$1")
    $JSON_SUMMARY || echo "✓ $1"
}

doctor_warn() {
    DOCTOR_WARN+=("$1")
    $JSON_SUMMARY || echo "⚠ $1"
}

doctor_action() {
    DOCTOR_ACTIONS+=("$1")
    $JSON_SUMMARY || echo "  → $1"
}

path_contains() {
    local wanted="$1"
    local entry
    for entry in ${(s.:.)PATH}; do
        [[ "$entry" == "$wanted" ]] && return 0
    done
    return 1
}

doctor_command() {
    local command_name="$1"
    local hint="${2:-}"
    local command_path

    if command_path="$(command -v "$command_name" 2>/dev/null)"; then
        doctor_ok "$command_name: $command_path"
        return 0
    else
        doctor_warn "$command_name missing${hint:+ — $hint}"
        return 0
    fi
}

doctor_any_command() {
    local label="$1"
    local hint="$2"
    shift 2

    local command_name command_path
    for command_name in "$@"; do
        if command_path="$(command -v "$command_name" 2>/dev/null)"; then
            doctor_ok "$label: using $command_name at $command_path"
            return 0
        fi
    done

    doctor_warn "$label missing${hint:+ — $hint}"
}

doctor_path() {
    local path_entry="$1"
    if path_contains "$path_entry"; then
        doctor_ok "PATH contains $path_entry"
        return 0
    else
        doctor_warn "PATH missing $path_entry"
        return 1
    fi
}

doctor_env_equals() {
    local variable_name="$1"
    local expected="$2"
    local actual
    actual="$(printenv "$variable_name" 2>/dev/null || true)"

    if [[ "$actual" == "$expected" ]]; then
        doctor_ok "$variable_name=$expected"
        return 0
    else
        doctor_warn "$variable_name is '${actual:-unset}', expected '$expected'"
        return 1
    fi
}

doctor_path_absent() {
    local path_entry="$1"
    local reason="$2"
    if path_contains "$path_entry"; then
        doctor_warn "legacy PATH entry present: $path_entry"
        doctor_action "$reason"
    fi
}

doctor_file_or_dir_absent() {
    local path_entry="$1"
    local reason="$2"
    if [[ -e "$path_entry" ]]; then
        doctor_warn "legacy path exists: $path_entry"
        doctor_action "$reason"
    fi
}

doctor_policy_recommendations() {
    if command -v mise &>/dev/null; then
        doctor_warn "mise installed, but current policy uses native managers instead"
        doctor_action "If you agree with the policy: run 'mise prune', then uninstall mise with your package manager."
    else
        doctor_ok "mise absent (policy: native managers instead)"
    fi

    if ! command -v pnpm &>/dev/null; then
        doctor_action "Add pnpm if you want JS/TS global package updates: 'pamac install pnpm'."
    fi

    if command -v corepack &>/dev/null; then
        doctor_warn "corepack installed, but current policy prefers distro-managed pnpm"
        doctor_action "If pnpm is installed with pamac/pacman, remove corepack: 'pamac remove corepack'."
    fi

    if command -v bun &>/dev/null && command -v pnpm &>/dev/null; then
        doctor_ok "JS/TS policy: pnpm owns package management; bun is runtime/toolkit only"
    elif command -v bun &>/dev/null; then
        doctor_action "Keep bun as runtime/toolkit; avoid using 'bun add -g' for shared JS CLIs if pnpm will own JS package management."
    fi

    doctor_path_absent "$HOME/.cargo/bin" "Remove stale ~/.cargo/bin from shell config; use ~/.local/share/cargo/bin."
    doctor_path_absent "$HOME/.npm-global/bin" "Remove legacy npm-global PATH entry if pnpm will own JS globals."
    doctor_file_or_dir_absent "$HOME/.cargo" "Move/remove old ~/.cargo after verifying ~/.local/share/cargo works."
    doctor_file_or_dir_absent "$HOME/.rustup" "Move/remove old ~/.rustup after verifying ~/.local/share/rustup works."
}

print_doctor_summary() {
    if $JSON_SUMMARY; then
        local ok_json="$(array_to_json "${DOCTOR_OK[@]}")"
        local warn_json="$(array_to_json "${DOCTOR_WARN[@]}")"
        local action_json="$(array_to_json "${DOCTOR_ACTIONS[@]}")"
        printf '{"ok":[%s],"warnings":[%s],"actions":[%s]}' "$ok_json" "$warn_json" "$action_json"
        printf '\n'
        return 0
    fi

    title "Doctor summary"
    echo "  ok:       ${#DOCTOR_OK[@]}"
    echo "  warnings: ${#DOCTOR_WARN[@]}"
    echo "  actions:  ${#DOCTOR_ACTIONS[@]}"
}

run_doctor() {
    DOCTOR_OK=()
    DOCTOR_WARN=()
    DOCTOR_ACTIONS=()

    $JSON_SUMMARY || title "Updater doctor"

    doctor_command "checkupdates" "install pacman-contrib: sudo pacman -S pacman-contrib"
    doctor_any_command "Arch/AUR updater" "install paru or pamac" paru pamac
    doctor_command "flatpak"
    doctor_command "uv"
    doctor_command "pnpm" "install pnpm if you want the pnpm daily stage: pamac install pnpm" || true
    doctor_command "bun"
    doctor_command "go-global-update" "go install github.com/Gelio/go-global-update@latest"
    doctor_command "gem"
    doctor_command "cargo-install-update" "cargo install cargo-update"
    doctor_command "nvim"

    if [[ -f "$HOME/.local/share/zinit/zinit.git/zinit.zsh" ]]; then
        doctor_ok "zinit script found"
    else
        doctor_warn "zinit script missing at $HOME/.local/share/zinit/zinit.git/zinit.zsh"
    fi

    doctor_env_equals "GOBIN" "$HOME/.local/bin" || doctor_action "Set GOBIN in your env file: export GOBIN=\"\$HOME/.local/bin\""
    doctor_env_equals "GOPATH" "$HOME/.local/share/go" || doctor_action "Set GOPATH in your env file: export GOPATH=\"\$HOME/.local/share/go\""
    doctor_env_equals "CARGO_HOME" "$HOME/.local/share/cargo" || doctor_action "Set CARGO_HOME in your env file and migrate with rsync from ~/.cargo/."
    doctor_env_equals "RUSTUP_HOME" "$HOME/.local/share/rustup" || doctor_action "Set RUSTUP_HOME in your env file and migrate with rsync from ~/.rustup/."
    doctor_env_equals "GEM_HOME" "$HOME/.local/share/gem/ruby" || doctor_action "Set GEM_HOME/GEM_PATH to ~/.local/share/gem/ruby for user-local gems."
    doctor_env_equals "PNPM_HOME" "$HOME/.local/share/pnpm" || doctor_action "Set PNPM_HOME to ~/.local/share/pnpm if pnpm is part of your JS policy."
    doctor_env_equals "BUN_INSTALL" "$HOME/.bun" || doctor_action "Set BUN_INSTALL to ~/.bun so bun runtime tools stay user-local."

    doctor_path "$HOME/.local/bin" || doctor_action "Add ~/.local/bin early in PATH."
    doctor_path "$HOME/.local/share/cargo/bin" || doctor_action "Add ~/.local/share/cargo/bin to PATH."
    doctor_path "$HOME/.local/share/gem/ruby/bin" || doctor_action "Add ~/.local/share/gem/ruby/bin to PATH."
    doctor_path "$HOME/.bun/bin" || doctor_action "Add ~/.bun/bin to PATH."
    doctor_path "$HOME/.local/share/pnpm" || doctor_action "Add ~/.local/share/pnpm to PATH if using pnpm globals."

    doctor_policy_recommendations

    print_doctor_summary
    return 0
}

time_function() {
    local start=$(date +%s)
    "$@"
    local end=$(date +%s)
    local duration=$((end - start))
    $QUIET || echo "⏱️  Completed in ${duration}s"
}

completions() {
    mkdir -p ~/.zfunc
    echo "#compdef updater" >~/.zfunc/_updater
    echo "" >>~/.zfunc/_updater
    echo "_updater() {" >>~/.zfunc/_updater
    echo "  local -a commands" >>~/.zfunc/_updater
    echo "  commands=(" >>~/.zfunc/_updater
    local stage
    for stage in doctor all daily weekly monthly "${ALL_STAGES[@]}" completions and-shutdown; do
        echo "    '$stage:${STAGE_DESCRIPTIONS[$stage]}'" >>~/.zfunc/_updater
    done
    echo "  )" >>~/.zfunc/_updater
    echo "  _arguments -s \\" >>~/.zfunc/_updater
    echo "    '(-h --help help)'{-h,--help}'[Show help message]' \\" >>~/.zfunc/_updater
    echo "    '(-q --quiet)'{-q,--quiet}'[Show only warnings and errors]' \\" >>~/.zfunc/_updater
    echo "    '--json[Print machine-readable stage summary]' \\" >>~/.zfunc/_updater
    echo "    '--only=[Run only listed stages (comma-separated)]' \\" >>~/.zfunc/_updater
    echo "    '--skip=[Skip listed stages (comma-separated)]' \\" >>~/.zfunc/_updater
    echo "    '*:command:_describe -t commands updater-commands commands'" >>~/.zfunc/_updater
    echo "}" >>~/.zfunc/_updater
    echo "" >>~/.zfunc/_updater
    echo "_updater \"\$@\"" >>~/.zfunc/_updater
    echo "Zsh completions have been saved to ~/.zfunc/_updater."
    echo "Please ensure ~/.zfunc is in your fpath and restart your shell or run 'autoload -U compinit && compinit' to enable them."
}

main() {
    local shutdown_after=false
    local only_flag_used=false
    while [[ $# -gt 0 ]]; do
        case $1 in
        -q | --quiet)
            QUIET=true
            shift
            ;;
        --json)
            JSON_SUMMARY=true
            shift
            ;;
        --only)
            shift
            if [[ -z "$1" ]]; then
                echo "Missing value for --only"
                exit 1
            fi
            only_flag_used=true
            local -a parsed_only
            local only_value="$1"
            parsed_only=("${(@s:,:)only_value}")
            normalize_stage_list only "${parsed_only[@]}"
            ONLY_STAGES=("${NORMALIZED_STAGE_LIST[@]}")
            shift
            ;;
        --skip)
            shift
            if [[ -z "$1" ]]; then
                echo "Missing value for --skip"
                exit 1
            fi
            local -a parsed_skip
            local skip_value="$1"
            parsed_skip=("${(@s:,:)skip_value}")
            normalize_stage_list skip "${parsed_skip[@]}"
            SKIP_STAGES=("${NORMALIZED_STAGE_LIST[@]}")
            shift
            ;;
        -h | --help | help)
            show_help
            exit 0
            ;;
        and-shutdown)
            shutdown_after=true
            shift
            ;;
        *)
            break
            ;;
        esac
    done

    if $only_flag_used && (( ${#ONLY_STAGES[@]} == 0 )); then
        subtitle "Warning: no valid stages found in --only. Nothing to run." >&2
        exit 1
    fi

    acquire_lock

    if [ $shutdown_after = true ]; then
        if $QUIET; then
            time_function run_all_updates >/dev/null
        else
            time_function run_all_updates
        fi
        shutdown_system
    elif [ $# -eq 0 ]; then
        run_doctor
        exit 0
    else
        for arg in "$@"; do
            case $arg in
            doctor)
                run_doctor
                exit 0
                ;;
            all)
                if $QUIET; then
                    time_function run_all_updates >/dev/null
                else
                    time_function run_all_updates
                fi
                ;;
            daily)
                run_daily_updates
                ;;
            weekly)
                run_weekly_updates
                ;;
            monthly)
                run_monthly_updates
                ;;
            completions)
                completions
                exit 0
                ;;
            *)
                run_named_stage "$arg"
                ;;
            esac
        done
    fi

    print_stage_summary
}

main "$@"
