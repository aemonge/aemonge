if is_discovery_cache_current "${SCODER_CACHE_BWRAP_PATH}" "${SCODER_CACHE_BWRAP_VERSION}" && [[ -n "${SCODER_CACHE_BWRAP_DISABLE_USERNS_SUPPORTED:-}" ]]; then
    BWRAP_DISABLE_USERNS_SUPPORTED="${SCODER_CACHE_BWRAP_DISABLE_USERNS_SUPPORTED}"
else
    BWRAP_DISABLE_USERNS_SUPPORTED=0
    if bwrap --help 2>/dev/null | grep -q -- "--disable-userns"; then
        BWRAP_DISABLE_USERNS_SUPPORTED=1
    fi
    SCODER_CACHE_BWRAP_DISABLE_USERNS_SUPPORTED="${BWRAP_DISABLE_USERNS_SUPPORTED}"
    write_discovery_cache
fi

trace_startup "bwrap capabilities discovered"

if is_discovery_cache_current "${SCODER_CACHE_BWRAP_PATH}" "${SCODER_CACHE_BWRAP_VERSION}" && [[ "${SCODER_CACHE_BWRAP_NAMESPACE_SUPPORT:-}" == "ok" ]]; then
    trace_startup "bwrap namespace probe cache hit"
else
    if ! check_bwrap_namespace_support; then
        exit 1
    fi
    SCODER_CACHE_BWRAP_NAMESPACE_SUPPORT="ok"
    write_discovery_cache
    trace_startup "bwrap namespace probe completed"
fi

SCODER_SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
SCODER_GIT_HOST="${SCODER_GIT:-${SCODER_SCRIPT_DIR}/scoder-git}"
if [[ ! -x "${SCODER_GIT_HOST}" ]]; then
