        failed_tests=$((failed_tests + 1))
    fi

    rm -f "${integrity_entry}"
    if ! check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${integrity_cache}" >/dev/null 2>&1 &&
        [[ ! -e "${integrity_cache}" ]]; then
        echo "PASS Test O.29b: watched entry deletion invalidates without replacement cache"
    else
        echo "FAIL Test O.29b: watched entry deletion was cached or accepted"
        failed_tests=$((failed_tests + 1))
    fi

    local symlink_plugin_dir="${plugin_config_dir}/plugins/symlink-package"
    local symlink_cache="${plugin_home}/scoder-cache/symlink-integrity-v1"
    mkdir -p "${symlink_plugin_dir}"
    printf '%s\n' '{"main":"entry.js"}' >"${symlink_plugin_dir}/package.json"
    printf '%s\n' 'export default { target: "one" };' >"${symlink_plugin_dir}/one.js"
    printf '%s\n' 'export default { target: "two" };' >"${symlink_plugin_dir}/two.js"
    ln -s one.js "${symlink_plugin_dir}/entry.js"
    printf '%s\n' '{"plugin":["./plugins/symlink-package"]}' >"${plugin_config}"
    if check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${symlink_cache}"; then
        ln -sfn two.js "${symlink_plugin_dir}/entry.js"
        if check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${symlink_cache}" &&
            [[ "${SCODER_PLUGIN_INTEGRITY_CACHE_HIT:-}" == "0" ]]; then
            echo "PASS Test O.29c: watched symlink retarget invalidates cache"
        else
            echo "FAIL Test O.29c: watched symlink retarget did not invalidate cache"
            failed_tests=$((failed_tests + 1))
        fi
    else
        echo "FAIL Test O.29c: symlink fixture could not populate cache"
        failed_tests=$((failed_tests + 1))
    fi

    printf '%s\n' '{"plugin":["never-installed-plugin"]}' >"${plugin_config}"
    rm -f "${integrity_cache}"
    if ! check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${integrity_cache}" >/dev/null 2>&1 &&
        [[ ! -e "${integrity_cache}" ]]; then
        echo "PASS Test O.30: failed full checks are never cached"
    else
        echo "FAIL Test O.30: failed full check produced a cache"
        failed_tests=$((failed_tests + 1))
    fi

    local manifestless_dir="${plugin_config_dir}/plugins/manifestless-structural"
    local manifestless_cache="${plugin_home}/scoder-cache/manifestless-integrity-v1"
    mkdir -p "${manifestless_dir}"
    printf '%s\n' 'export default {};' >"${manifestless_dir}/index.mjs"
    printf '%s\n' '{"plugin":["./plugins/manifestless-structural"]}' >"${plugin_config}"
    if check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${manifestless_cache}"; then
        printf '%s\n' '{not-json' >"${manifestless_dir}/package.json"
        if ! check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${manifestless_cache}" >/dev/null 2>&1 &&
            [[ ! -e "${manifestless_cache}" ]]; then
            echo "PASS Test O.31a: added malformed manifest invalidates cached manifest-less package"
        else
            echo "FAIL Test O.31a: added malformed manifest was hidden by cache"
            failed_tests=$((failed_tests + 1))
        fi
    else
        echo "FAIL Test O.31a: manifest-less fixture could not populate cache"
        failed_tests=$((failed_tests + 1))
    fi

    local precedence_dir="${plugin_config_dir}/plugins/conventional-precedence"
    local precedence_cache="${plugin_home}/scoder-cache/precedence-integrity-v1"
    mkdir -p "${precedence_dir}"
    printf '%s\n' 'export default { selected: "mjs" };' >"${precedence_dir}/index.mjs"
    printf '%s\n' '{"plugin":["./plugins/conventional-precedence"]}' >"${plugin_config}"
    if check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${precedence_cache}"; then
        printf '%s\n' 'export default { selected: "js" };' >"${precedence_dir}/index.js"
        if check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${precedence_cache}" &&
            [[ "${SCODER_PLUGIN_INTEGRITY_CACHE_HIT:-}" == "0" ]]; then
            echo "PASS Test O.31b: higher-precedence conventional entry invalidates cache"
        else
            echo "FAIL Test O.31b: higher-precedence conventional entry did not invalidate cache"
            failed_tests=$((failed_tests + 1))
        fi
    else
        echo "FAIL Test O.31b: conventional precedence fixture could not populate cache"
        failed_tests=$((failed_tests + 1))
    fi

    local newline_directory_entry="${precedence_dir}/additional"$'\n'"entry.js"
    printf '%s\n' 'export default {};' >"${newline_directory_entry}"
    if check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${precedence_cache}" &&
        [[ "${SCODER_PLUGIN_INTEGRITY_CACHE_HIT:-}" == "0" ]]; then
        echo "PASS Test O.31c: newline-bearing directory entry invalidates cache"
    else
        echo "FAIL Test O.31c: newline-bearing directory entry did not invalidate cache"
        failed_tests=$((failed_tests + 1))
    fi

    local validation_race_cache="${plugin_home}/scoder-cache/validation-race-v1"
    printf '%s\n' '{"plugin":["valid-plugin"]}' >"${plugin_config}"
    printf '%s\n' '{"name":"valid-plugin","main":"dist/index.js"}' >"${valid_package}/package.json"
    printf '%s\n' 'export default {};' >"${integrity_entry}"
    plugin_integrity_cache_validation_hook() {
        printf '%s\n' '{not-json' >"${valid_package}/package.json"
    }
    if ! check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${validation_race_cache}" >/dev/null 2>&1 &&
        [[ ! -e "${validation_race_cache}" ]]; then
        echo "PASS Test O.31d: validation-window manifest mutation is not cached"
    else
        echo "FAIL Test O.31d: validation-window manifest mutation produced a cache"
        failed_tests=$((failed_tests + 1))
    fi

    local watchset_dir="${plugin_config_dir}/plugins/watchset-race"
    local watchset_cache="${plugin_home}/scoder-cache/watchset-race-v1"
    mkdir -p "${watchset_dir}"
    printf '%s\n' 'export default {};' >"${watchset_dir}/index.mjs"
    printf '%s\n' '{"plugin":["./plugins/watchset-race"]}' >"${plugin_config}"
    plugin_integrity_cache_validation_hook() {
        printf '%s\n' '{"main":"index.mjs"}' >"${watchset_dir}/package.json"
    }
    if ! check_opencode_plugins_cached "${integrity_script}" "${plugin_config}" "${plugin_cache_root}" "${watchset_cache}" >/dev/null 2>&1 &&
        [[ ! -e "${watchset_cache}" ]]; then
        echo "PASS Test O.31e: changed validation-window watched set is not cached"
    else
        echo "FAIL Test O.31e: changed validation-window watched set produced a cache"
        failed_tests=$((failed_tests + 1))
    fi
    # shellcheck disable=SC2329 # Restore the no-op test hook after mutation fixtures.
    plugin_integrity_cache_validation_hook() { :; }

    OPENCODE_ARGS=()

    # Cleanup
    rm -rf "${test_project}"
    rm -rf "${shared_ro_dir}" "${shared_rw_dir}"

    echo ""
    if [[ "${failed_tests}" -eq 0 ]]; then
        echo "🎉 All validation tests passed!"
        return 0
    else
        echo "⚠️  ${failed_tests} test(s) failed"
        return 1
    fi
}

run_doctor() {
    local validation_status=0

    if run_validation; then
        :
    else
        validation_status=$?
    fi

    info "Doctor: current OpenCode plugin integrity"
    if check_opencode_plugins "${OPENCODE_DEFAULT_CONFIG}" "${HOME}/.cache/opencode/packages"; then
        echo "PASS Doctor: configured OpenCode plugins are structurally loadable"
    else
        echo "FAIL Doctor: configured OpenCode plugin integrity failed"
        validation_status=1
    fi

    return "${validation_status}"
}

