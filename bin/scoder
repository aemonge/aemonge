REAL_GIT_HOST="$(command -v git 2>/dev/null || true)"
if [[ -z "${REAL_GIT_HOST}" || ! -x "${REAL_GIT_HOST}" ]]; then
    error "real git binary not found in host PATH"
    exit 1
fi
if is_discovery_cache_current "${SCODER_CACHE_BWRAP_PATH}" "${SCODER_CACHE_BWRAP_VERSION}" && [[ "${SCODER_CACHE_REAL_GIT_HOST:-}" == "${REAL_GIT_HOST}" && -x "${SCODER_CACHE_REAL_GIT_REALPATH:-}" ]]; then
    REAL_GIT_HOST="${SCODER_CACHE_REAL_GIT_REALPATH}"
else
    SCODER_CACHE_REAL_GIT_HOST="${REAL_GIT_HOST}"
    SCODER_CACHE_REAL_GIT_REALPATH="$(realpath "${REAL_GIT_HOST}")"
    REAL_GIT_HOST="${SCODER_CACHE_REAL_GIT_REALPATH}"
fi

if is_discovery_cache_current "${SCODER_CACHE_BWRAP_PATH}" "${SCODER_CACHE_BWRAP_VERSION}" && [[ "${SCODER_CACHE_SCODER_GIT_HOST:-}" == "${SCODER_GIT_HOST}" && -x "${SCODER_CACHE_SCODER_GIT_REALPATH:-}" ]]; then
    SCODER_GIT_HOST="${SCODER_CACHE_SCODER_GIT_REALPATH}"
else
    SCODER_CACHE_SCODER_GIT_HOST="${SCODER_GIT_HOST}"
    SCODER_CACHE_SCODER_GIT_REALPATH="$(realpath "${SCODER_GIT_HOST}")"
    SCODER_GIT_HOST="${SCODER_CACHE_SCODER_GIT_REALPATH}"
