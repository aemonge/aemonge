    if [[ "$1" == "--" && "${SCODER_PARSE_MODE}" -eq 0 ]]; then
        SCODER_PARSE_MODE=1
        shift
        continue
    fi

    if [[ "${SCODER_PARSE_MODE}" -eq 0 ]]; then
        OPENCODE_ARGS+=("$1")
    else
        SCODER_ARGS+=("$1")
    fi
    shift
done

