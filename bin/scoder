# Helper: opt_bind (used for optional host-path binds)
opt_bind() {
    local host_p="$1"
    local sand_p="$2"
    local resolved_host_p
    if [[ -d "${host_p}" ]]; then
        resolve_bind_source_path "${host_p}"
        resolved_host_p="${REPLY}"
        EXTRA_BINDS+=(--ro-bind "${resolved_host_p}" "${sand_p}")
    fi
}

opt_bind_path() {
    local host_p="$1"
    local sand_p="$2"
    local resolved_host_p
    if [[ -e "${host_p}" ]]; then
        resolve_bind_source_path "${host_p}"
        resolved_host_p="${REPLY}"
        EXTRA_BINDS+=(--bind "${resolved_host_p}" "${sand_p}")
    fi
}

opt_ro_bind_path() {
    local host_p="$1"
    local sand_p="$2"
    local resolved_host_p
    if [[ -e "${host_p}" ]]; then
        resolve_bind_source_path "${host_p}"
        resolved_host_p="${REPLY}"
        add_parent_dirs_once "$(dirname "${sand_p}")"
        EXTRA_BINDS+=(--ro-bind "${resolved_host_p}" "${sand_p}")
    fi
}

bind_runtime_dir() {
    local host_p="$1"
    local sand_p="$2"
    local resolved_host_p

    mkdir -p "${host_p}"
    bind_runtime_dir_precreated "${host_p}" "${sand_p}"
}

bind_runtime_dir_precreated() {
    local host_p="$1"
    local sand_p="$2"
    local resolved_host_p

    resolve_bind_source_path "${host_p}"
    resolved_host_p="${REPLY}"
    add_parent_dirs_once "$(dirname "${sand_p}")"
    EXTRA_BINDS+=(--bind "${resolved_host_p}" "${sand_p}")
}

add_extra_dir_once() {
    local dir_path="$1"

    if [[ -n "${EXTRA_DIR_SET[${dir_path}]:-}" ]]; then
        return
    fi

    EXTRA_DIR_SET["${dir_path}"]=1
    EXTRA_DIRS+=(--dir "${dir_path}")
}

add_parent_dirs_once() {
    local dir_path="$1"
    local parent=""
    local segment

    if [[ -n "${PARENT_DIR_EXPANSION_SET[${dir_path}]:-}" ]]; then
        return
    fi

    PARENT_DIR_EXPANSION_SET["${dir_path}"]=1

    IFS='/' read -r -a segments <<<"${dir_path}"
    for segment in "${segments[@]}"; do
        [[ -z "${segment}" ]] && continue
        parent="${parent}/${segment}"
        add_extra_dir_once "${parent}"
    done
}

map_host_path_to_sandbox() {
    local host_path="$1"

    if [[ "${host_path}" == "${HOST_HOME}"* ]]; then
        REPLY="${SANDBOX_HOME}${host_path#${HOST_HOME}}"
        return
    fi

    REPLY="${host_path}"
}

mirror_persistent_subpath_symlink() {
    local host_path="$1"
    local visible_sandbox_path="$2"
    local resolved_target
    local target_sandbox_path

    if [[ ! -L "${host_path}" ]]; then
        REPLY="${visible_sandbox_path}"
        return
    fi

    resolved_target="$(realpath "${host_path}")"
    map_host_path_to_sandbox "${resolved_target}"
    target_sandbox_path="${REPLY}"
    add_parent_dirs_once "$(dirname "${visible_sandbox_path}")"
    add_parent_dirs_once "$(dirname "${target_sandbox_path}")"
    SANDBOX_SYMLINKS+=(--symlink "${target_sandbox_path}" "${visible_sandbox_path}")
    REPLY="${target_sandbox_path}"
}

bind_symlink_targets_in_dir() {
    local host_dir="$1"
    local host_path
    local resolved_target
    local target_sandbox_path
    local restore_nullglob
    local restore_dotglob
    local -a symlink_candidates=()

    if [[ ! -d "${host_dir}" ]]; then
        return
    fi

    restore_nullglob="$(shopt -p nullglob || true)"
    restore_dotglob="$(shopt -p dotglob || true)"
    shopt -s nullglob dotglob
    symlink_candidates=("${host_dir}"/*)
    eval "${restore_nullglob}"
    eval "${restore_dotglob}"

    for host_path in "${symlink_candidates[@]}"; do
        if [[ ! -L "${host_path}" ]]; then
            continue
        fi

        resolved_target="$(realpath "${host_path}")"
        map_host_path_to_sandbox "${resolved_target}"
        target_sandbox_path="${REPLY}"
        add_parent_dirs_once "$(dirname "${target_sandbox_path}")"
        EXTRA_BINDS+=(--bind "${resolved_target}" "${target_sandbox_path}")
    done
}

select_host_tool_home() {
    local env_value="$1"
    local preferred_path="$2"
    local legacy_path="$3"

    if [[ -n "${env_value}" ]]; then
        REPLY="${env_value}"
        return
    fi

    if [[ -d "${preferred_path}" || ! -d "${legacy_path}" ]]; then
        REPLY="${preferred_path}"
        return
    fi

    REPLY="${legacy_path}"
}

mirror_persistent_subpath_symlink "${HOST_HOME}/.config/opencode" "${SANDBOX_OPENCODE_CONFIG_DIR}"
SANDBOX_OPENCODE_CONFIG_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.local/share/opencode" "${SANDBOX_OPENCODE_DATA_DIR}"
SANDBOX_OPENCODE_DATA_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.cache/opencode" "${SANDBOX_OPENCODE_CACHE_DIR}"
SANDBOX_OPENCODE_CACHE_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.cache/bun" "${SANDBOX_BUN_CACHE_DIR}"
SANDBOX_BUN_CACHE_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.opencode" "${SANDBOX_OPENCODE_ALT_DIR}"
SANDBOX_OPENCODE_ALT_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.agents" "${SANDBOX_AGENTS_DIR}"
SANDBOX_AGENTS_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.claude" "${SANDBOX_CLAUDE_DIR}"
SANDBOX_CLAUDE_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.bun" "${SANDBOX_BUN_HOME}"
SANDBOX_BUN_HOME="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.opencode-browser" "${SANDBOX_BROWSER_DIR}"
SANDBOX_BROWSER_DIR="${REPLY}"

bind_symlink_targets_in_dir "${OPENCODE_CONFIG_DIR}"

# Git identity/config is visible read-only so commits can use the user's normal
# identity without allowing agents to persist global git config changes.
if [[ -f "${HOST_HOME}/.gitconfig" ]]; then
    resolve_bind_source_path "${HOST_HOME}/.gitconfig"
    EXTRA_BINDS+=(--ro-bind "${REPLY}" "${SANDBOX_HOME}/.gitconfig")
fi

if [[ -f "${HOST_HOME}/.config/git/config" ]]; then
    add_parent_dirs_once "${SANDBOX_HOME}/.config/git"
    resolve_bind_source_path "${HOST_HOME}/.config/git/config"
    EXTRA_BINDS+=(--ro-bind "${REPLY}" "${SANDBOX_HOME}/.config/git/config")
fi
trace_startup "persistent symlink and git config binds prepared"

# Bind host tools unless explicitly disabled
if [[ "${ALLOW_HOST_TOOLS}" -eq 1 ]]; then
    info "Binding host development tools"

    # User binaries
    if [[ -d "${HOME}/.local/bin" ]]; then
        resolve_bind_source_path "${HOME}/.local/bin"
        EXTRA_BINDS+=(--ro-bind "${REPLY}" "${SANDBOX_HOME}/.local/bin")
        SANDBOX_PATH="${SANDBOX_HOME}/.local/bin:${SANDBOX_PATH}"
    fi

    trace_startup "host user binary binds prepared"

    # MCP/runtime package-manager state and caches.
    # These are writable so common language/package launchers can install and
    # cache dependencies without exposing the entire host home.
    HOST_RUNTIME_BIND_SUBPATHS=(
        ".local/share/uv"
        ".cache/uv"
        ".npm"
        ".cache/npm"
        ".cache/node"
        ".local/share/pnpm"
        ".cache/pnpm"
        ".krimto"
        ".cache/yarn"
        ".cache/pip"
        ".cache/pipx"
        ".local/pipx"
        ".cache/sccache"
        ".cache/go-build"
        ".hex"
        ".mix"
        ".cache/rebar3"
        ".cache/gleam"
        ".local/share/gleam"
        ".deno"
        ".gradle"
        ".m2/repository"
        ".nuget/packages"
        ".gem"
        ".bundle"
        ".cache/bundle"
        ".composer"
        ".cache/composer"
    )

    HOST_RUNTIME_BIND_DIRS=()
    for runtime_subpath in "${HOST_RUNTIME_BIND_SUBPATHS[@]}"; do
        HOST_RUNTIME_BIND_DIRS+=("${HOME}/${runtime_subpath}")
    done

    mkdir -p "${HOST_RUNTIME_BIND_DIRS[@]}"

    for runtime_subpath in "${HOST_RUNTIME_BIND_SUBPATHS[@]}"; do
        bind_runtime_dir_precreated "${HOME}/${runtime_subpath}" "${SANDBOX_HOME}/${runtime_subpath}"
    done
    trace_startup "host runtime cache binds prepared"

    # Pyenv
    if [[ -d "${HOME}/.pyenv" ]]; then
        resolve_bind_source_path "${HOME}/.pyenv"
        EXTRA_BINDS+=(--ro-bind "${REPLY}" "${SANDBOX_HOME}/.pyenv")
        SANDBOX_PATH="${SANDBOX_HOME}/.pyenv/shims:${SANDBOX_HOME}/.pyenv/bin:${SANDBOX_PATH}"
        PYENV_ROOT_SANDBOX="${SANDBOX_HOME}/.pyenv"
    fi

    # Rust/Cargo. Prefer explicit env from the host shell, then the XDG-style
    # homes from ~/.config/env/development.sh, then rustup/cargo legacy homes.
    select_host_tool_home "${RUSTUP_HOME:-}" "${HOME}/.local/share/rustup" "${HOME}/.rustup"
    HOST_RUSTUP_HOME="${REPLY}"
    if [[ -d "${HOST_RUSTUP_HOME}" ]]; then
        resolve_bind_source_path "${HOST_RUSTUP_HOME}"
        resolved_host_tool_home="${REPLY}"
        map_host_path_to_sandbox "${HOST_RUSTUP_HOME}"
        sandbox_tool_home="${REPLY}"
        add_parent_dirs_once "$(dirname "${sandbox_tool_home}")"
        EXTRA_BINDS+=(--ro-bind "${resolved_host_tool_home}" "${sandbox_tool_home}")
        RUSTUP_HOME_SANDBOX="${sandbox_tool_home}"
    fi

    select_host_tool_home "${CARGO_HOME:-}" "${HOME}/.local/share/cargo" "${HOME}/.cargo"
    HOST_CARGO_HOME="${REPLY}"
    mkdir -p "${HOST_CARGO_HOME}"
    resolve_bind_source_path "${HOST_CARGO_HOME}"
    resolved_host_tool_home="${REPLY}"
    map_host_path_to_sandbox "${HOST_CARGO_HOME}"
    sandbox_tool_home="${REPLY}"
    add_parent_dirs_once "$(dirname "${sandbox_tool_home}")"
    EXTRA_BINDS+=(--bind "${resolved_host_tool_home}" "${sandbox_tool_home}")
    CARGO_HOME_SANDBOX="${sandbox_tool_home}"
    SANDBOX_PATH="${CARGO_HOME_SANDBOX}/bin:${SANDBOX_PATH}"

    # Go. Prefer explicit GOPATH from the host shell, then ~/.local/share/go,
    # then the legacy ~/go path. Keep GOBIN explicit when configured.
    select_host_tool_home "${GOPATH:-}" "${HOME}/.local/share/go" "${HOME}/go"
    HOST_GOPATH="${REPLY}"
    mkdir -p "${HOST_GOPATH}"
    resolve_bind_source_path "${HOST_GOPATH}"
    resolved_host_tool_home="${REPLY}"
    map_host_path_to_sandbox "${HOST_GOPATH}"
    sandbox_tool_home="${REPLY}"
    add_parent_dirs_once "$(dirname "${sandbox_tool_home}")"
    EXTRA_BINDS+=(--bind "${resolved_host_tool_home}" "${sandbox_tool_home}")
    GOPATH_SANDBOX="${sandbox_tool_home}"
    SANDBOX_PATH="${GOPATH_SANDBOX}/bin:${SANDBOX_PATH}"
    if [[ -n "${GOBIN:-}" ]]; then
        map_host_path_to_sandbox "${GOBIN}"
        GOBIN_SANDBOX="${REPLY}"
        SANDBOX_PATH="${GOBIN_SANDBOX}:${SANDBOX_PATH}"
    fi

    trace_startup "host pyenv rust cargo go binds prepared"
fi
trace_startup "host tool binds prepared"

if [[ "${ALLOW_NVIM_REMOTE}" -eq 1 && -n "${NVIM:-}" && -S "${NVIM}" ]]; then
    NVIM_SOCKET_HOST="${NVIM}"
    NVIM_SOCKET_SANDBOX="${NVIM_SOCKET_HOST}"
    add_parent_dirs_once "$(dirname "${NVIM_SOCKET_SANDBOX}")"
    opt_bind_path "${NVIM_SOCKET_HOST}" "${NVIM_SOCKET_SANDBOX}"
fi
trace_startup "nvim bridge binds prepared"

if [[ "${ALLOW_GUI}" -eq 1 ]]; then
    info "Allowing GUI/session access"

    if [[ -d /tmp/.X11-unix ]]; then
        add_parent_dirs_once /tmp/.X11-unix
        EXTRA_BINDS+=(--ro-bind /tmp/.X11-unix /tmp/.X11-unix)
    fi

    if [[ -n "${XAUTHORITY:-}" && -e "${XAUTHORITY}" ]]; then
        add_parent_dirs_once "$(dirname "${XAUTHORITY}")"
        EXTRA_BINDS+=(--ro-bind "$(realpath "${XAUTHORITY}")" "${XAUTHORITY}")
    elif [[ -f "${HOST_HOME}/.Xauthority" ]]; then
        add_parent_dirs_once "$(dirname "${SANDBOX_HOME}/.Xauthority")"
        EXTRA_BINDS+=(--ro-bind "$(realpath "${HOST_HOME}/.Xauthority")" "${SANDBOX_HOME}/.Xauthority")
    fi

    if [[ -n "${XDG_RUNTIME_DIR:-}" && -d "${XDG_RUNTIME_DIR}" ]]; then
        bind_runtime_dir "${XDG_RUNTIME_DIR}" "${XDG_RUNTIME_DIR}"
    fi
fi
trace_startup "gui binds prepared"

RESOLV_CONF_TARGET="$(readlink -f /etc/resolv.conf 2>/dev/null || true)"
if [[ -n "${RESOLV_CONF_TARGET}" && "${RESOLV_CONF_TARGET}" != "/etc/resolv.conf" && -f "${RESOLV_CONF_TARGET}" ]]; then
    add_parent_dirs_once "$(dirname "${RESOLV_CONF_TARGET}")"
    EXTRA_BINDS+=(--ro-bind "${RESOLV_CONF_TARGET}" "${RESOLV_CONF_TARGET}")
fi

# Some hosts resolve names through NSS/systemd-resolved instead of plain DNS in
# /etc/resolv.conf. Keep network shared, but expose resolver runtime sockets and
# state read-only so getent/curl/opencode provider calls do not block in DNS.
opt_ro_bind_path /run/systemd/resolve /run/systemd/resolve
opt_ro_bind_path /run/dbus /run/dbus
opt_ro_bind_path /run/NetworkManager /run/NetworkManager
opt_ro_bind_path /var/run/nscd /var/run/nscd
trace_startup "resolver runtime binds prepared"

# Project-local Cargo binaries
if [[ -d "${PROJECT_DIR}/.cargo/bin" ]]; then
    EXTRA_BINDS+=("${PROJECT_TOOL_BIND_FLAG}" "${PROJECT_DIR}/.cargo/bin" "${SANDBOX_HOME}/.cargo/bin")
    SANDBOX_PATH="${SANDBOX_HOME}/.cargo/bin:${SANDBOX_PATH}"
fi

# Python virtual environments (project-local)
if [[ -d "${PROJECT_DIR}/.venv/bin" ]]; then
    EXTRA_BINDS+=("${PROJECT_TOOL_BIND_FLAG}" "${PROJECT_DIR}/.venv/bin" "${SANDBOX_PROJECT_ROOT}/.venv/bin")
    SANDBOX_PATH="${SANDBOX_PROJECT_ROOT}/.venv/bin:${SANDBOX_PATH}"
fi

# Node.js project-local binaries
if [[ -d "${PROJECT_DIR}/node_modules/.bin" ]]; then
    EXTRA_BINDS+=("${PROJECT_TOOL_BIND_FLAG}" "${PROJECT_DIR}/node_modules/.bin" "${SANDBOX_PROJECT_ROOT}/node_modules/.bin")
    SANDBOX_PATH="${SANDBOX_PROJECT_ROOT}/node_modules/.bin:${SANDBOX_PATH}"
fi
trace_startup "project tool binds prepared"

# Go project-local binaries
if [[ -d "${PROJECT_DIR}/bin" && -f "${PROJECT_DIR}/go.mod" ]]; then
    EXTRA_BINDS+=("${PROJECT_TOOL_BIND_FLAG}" "${PROJECT_DIR}/bin" "${SANDBOX_PROJECT_ROOT}/bin")
    SANDBOX_PATH="${SANDBOX_PROJECT_ROOT}/bin:${SANDBOX_PATH}"
fi

if [[ "${TARGET_KIND}" == "file" ]] && ! is_path_within "${PROJECT_DIR}" "${INVOCATION_CWD}"; then
    EXTRA_BINDS+=(--ro-bind "${INVOCATION_CWD}" "${INVOCATION_CWD}")
fi

# -------- Infrastructure Protection --------
PROTECTED_INFRA_DIRS=(
    ".git"
    ".github"
    ".turbo"
    ".cargo"
)

PROTECTED_INFRA_FILES=(
    ".gitignore"
    "package-lock.json"
    "poetry.lock"
    "Cargo.lock"
    "pnpm-lock.yaml"
    "yarn.lock"
)

SAFE_BINDS=()
if [[ "${ALLOW_INFRA}" -eq 0 ]]; then
    for dir in "${PROTECTED_INFRA_DIRS[@]}"; do
        if [[ "${dir}" == ".git" && "${ALLOW_GIT}" -eq 1 ]]; then
            continue
        fi

        if [[ -d "${PROJECT_DIR}/${dir}" ]]; then
            SAFE_BINDS+=(--ro-bind "${PROJECT_DIR}/${dir}" "${SANDBOX_PROJECT_ROOT}/${dir}")
            info "Protecting ${dir}/ (read-only)"
        fi
    done

    for file in "${PROTECTED_INFRA_FILES[@]}"; do
        if [[ -f "${PROJECT_DIR}/${file}" ]]; then
            SAFE_BINDS+=(--ro-bind "${PROJECT_DIR}/${file}" "${SANDBOX_PROJECT_ROOT}/${file}")
            info "Protecting ${file} (read-only)"
        fi

        if [[ "${TARGET_KIND}" == "dir" && "${TARGET_PATH}" != "${PROJECT_DIR}" && -f "${TARGET_PATH}/${file}" ]]; then
            SAFE_BINDS+=(--ro-bind "${TARGET_PATH}/${file}" "${TARGET_PATH}/${file}")
            info "Protecting ${TARGET_PATH#"${PROJECT_DIR}/"}/${file} (read-only)"
        fi
    done
fi

for added_path in "${ADD_RO_PATHS[@]}"; do
    add_custom_bind --ro-bind "${added_path}"
    info "Adding ${added_path} (read-only)"
done

for added_path in "${ADD_RW_PATHS[@]}"; do
    add_custom_bind --bind "${added_path}"
    info "Adding ${added_path} (read-write)"
done

# -------- run sandbox --------
BWRAP_CMD=(
    bwrap
    --ro-bind /usr /usr
    --ro-bind /bin /bin
    --ro-bind /lib /lib
)

if [[ "${BWRAP_DISABLE_USERNS_SUPPORTED}" -eq 1 ]]; then
    BWRAP_CMD=(bwrap --unshare-user "${BWRAP_CMD[@]:1}")
    BWRAP_CMD+=(--disable-userns)
else
    BWRAP_CMD=(bwrap --unshare-user-try "${BWRAP_CMD[@]:1}")
fi

if [[ -d /lib64 ]]; then
    BWRAP_CMD+=(--ro-bind /lib64 /lib64)
fi

if [[ -d /sys ]]; then
    BWRAP_CMD+=(--ro-bind /sys /sys)
fi

BWRAP_CMD+=(--ro-bind /etc /etc)

# Shadow git inside the sandbox with scoder-git while preserving the real git
# binary at a private path for the wrapper to call after policy checks.
BWRAP_CMD+=(
    --ro-bind "${REAL_GIT_HOST}" /scoder/real-git
    --ro-bind "${SCODER_GIT_HOST}" /usr/bin/git
)

if [[ "${RESTRICT_DEV}" -eq 1 ]]; then
    BWRAP_CMD+=(
        --dev-bind /dev/null /dev/null
        --dev-bind /dev/zero /dev/zero
        --dev-bind /dev/random /dev/random
        --dev-bind /dev/urandom /dev/urandom
        --dev-bind /dev/tty /dev/tty
        --tmpfs /dev/shm
    )
else
    BWRAP_CMD+=(--dev /dev)
fi

BWRAP_CMD+=(
    --proc /proc
    --tmpfs /tmp
    --tmpfs /home
    --dir "${SANDBOX_HOME}"
    --dir "${SANDBOX_LOCAL_DIR}"
    --dir "${SANDBOX_LOCAL_SHARE_DIR}"
    --dir "${SANDBOX_LOCAL_STATE_DIR}"
    --dir "${SANDBOX_CONFIG_DIR}"
    --dir "${SANDBOX_OPENCODE_CONFIG_DIR}"
    --dir "${SANDBOX_CACHE_DIR}"
    --dir "${SANDBOX_BUN_CACHE_DIR}"
)

BWRAP_CMD+=("${EXTRA_DIRS[@]}")
BWRAP_CMD+=("${SANDBOX_SYMLINKS[@]}")
BWRAP_CMD+=("${EXTRA_BINDS[@]}")
if [[ "${SANDBOX_PROJECT_ROOT}" != "/" ]]; then
    BWRAP_CMD+=(--dir "$(dirname "${SANDBOX_PROJECT_ROOT}")")
fi
if [[ "${SANDBOX_PROJECT_ROOT}" != "/" ]]; then
    BWRAP_CMD+=(--dir "${SANDBOX_PROJECT_ROOT}")
fi
BWRAP_CMD+=("${PROJECT_BIND_FLAG}" "${PROJECT_DIR}" "${SANDBOX_PROJECT_ROOT}")

if [[ "${SANDBOX_WORKDIR}" != "/" && "${SANDBOX_WORKDIR}" != "${SANDBOX_PROJECT_ROOT}" ]]; then
    add_parent_dirs_once "${SANDBOX_WORKDIR}"
fi

if [[ "${TARGET_KIND}" == "file" && "${FS_MODE}" != "ro" ]]; then
    prepare_single_file_overlay
    BWRAP_CMD+=("${FILE_MODE_BINDS[@]}")
fi

if [[ ${#SAFE_BINDS[@]} -gt 0 ]]; then
    BWRAP_CMD+=("${SAFE_BINDS[@]}")
fi

# Data/cache binding (always for persistence)
BWRAP_CMD+=(
    --bind "${OPENCODE_CONFIG_DIR}" "${SANDBOX_OPENCODE_CONFIG_DIR}"
    --bind "${OPENCODE_DATA}" "${SANDBOX_OPENCODE_DATA_DIR}"
    --bind "${OPENCODE_CACHE}" "${SANDBOX_OPENCODE_CACHE_DIR}"
    --bind "${OPENCODE_ALT_DIR}" "${SANDBOX_OPENCODE_ALT_DIR}"
    --bind "${AGENTS_DIR}" "${SANDBOX_AGENTS_DIR}"
    --bind "${BUN_HOME}" "${SANDBOX_BUN_HOME}"
    --bind "${BUN_CACHE}" "${SANDBOX_BUN_CACHE_DIR}"
    --bind "${PLAYWRIGHT_BROWSERS_CACHE}" "${SANDBOX_PLAYWRIGHT_BROWSERS_CACHE}"
)

if [[ -n "${CLAUDE_DIR:-}" ]]; then
    BWRAP_CMD+=(--bind "${CLAUDE_DIR}" "${SANDBOX_CLAUDE_DIR}")
fi

if [[ -n "${OPENCODE_BROWSER_DIR:-}" ]]; then
    BWRAP_CMD+=(--bind "${OPENCODE_BROWSER_DIR}" "${SANDBOX_BROWSER_DIR}")
fi

if [[ -f "${OPENCODE_CONFIG_DIR}/opencode.json" ]]; then
    info "Using config: ${OPENCODE_CONFIG_DIR}/opencode.json"
else
    info "No opencode.json found, OpenCode will use defaults"
fi

BWRAP_CMD+=(--chdir "${SANDBOX_WORKDIR}")
BWRAP_CMD+=(
    --die-with-parent
    --clearenv
)

inherit_host_environment

BWRAP_CMD+=(
    --setenv PATH "${SANDBOX_PATH}"
    --setenv HOME "${SANDBOX_HOME}"
    --setenv USER "${HOST_USER}"
    --setenv LOGNAME "${HOST_LOGNAME}"
    --setenv TERM "${TERM:-xterm-256color}"
    --setenv COLORTERM "${COLORTERM:-truecolor}"
    --setenv LANG "${LANG:-C.UTF-8}"
    --setenv LC_ALL "${LC_ALL:-C.UTF-8}"
    --setenv EDITOR "${SANDBOX_EDITOR}"
    --setenv VISUAL "${SANDBOX_EDITOR}"
    --setenv SHELL "${SHELL:-/bin/bash}"
    --setenv GIT_OPTIONAL_LOCKS 0
    --setenv SCODER_REAL_GIT /scoder/real-git
    --setenv PLAYWRIGHT_BROWSERS_PATH "${SANDBOX_PLAYWRIGHT_BROWSERS_CACHE}"
    --setenv PNPM_HOME "${SANDBOX_PNPM_HOME}"
    --setenv MISE_SKIP_ACTIVATE 1
    --setenv UV_LINK_MODE copy
)

if [[ -n "${PYENV_ROOT_SANDBOX:-}" ]]; then
    BWRAP_CMD+=(--setenv PYENV_ROOT "${PYENV_ROOT_SANDBOX}")
fi

if [[ -n "${RUSTUP_HOME_SANDBOX:-}" ]]; then
    BWRAP_CMD+=(--setenv RUSTUP_HOME "${RUSTUP_HOME_SANDBOX}")
fi

if [[ -n "${CARGO_HOME_SANDBOX:-}" ]]; then
    BWRAP_CMD+=(--setenv CARGO_HOME "${CARGO_HOME_SANDBOX}")
fi

if [[ -n "${GOPATH_SANDBOX:-}" ]]; then
    BWRAP_CMD+=(--setenv GOPATH "${GOPATH_SANDBOX}")
fi

if [[ -n "${GOBIN_SANDBOX:-}" ]]; then
    BWRAP_CMD+=(--setenv GOBIN "${GOBIN_SANDBOX}")
fi

if [[ "${ALLOW_NVIM_REMOTE}" -eq 1 && -n "${NVIM_SOCKET_SANDBOX:-}" ]]; then
    BWRAP_CMD+=(--setenv NVIM "${NVIM_SOCKET_SANDBOX}")
fi

if [[ "${ALLOW_NVIM_REMOTE}" -eq 1 && -n "${NVIM_LISTEN_ADDRESS:-}" ]]; then
    BWRAP_CMD+=(--setenv NVIM_LISTEN_ADDRESS "${NVIM_LISTEN_ADDRESS}")
fi

if [[ "${ALLOW_NVIM_REMOTE}" -eq 1 && -n "${XDG_RUNTIME_DIR:-}" ]]; then
    BWRAP_CMD+=(--setenv XDG_RUNTIME_DIR "${XDG_RUNTIME_DIR}")
fi

if [[ -n "${PYO3_PYTHON:-}" ]]; then
    BWRAP_CMD+=(--setenv PYO3_PYTHON "${SANDBOX_WORKDIR}/.venv/bin/python")
fi

if [[ ${#RAW_COMMAND[@]} -gt 0 ]]; then
    BWRAP_CMD+=("${RAW_COMMAND[@]}")
else
    BWRAP_CMD+=("${OPENCODE_BIN}" "${OPENCODE_ARGS[@]}")
fi

trace_startup "bwrap command built"

info "Launching scoder sandbox..."
if [[ "${TARGET_KIND}" == "file" && "${FS_MODE}" != "ro" ]]; then
    "${BWRAP_CMD[@]}"
    BWRAP_STATUS=$?
    if [[ ${BWRAP_STATUS} -eq 0 ]]; then
        sync_single_file_target_back || exit 1
    fi
    exit ${BWRAP_STATUS}
fi

exec "${BWRAP_CMD[@]}"
