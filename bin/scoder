#!/usr/bin/env bash

# scoder - Safe wrapper for OpenCode using bubblewrap
# Homepage: https://github.com/anomalyco/opencode
# Author: Andres Monge (aemonge)
# License: MIT

set -euo pipefail

readonly PROGRAM_NAME="scoder"
readonly PROGRAM_VERSION="0.9.0"
readonly OPENCODE_BIN_DEFAULT="opencode"

# Colors for output
readonly RED='\033[0;31m'
readonly YELLOW='\033[1;33m'
readonly GREEN='\033[0;32m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m' # No Color

usage() {
    cat <<'USAGE_EOF'
scoder 0.9.0
Safe OpenCode wrapper using bubblewrap.

Usage:
  scoder [OPENCODE_ARGS...] [-- [TARGET] [SCODER_OPTIONS...]]
  scoder [OPENCODE_ARGS...] -- [TARGET] -x COMMAND [ARG...]

Options:
  -h, --help              Show this help and exit
  -V, --version           Show version and exit
  -a, --add PATH          Add extra file/dir to sandbox read-only
  -A, --add-rw PATH       Add extra file/dir to sandbox read-write
  -b, --bin PATH          Path to opencode binary (default: "opencode")
  -q, --quiet             Suppress informational output
  -x, --exec COMMAND...   Execute raw command inside sandbox instead of opencode
      --doctor            Run user-facing diagnostics and exit
      --validate          Run comprehensive validation tests and exit
      --ro                Mount project directory read-only (safe)
      --rw                Mount project directory read-write (default)
      --allow-git         Allow write access to .git directory (default: read-only)
      --allow-infra       Allow write access to all protected infra dirs
      --full-dev          Allow full /dev access inside sandbox
      --no-nvim-remote    Disable active Neovim socket bridge
  -g, --allow-gui         Allow GUI/session access for desktop apps like Chromium
  -w, --web-developer     Enable browser-dev mode and auto-start Chromium DevTools
  --allow-host-tools      Bind host user tools (~/.local/bin, mise, pyenv, uv, rustup/cargo, etc) (default)
  --no-host-tools         Disable binding host user tools
USAGE_EOF

    cat <<'USAGE_END'

Arguments:
  OPENCODE_ARGS           Arguments passed verbatim to opencode before "--"
  TARGET                  Directory or regular file exposed at same absolute path after "--" (default: $PWD)
  COMMAND [ARG...]        Raw command executed inside the sandbox with -x/--exec

Environment:
  OPENCODE_BIN            Overrides default opencode binary
  SCODER_FS_MODE          "ro" (secure) or "rw" (default, allow writes)

Protected Directories (read-only by default):
  .git, .github, .turbo, .cargo
  .gitignore, package-lock.json, poetry.lock, Cargo.lock, .github/

Writable Runtime State:
  - ~/.config/opencode
  - ~/.cache/opencode
  - ~/.local/share/opencode
  - ~/.opencode
  - ~/.agents
  - ~/.bun
  - ~/.cache/bun
  - ~/.cache/ms-playwright

Examples:
  scoder                    # rw sandbox of $PWD, infra protected
  scoder "hi"                         # pass prompt to opencode, sandbox $PWD
  scoder "hi" -- ./myproj -w          # prompt opencode, sandbox ./myproj, browser-dev mode
  scoder agent list -- ./myproj        # run opencode agent list in ./myproj sandbox
  scoder -- ./myproj --doctor          # run user-facing diagnostics
  scoder -- ./myproj --validate        # run comprehensive validation tests
  scoder -- ./myproj --ro              # read-only sandbox
  scoder -- ./myproj --allow-git       # allow .git writes
  scoder -- ./myproj -a ../shared.env  # add extra file read-only
  scoder -- ./myproj -A ../scratch     # add extra directory read-write
  scoder -- ./myproj -x /bin/bash -lc 'env | grep HOME' # raw command in sandbox
  scoder -- src/lib/target.txt -x /bin/bash -lc 'cat src/lib/target.txt'

Security Note:
  HOME mirrors your host home path on tmpfs with explicit binds.
  The active Neovim socket is exposed by default when NVIM points to a socket.
  OpenCode and Bun runtime state is persisted via explicit writable binds.
  Host tools are bound by default (use --no-host-tools to disable them).
  The project is writable by default, but critical infrastructure directories
  are protected read-only unless you explicitly opt in.
USAGE_END
}

version() {
    echo "${PROGRAM_NAME} ${PROGRAM_VERSION}"
    echo "Sandbox mode: bubblewrap"
}

error() {
    echo -e "${RED}${PROGRAM_NAME}: $*${NC}" >&2
}

warning() {
    echo -e "${YELLOW}${PROGRAM_NAME}: $*${NC}" >&2
}

info() {
    if [[ "${QUIET}" -eq 0 ]]; then
        echo -e "${GREEN}${PROGRAM_NAME}: $*${NC}" >&2
    fi
}

info_blue() {
    if [[ "${QUIET}" -eq 0 ]]; then
        echo -e "${BLUE}${PROGRAM_NAME}: $*${NC}" >&2
    fi
}

startup_trace_ms() {
    date +%s%3N 2>/dev/null || printf '%s000' "$(date +%s)"
}

trace_startup() {
    if [[ "${SCODER_TRACE_STARTUP:-0}" != "1" ]]; then
        return 0
    fi

    local label="$1"
    local now
    local delta
    local total

    now="$(startup_trace_ms)"
    if [[ "${SCODER_TRACE_STARTUP_STARTED:-0}" -eq 0 ]]; then
        SCODER_TRACE_STARTUP_STARTED="${now}"
        SCODER_TRACE_STARTUP_LAST="${now}"
    fi

    delta=$((now - SCODER_TRACE_STARTUP_LAST))
    total=$((now - SCODER_TRACE_STARTUP_STARTED))
    SCODER_TRACE_STARTUP_LAST="${now}"

    printf 'scoder startup: +%sms total=%sms %s\n' "${delta}" "${total}" "${label}" >&2
}

file_mtime() {
    stat -c %Y "$1" 2>/dev/null || printf '0'
}

resolve_bind_source_path() {
    local source_path="$1"

    if [[ -L "${source_path}" ]]; then
        REPLY="$(realpath "${source_path}")"
        return
    fi

    REPLY="${source_path}"
}

init_discovery_cache() {
    SCODER_CACHE_DIR="${HOST_HOME}/.cache/scoder"
    SCODER_DISCOVERY_CACHE="${SCODER_CACHE_DIR}/discovery-v1.env"
    SCODER_PLUGIN_INTEGRITY_CACHE="${SCODER_CACHE_DIR}/plugin-integrity-v1"
    SCODER_DISCOVERY_CACHE_VALID=0

    mkdir -p "${SCODER_CACHE_DIR}"

    if [[ "${SCODER_FORCE_PROBE:-0}" == "1" || "${SCODER_FORCE_DISCOVERY:-0}" == "1" ]]; then
        return 0
    fi

    if [[ -f "${SCODER_DISCOVERY_CACHE}" ]]; then
        # shellcheck disable=SC1090
        source "${SCODER_DISCOVERY_CACHE}" || true
        SCODER_DISCOVERY_CACHE_VALID=1
    fi
}

is_discovery_cache_current() {
    local expected_bwrap_path="$1"
    local expected_bwrap_version="$2"
    local expected_script_mtime

    if [[ "${SCODER_DISCOVERY_CACHE_VALID:-0}" -ne 1 ]]; then
        return 1
    fi

    expected_script_mtime="$(file_mtime "$0")"
    [[ "${SCODER_CACHE_SCRIPT_MTIME:-}" == "${expected_script_mtime}" ]] || return 1
    [[ "${SCODER_CACHE_BWRAP_PATH:-}" == "${expected_bwrap_path}" ]] || return 1
    [[ "${SCODER_CACHE_BWRAP_VERSION:-}" == "${expected_bwrap_version}" ]] || return 1
}

write_discovery_cache() {
    if [[ -z "${SCODER_DISCOVERY_CACHE:-}" ]]; then
        return 0
    fi

    umask 077
    {
        printf 'SCODER_CACHE_SCRIPT_MTIME=%q\n' "$(file_mtime "$0")"
        printf 'SCODER_CACHE_BWRAP_PATH=%q\n' "${SCODER_CACHE_BWRAP_PATH:-}"
        printf 'SCODER_CACHE_BWRAP_VERSION=%q\n' "${SCODER_CACHE_BWRAP_VERSION:-}"
        printf 'SCODER_CACHE_BWRAP_DISABLE_USERNS_SUPPORTED=%q\n' "${SCODER_CACHE_BWRAP_DISABLE_USERNS_SUPPORTED:-}"
        printf 'SCODER_CACHE_BWRAP_NAMESPACE_SUPPORT=%q\n' "${SCODER_CACHE_BWRAP_NAMESPACE_SUPPORT:-}"
        printf 'SCODER_CACHE_REAL_GIT_HOST=%q\n' "${SCODER_CACHE_REAL_GIT_HOST:-}"
        printf 'SCODER_CACHE_REAL_GIT_REALPATH=%q\n' "${SCODER_CACHE_REAL_GIT_REALPATH:-}"
        printf 'SCODER_CACHE_SCODER_GIT_HOST=%q\n' "${SCODER_CACHE_SCODER_GIT_HOST:-}"
        printf 'SCODER_CACHE_SCODER_GIT_REALPATH=%q\n' "${SCODER_CACHE_SCODER_GIT_REALPATH:-}"
        printf 'SCODER_CACHE_OPENCODE_BIN=%q\n' "${SCODER_CACHE_OPENCODE_BIN:-}"
    } >"${SCODER_DISCOVERY_CACHE}"
}

json_escape() {
    local value="$1"
    value=${value//\\/\\\\}
    value=${value//\"/\\\"}
    value=${value//$'\n'/\\n}
    printf '%s' "${value}"
}

watch_plugin_integrity_path() {
    SCODER_PLUGIN_WATCH_PATHS+=("$1")
}

is_local_plugin_spec() {
    case "$1" in
    /* | ./* | ../* | \~ | \~/* | file:*) return 0 ;;
    esac
    return 1
}

resolve_local_plugin_path() {
    local spec="$1"
    local config_dir="$2"
    local path="${spec#file:}"

    case "${path}" in
    \~) path="${HOST_HOME}" ;;
    \~/*) path="${HOST_HOME}/${path#\~/}" ;;
    /*) ;;
    *) path="${config_dir}/${path}" ;;
    esac

    realpath -ms -- "${path}"
}

opencode_plugin_cache_key() {
    local spec="$1"
    local scoped_tail

    case "${spec}" in
    git+* | github:* | http://* | https://* | *@git+* | *@github:*)
        printf '%s\n' "${spec}"
        return
        ;;
    @*/*)
        scoped_tail="${spec#*/}"
        if [[ "${scoped_tail}" == *@* ]]; then
            printf '%s\n' "${spec}"
        else
            printf '%s@latest\n' "${spec}"
        fi
        ;;
    *@*) printf '%s\n' "${spec}" ;;
    *) printf '%s@latest\n' "${spec}" ;;
    esac
}

is_valid_package_manifest() {
    local package_dir="$1"
    local manifest="${package_dir}/package.json"
    local jq_bin="${SCODER_JQ_BIN:-jq}"

    [[ -f "${manifest}" ]] && "${jq_bin}" -e 'type == "object"' "${manifest}" >/dev/null 2>&1
}

resolve_contained_path() {
    local root
    local candidate
    local relative

    root="$(realpath -m -- "$1")" || return 1
    candidate="$(realpath -m -- "$2")" || return 1
    relative="$(realpath -m --relative-to="${root}" -- "${candidate}")" || return 1

    case "${relative}" in
    .. | ../* | /*) return 1 ;;
    esac

    printf '%s\n' "${candidate}"
}

resolve_plugin_entry() {
    local package_dir="$1"
    local manifest="${package_dir}/package.json"
    local jq_bin="${SCODER_JQ_BIN:-jq}"
    local entry
    local entry_candidate

    if [[ -f "${manifest}" ]]; then
        is_valid_package_manifest "${package_dir}" || return 1
        entry="$("${jq_bin}" -er '
            [
                if (.exports? | type) == "string" then .exports else null end,
                if (.exports?["."]? | type) == "string" then .exports["."] else null end,
                if ((.exports?["."]? | type) == "object") and
                    ((.exports["."].import? | type) == "string")
                then .exports["."].import else null end,
                if ((.exports?["."]? | type) == "object") and
                    ((.exports["."].default? | type) == "string")
                then .exports["."].default else null end,
                if ((.exports?["."]? | type) == "object") and
                    ((.exports["."].require? | type) == "string")
                then .exports["."].require else null end,
                if ((.exports? | type) == "object") and
                    ((.exports.import? | type) == "string")
                then .exports.import else null end,
                if ((.exports? | type) == "object") and
                    ((.exports.default? | type) == "string")
                then .exports.default else null end,
                if ((.exports? | type) == "object") and
                    ((.exports.require? | type) == "string")
                then .exports.require else null end,
                if (.module? | type) == "string" then .module else null end,
                if (.main? | type) == "string" then .main else null end
            ] | map(select(type == "string" and length > 0)) | .[0] // empty
        ' "${manifest}" 2>/dev/null || true)"

        if [[ -n "${entry}" ]]; then
            case "${entry}" in
            /*) entry_candidate="${entry}" ;;
            *) entry_candidate="${package_dir}/${entry#./}" ;;
            esac
            if ! resolve_contained_path "${package_dir}" "${entry_candidate}" >/dev/null; then
                return 2
            fi
            printf '%s\n' "${entry_candidate}"
            return 0
        fi
    fi

    for entry in index.js index.mjs index.ts; do
        entry_candidate="${package_dir}/${entry}"
        if ! resolve_contained_path "${package_dir}" "${entry_candidate}" >/dev/null; then
            return 2
        fi
        if [[ -f "${entry_candidate}" ]]; then
            printf '%s\n' "${entry_candidate}"
            return 0
        fi
    done

    return 1
}

report_external_plugin_failure() {
    local spec="$1"
    local reason="$2"
    local path="$3"

    error "plugin '${spec}': ${reason}: ${path}"
    printf '  repair: opencode plugin --global --force %q\n' "${spec}" >&2
}

report_local_plugin_failure() {
    local spec="$1"
    local reason="$2"
    local path="$3"

    error "plugin '${spec}': ${reason}: ${path}"
    printf '  repair: restore the local plugin or correct its configured path: %q\n' "${spec}" >&2
}

check_local_plugin() {
    local spec="$1"
    local config_dir="$2"
    local path
    local entry
    local entry_status

    path="$(resolve_local_plugin_path "${spec}" "${config_dir}")"
    if [[ -f "${path}" ]]; then
        watch_plugin_integrity_path "${path}"
        return 0
    fi
    if [[ ! -d "${path}" ]]; then
        report_local_plugin_failure "${spec}" "local path is missing" "${path}"
        return 1
    fi
    watch_plugin_integrity_path "${path}"
    if [[ -f "${path}/package.json" ]] && ! is_valid_package_manifest "${path}"; then
        report_local_plugin_failure "${spec}" "local package manifest is invalid" "${path}/package.json"
        return 1
    fi
    if [[ -f "${path}/package.json" ]]; then
        watch_plugin_integrity_path "${path}/package.json"
    fi

    if entry="$(resolve_plugin_entry "${path}")"; then
        if [[ -f "${entry}" ]]; then
            watch_plugin_integrity_path "${entry}"
            return 0
        fi
    else
        entry_status=$?
        if [[ ${entry_status} -eq 2 ]]; then
            report_local_plugin_failure "${spec}" "entry point escapes package directory" "${path}/package.json"
            return 1
        fi
    fi
    if [[ -z "${entry:-}" || ! -f "${entry}" ]]; then
        report_local_plugin_failure "${spec}" "local package entry point is missing" "${entry:-${path}}"
        return 1
    fi
}

check_external_plugin() {
    local spec="$1"
    local cache_root="$2"
    local jq_bin="${SCODER_JQ_BIN:-jq}"
    local cache_key
    local wrapper
    local dependency
    local dependency_count
    local cache_root_path
    local wrapper_candidate
    local package_dir
    local package_candidate
    local node_modules_root
    local entry
    local entry_status

    cache_key="$(opencode_plugin_cache_key "${spec}")"
    cache_root_path="$(realpath -m -- "${cache_root}")"
    wrapper_candidate="${cache_root_path}/${cache_key}"
    if ! wrapper="$(resolve_contained_path "${cache_root_path}" "${wrapper_candidate}")"; then
        report_external_plugin_failure "${spec}" "cache wrapper escapes cache root" "${wrapper_candidate}"
        return 1
    fi
    if [[ ! -f "${wrapper}/package.json" ]]; then
        report_external_plugin_failure "${spec}" "cache wrapper is missing" "${wrapper}"
        return 1
    fi
    watch_plugin_integrity_path "${wrapper_candidate}"
    watch_plugin_integrity_path "${wrapper_candidate}/package.json"
    if ! is_valid_package_manifest "${wrapper}"; then
        report_external_plugin_failure "${spec}" "cache wrapper manifest is invalid" "${wrapper}/package.json"
        return 1
    fi
    if ! "${jq_bin}" -e '(.dependencies? | type) == "object"' "${wrapper}/package.json" >/dev/null 2>&1; then
        report_external_plugin_failure "${spec}" "cache wrapper dependencies must be a JSON object" "${wrapper}/package.json"
        return 1
    fi

    if ! dependency_count="$("${jq_bin}" -er '.dependencies | keys | length' "${wrapper}/package.json" 2>/dev/null)"; then
        report_external_plugin_failure "${spec}" "cache wrapper manifest is invalid" "${wrapper}/package.json"
        return 1
    fi
    if [[ "${dependency_count}" -ne 1 ]]; then
        report_external_plugin_failure "${spec}" "cache wrapper must contain exactly one dependency" "${wrapper}/package.json"
        return 1
    fi

    if ! dependency="$("${jq_bin}" -er '.dependencies // {} | keys[0]' "${wrapper}/package.json" 2>/dev/null)"; then
        report_external_plugin_failure "${spec}" "cache wrapper dependency is invalid" "${wrapper}/package.json"
        return 1
    fi
    if ! node_modules_root="$(resolve_contained_path "${wrapper}" "${wrapper}/node_modules")"; then
        report_external_plugin_failure "${spec}" "installed package escapes node_modules" "${wrapper}/node_modules"
        return 1
    fi
    case "${dependency}" in
    /*) package_candidate="${dependency}" ;;
    *) package_candidate="${node_modules_root}/${dependency}" ;;
    esac
    if ! package_dir="$(resolve_contained_path "${node_modules_root}" "${package_candidate}")"; then
        report_external_plugin_failure "${spec}" "installed package escapes node_modules" "${package_candidate}"
        return 1
    fi
    if [[ ! -f "${package_dir}/package.json" ]]; then
        report_external_plugin_failure "${spec}" "installed package is missing" "${package_dir}"
        return 1
    fi
    watch_plugin_integrity_path "${package_candidate}"
    watch_plugin_integrity_path "${package_candidate}/package.json"
    if ! is_valid_package_manifest "${package_dir}"; then
        report_external_plugin_failure "${spec}" "installed package manifest is invalid" "${package_dir}/package.json"
        return 1
    fi

    if entry="$(resolve_plugin_entry "${package_dir}")"; then
        if [[ -f "${entry}" ]]; then
            watch_plugin_integrity_path "${entry}"
            return 0
        fi
    else
        entry_status=$?
        if [[ ${entry_status} -eq 2 ]]; then
            report_external_plugin_failure "${spec}" "entry point escapes package directory" "${package_dir}/package.json"
            return 1
        fi
    fi
    if [[ -z "${entry:-}" || ! -f "${entry}" ]]; then
        report_external_plugin_failure "${spec}" "entry point is missing" "${entry:-${package_dir}}"
        return 1
    fi
}

check_opencode_plugins() {
    local config_path="$1"
    local cache_root="$2"
    local jq_bin="${SCODER_JQ_BIN:-jq}"
    local config_dir
    local index
    local plugin_count
    local spec
    local failures=0

    SCODER_PLUGIN_WATCH_PATHS=()
    [[ -f "${config_path}" ]] || return 0
    watch_plugin_integrity_path "${config_path}"
    if ! command -v "${jq_bin}" >/dev/null 2>&1 && [[ ! -x "${jq_bin}" ]]; then
        error "OpenCode plugin preflight requires jq: ${jq_bin}"
        return 1
    fi
    if ! "${jq_bin}" -e '
        if has("plugin") then
            if (.plugin | type) != "array" then false
            else all(.plugin[];
                (type == "string") or
                ((type == "array") and (length == 2) and
                    ((.[0] | type) == "string") and ((.[1] | type) == "object"))
            )
            end
        else true
        end
    ' "${config_path}" >/dev/null 2>&1; then
        error "invalid OpenCode plugin configuration: ${config_path}"
        return 1
    fi

    config_dir="$(dirname "${config_path}")"
    if ! plugin_count="$("${jq_bin}" -er 'if has("plugin") then (.plugin | length) else 0 end' "${config_path}")"; then
        error "invalid OpenCode plugin configuration: ${config_path}"
        return 1
    fi
    for ((index = 0; index < plugin_count; index++)); do
        # shellcheck disable=SC2016 # $index is a jq variable.
        if ! spec="$("${jq_bin}" -er --argjson index "${index}" '
            .plugin[$index] | if type == "array" then .[0] else . end
        ' "${config_path}")"; then
            error "invalid OpenCode plugin entry at index ${index}: ${config_path}"
            failures=$((failures + 1))
            continue
        fi
        if is_local_plugin_spec "${spec}"; then
            check_local_plugin "${spec}" "${config_dir}" || failures=$((failures + 1))
        else
            check_external_plugin "${spec}" "${cache_root}" || failures=$((failures + 1))
        fi
    done

    [[ ${failures} -eq 0 ]]
}

plugin_integrity_path_fingerprint() {
    local fingerprint
    local path
    local -a file_paths=()
    local -a directory_paths=()
    local -a directory_entries=()
    local snapshot_file

    for path in "$@"; do
        if [[ -f "${path}" ]]; then
            file_paths+=("${path}")
        elif [[ -d "${path}" ]]; then
            directory_paths+=("${path}")
        else
            return 1
        fi
    done

    if [[ ${#directory_paths[@]} -gt 0 ]]; then
        snapshot_file="$(mktemp "${TMPDIR:-/tmp}/scoder-plugin-paths.XXXXXX")" || return 1
        if ! find -H "${directory_paths[@]}" -mindepth 1 -maxdepth 1 -print0 | sort -z >"${snapshot_file}"; then
            rm -f -- "${snapshot_file}"
            return 1
        fi
        if ! mapfile -d '' -t directory_entries <"${snapshot_file}"; then
            rm -f -- "${snapshot_file}"
            return 1
        fi
        rm -f -- "${snapshot_file}"
    fi

    fingerprint="$({
        printf 'paths\0'
        printf '%s\0' "$@"
        realpath -ez -- "$@" || return 1
        stat --printf='path\0%n\0identity\0%F:%s:%Y:%i\0link\0%N\0' -- "$@" || return 1
        if [[ ${#file_paths[@]} -gt 0 ]]; then
            sha256sum -z -- "${file_paths[@]}" || return 1
        fi
        if [[ ${#directory_entries[@]} -gt 0 ]]; then
            stat --printf='entry\0%n\0identity\0%F:%s:%Y:%i\0link\0%N\0' \
                -- "${directory_entries[@]}" || return 1
        fi
    } | sha256sum)" || return 1
    REPLY="${fingerprint%% *}"
}

is_plugin_integrity_cache_current() {
    local cache_file="$1"
    local current_script="$2"
    local current_config="$3"
    local cache_fd
    local header
    local expected_fingerprint
    local path=""
    local -a cached_paths=()
    local owner
    local mode

    [[ -f "${cache_file}" && ! -L "${cache_file}" ]] || return 1
    owner="$(stat -c %u -- "${cache_file}")" || return 1
    mode="$(stat -c %a -- "${cache_file}")" || return 1
    [[ "${owner}" == "$(id -u)" && "${mode}" == "600" ]] || return 1

    exec {cache_fd}<"${cache_file}" || return 1
    if ! IFS= read -r -d '' header <&"${cache_fd}" || [[ "${header}" != "scoder-plugin-integrity-v1" ]]; then
        exec {cache_fd}<&-
        return 1
    fi
    if ! IFS= read -r -d '' expected_fingerprint <&"${cache_fd}"; then
        exec {cache_fd}<&-
        return 1
    fi

    while IFS= read -r -d '' path <&"${cache_fd}"; do
        cached_paths+=("${path}")
        path=""
    done
    exec {cache_fd}<&-

    [[ -z "${path}" && ${#cached_paths[@]} -ge 2 ]] || return 1
    [[ "${cached_paths[0]}" == "${current_script}" && "${cached_paths[1]}" == "${current_config}" ]] || return 1
    plugin_integrity_path_fingerprint "${cached_paths[@]}" && [[ "${REPLY}" == "${expected_fingerprint}" ]]
}

collect_plugin_integrity_paths() {
    local path
    local -A watched_paths=()

    SCODER_PLUGIN_UNIQUE_PATHS=()
    for path in "${SCODER_PLUGIN_WATCH_PATHS[@]}"; do
        if [[ -n "${watched_paths[${path}]+set}" ]]; then
            continue
        fi
        watched_paths[${path}]=1
        SCODER_PLUGIN_UNIQUE_PATHS+=("${path}")
    done
}

write_plugin_integrity_cache() {
    local cache_file="$1"
    local fingerprint="$2"
    shift 2
    local cache_dir
    local temporary_file

    cache_dir="$(dirname -- "${cache_file}")"
    mkdir -p "${cache_dir}" || return 1
    umask 077
    temporary_file="$(mktemp "${cache_file}.tmp.XXXXXX")" || return 1

    if ! {
        printf 'scoder-plugin-integrity-v1\0'
        printf '%s\0' "${fingerprint}"
        printf '%s\0' "$@"
    } >"${temporary_file}"; then
        rm -f -- "${temporary_file}"
        return 1
    fi

    if ! chmod 600 "${temporary_file}" || ! mv -f -- "${temporary_file}" "${cache_file}"; then
        rm -f -- "${temporary_file}"
        return 1
    fi
}

plugin_integrity_cache_validation_hook() { :; }

check_opencode_plugins_cached() {
    local script_path="$1"
    local config_path="$2"
    local cache_root="$3"
    local integrity_cache="$4"
    local first_fingerprint
    local second_fingerprint
    local index
    local -a first_paths=()
    local -a second_paths=()

    SCODER_PLUGIN_INTEGRITY_CACHE_HIT=0
    if command -v sha256sum >/dev/null 2>&1 &&
        is_plugin_integrity_cache_current "${integrity_cache}" "${script_path}" "${config_path}"; then
        SCODER_PLUGIN_INTEGRITY_CACHE_HIT=1
        trace_startup "OpenCode plugin integrity cache hit"
        return 0
    fi

    trace_startup "OpenCode plugin integrity cache miss"
    rm -f -- "${integrity_cache}"
    if ! check_opencode_plugins "${config_path}" "${cache_root}"; then
        return 1
    fi
    [[ -f "${config_path}" ]] || return 0
    if ! command -v sha256sum >/dev/null 2>&1; then
        return 0
    fi

    SCODER_PLUGIN_WATCH_PATHS=("${script_path}" "${SCODER_PLUGIN_WATCH_PATHS[@]}")
    collect_plugin_integrity_paths
    first_paths=("${SCODER_PLUGIN_UNIQUE_PATHS[@]}")
    if ! plugin_integrity_path_fingerprint "${first_paths[@]}"; then
        error "OpenCode plugin integrity changed after successful validation"
        return 1
    fi
    first_fingerprint="${REPLY}"

    plugin_integrity_cache_validation_hook
    if ! check_opencode_plugins "${config_path}" "${cache_root}"; then
        return 1
    fi
    SCODER_PLUGIN_WATCH_PATHS=("${script_path}" "${SCODER_PLUGIN_WATCH_PATHS[@]}")
    collect_plugin_integrity_paths
    second_paths=("${SCODER_PLUGIN_UNIQUE_PATHS[@]}")
    if ! plugin_integrity_path_fingerprint "${second_paths[@]}"; then
        error "OpenCode plugin integrity changed after repeated validation"
        return 1
    fi
    second_fingerprint="${REPLY}"

    if [[ ${#first_paths[@]} -ne ${#second_paths[@]} || "${first_fingerprint}" != "${second_fingerprint}" ]]; then
        error "OpenCode plugin integrity changed between validation passes"
        return 1
    fi
    for ((index = 0; index < ${#first_paths[@]}; index++)); do
        if [[ "${first_paths[index]}" != "${second_paths[index]}" ]]; then
            error "OpenCode plugin watched paths changed between validation passes"
            return 1
        fi
    done

    if ! write_plugin_integrity_cache "${integrity_cache}" "${second_fingerprint}" "${second_paths[@]}"; then
        error "OpenCode plugin integrity changed while caching successful validation"
        rm -f -- "${integrity_cache}"
        return 1
    fi
}

is_opencode_subcommand() {
    case "$1" in
    completion | acp | mcp | attach | run | debug | providers | auth | agent | upgrade | uninstall | serve | web | models | stats | export | import | github | pr | session | plugin | plug | db)
        return 0
        ;;
    esac

    return 1
}

is_plugin_repair_command() {
    [[ ${#OPENCODE_ARGS[@]} -gt 0 ]] || return 1
    case "${OPENCODE_ARGS[0]}" in
    plugin | plug) return 0 ;;
    esac
    return 1
}

pass_env_if_set() {
    local env_name="$1"
    if [[ -n "${!env_name:-}" ]]; then
        BWRAP_CMD+=(--setenv "${env_name}" "${!env_name}")
    fi
}

should_inherit_env() {
    local env_name="$1"

    if [[ "${ALLOW_GUI:-0}" -eq 1 ]]; then
        case "${env_name}" in
        DISPLAY | WAYLAND_DISPLAY | XAUTHORITY | DBUS_SESSION_BUS_ADDRESS | SESSION_MANAGER)
            return 0
            ;;
        esac
    fi

    case "${env_name}" in
    HOME | PATH | PWD | OLDPWD | SHELL | SHLVL | _ | USER | LOGNAME | TERM | COLORTERM | LANG | LC_ALL | \
        EDITOR | VISUAL | GIT_OPTIONAL_LOCKS | SCODER_* | PLAYWRIGHT_BROWSERS_PATH | MISE_SKIP_ACTIVATE | \
        UV_LINK_MODE | PYENV_ROOT | RUSTUP_HOME | CARGO_HOME | GOPATH | GOBIN | PYO3_PYTHON)
        return 1
        ;;
    SSH_AUTH_SOCK | GPG_AGENT_INFO | DBUS_SESSION_BUS_ADDRESS | SESSION_MANAGER | XAUTHORITY | DISPLAY | WAYLAND_DISPLAY)
        return 1
        ;;
    esac

    return 0
}

inherit_host_environment() {
    local env_name
    local env_output

    env_output="$(compgen -e || true)"

    while IFS= read -r env_name; do
        if should_inherit_env "${env_name}"; then
            pass_env_if_set "${env_name}"
        fi
    done <<<"${env_output}"
}

normalize_raw_command_if_needed() {
    if [[ ${#RAW_COMMAND[@]} -lt 2 ]]; then
        return
    fi

    case "${RAW_COMMAND[0]}" in
    bash | /bin/bash)
        case "${RAW_COMMAND[1]}" in
        -c | -lc)
            RAW_COMMAND=("${RAW_COMMAND[0]}" --noprofile --norc "${RAW_COMMAND[1]}" "${RAW_COMMAND[@]:2}")
            ;;
        esac
        ;;
    esac
}

find_chromium_binary() {
    local candidate
    local -a candidates=()

    if [[ -n "${SCODER_CHROMIUM_BIN:-}" ]]; then
        candidates+=("${SCODER_CHROMIUM_BIN}")
    fi

    candidates+=(chromium google-chrome-stable google-chrome chrome)

    for candidate in "${candidates[@]}"; do
        if command -v "${candidate}" >/dev/null 2>&1; then
            printf '%s' "$(command -v "${candidate}")"
            return 0
        fi
    done

    return 1
}

is_devtools_endpoint_ready() {
    if command -v curl >/dev/null 2>&1; then
        curl --silent --show-error --fail "http://127.0.0.1:9222/json/version" >/dev/null 2>&1
        return $?
    fi

    if command -v python3 >/dev/null 2>&1; then
        python3 - <<'PY' >/dev/null 2>&1
import sys
import urllib.request

try:
    with urllib.request.urlopen("http://127.0.0.1:9222/json/version", timeout=1):
        pass
except Exception:
    sys.exit(1)

sys.exit(0)
PY
        return $?
    fi

    return 1
}

ensure_chromium_devtools() {
    local chromium_bin
    local chromium_profile
    local chromium_log

    if is_devtools_endpoint_ready; then
        info "Chromium DevTools already available on 127.0.0.1:9222"
        return 0
    fi

    chromium_bin="$(find_chromium_binary || true)"
    if [[ -z "${chromium_bin}" ]]; then
        error "web-developer mode could not find a Chromium-compatible browser"
        error "set SCODER_CHROMIUM_BIN or install chromium/google-chrome"
        return 1
    fi

    chromium_profile="${SCODER_CHROMIUM_PROFILE:-/tmp/opencode-chrome}"
    chromium_log="${SCODER_CHROMIUM_LOG:-/tmp/scoder-chromium.log}"
    mkdir -p "${chromium_profile}"

    info "Starting Chromium DevTools via ${chromium_bin}"
    nohup "${chromium_bin}" \
        --remote-debugging-port=9222 \
        --user-data-dir="${chromium_profile}" \
        --no-first-run \
        --no-default-browser-check \
        about:blank >"${chromium_log}" 2>&1 < /dev/null &

    local attempt
    for attempt in {1..20}; do
        if is_devtools_endpoint_ready; then
            info "Chromium DevTools ready on 127.0.0.1:9222"
            return 0
        fi
        sleep 0.5
    done

    error "Chromium launched but DevTools endpoint did not become ready"
    error "check log: ${chromium_log}"
    return 1
}

check_bwrap_namespace_support() {
    local probe_output

    if probe_output="$(bwrap --unshare-user-try --ro-bind /usr /usr --proc /proc --dev /dev -- /bin/sh -c 'exit 0' 2>&1)"; then
        return 0
    fi

    case "${probe_output}" in
    *"Creating new namespace failed"* | *"max_*_namespaces exceeded"* | *"(ENOSPC)"*)
        error "bubblewrap cannot create the namespaces scoder needs in this environment"
        error "this usually means scoder is running inside another sandbox/container, or user namespaces are restricted"
        error "run scoder from your normal host shell instead of inside another sandboxed session"
        return 1
        ;;
    esac

    return 0
}

is_path_within() {
    local parent_path="$1"
    local child_path="$2"

    [[ "${child_path}" == "${parent_path}" || "${child_path}" == "${parent_path}"/* ]]
}

resolve_target_mode() {
    local requested_target="$1"
    local resolved_target
    local resolved_pwd

    if [[ ! -e "${requested_target}" ]]; then
        error "target path does not exist: ${requested_target}"
        exit 1
    fi

    resolved_target="$(realpath "${requested_target}")"
    resolved_pwd="$(realpath "${PWD}")"

    if [[ -d "${resolved_target}" ]]; then
        TARGET_KIND="dir"
        TARGET_PATH="${resolved_target}"
        TARGET_PARENT_DIR="$(dirname "${resolved_target}")"
        VISIBLE_ROOT="${resolved_target}"
        return
    fi

    if [[ -f "${resolved_target}" ]]; then
        TARGET_KIND="file"
        TARGET_PATH="${resolved_target}"
        TARGET_FILE="${resolved_target}"
        TARGET_PARENT_DIR="$(dirname "${resolved_target}")"
        if is_path_within "${resolved_pwd}" "${resolved_target}"; then
            VISIBLE_ROOT="${resolved_pwd}"
        else
            VISIBLE_ROOT="${TARGET_PARENT_DIR}"
        fi
        return
    fi

    error "target must be a directory or regular file: ${requested_target}"
    exit 1
}

find_cargo_workspace_root() {
    local start_dir="$1"
    local manifest_path="${start_dir}/Cargo.toml"
    local workspace_manifest=""
    local current_dir

    if [[ ! -f "${manifest_path}" ]]; then
        return 1
    fi

    if command -v cargo >/dev/null 2>&1; then
        workspace_manifest="$(cargo locate-project --workspace --manifest-path "${manifest_path}" --message-format plain 2>/dev/null || true)"
        if [[ -n "${workspace_manifest}" && -f "${workspace_manifest}" ]]; then
            dirname "$(realpath "${workspace_manifest}")"
            return 0
        fi
    fi

    current_dir="${start_dir}"
    while [[ "${current_dir}" != "/" ]]; do
        if [[ -f "${current_dir}/Cargo.toml" ]] && grep -Eq '^[[:space:]]*\[workspace\]' "${current_dir}/Cargo.toml"; then
            realpath "${current_dir}"
            return 0
        fi
        current_dir="$(dirname "${current_dir}")"
    done

    return 1
}

common_ancestor_path() {
    local left="$1"
    local right="$2"

    left="$(realpath -m "${left}")"
    right="$(realpath -m "${right}")"

    while [[ "${right}" != "${left}" && "${right}" != "${left}"/* ]]; do
        if [[ "${left}" == "/" ]]; then
            printf '/\n'
            return 0
        fi
        left="$(dirname "${left}")"
    done

    printf '%s\n' "${left}"
}

find_cargo_path_dependency_root() {
    local start_dir="$1"
    local manifest_path="${start_dir}/Cargo.toml"
    local dependency_root="${start_dir}"
    local line
    local dependency_path
    local dependency_dir

    if [[ ! -f "${manifest_path}" ]]; then
        return 1
    fi

    while IFS= read -r line; do
        if [[ "${line}" =~ path[[:space:]]*=[[:space:]]*\"([^\"]+)\" ]]; then
            dependency_path="${BASH_REMATCH[1]}"
        elif [[ "${line}" =~ path[[:space:]]*=[[:space:]]*\'([^\']+)\' ]]; then
            dependency_path="${BASH_REMATCH[1]}"
        else
            continue
        fi

        case "${dependency_path}" in
        /*)
            dependency_dir="$(realpath -m "${dependency_path}")"
            ;;
        *)
            dependency_dir="$(realpath -m "${start_dir}/${dependency_path}")"
            ;;
        esac

        dependency_root="$(common_ancestor_path "${dependency_root}" "${dependency_dir}")"
    done <"${manifest_path}"

    if [[ "${dependency_root}" != "${start_dir}" ]]; then
        printf '%s\n' "${dependency_root}"
        return 0
    fi

    return 1
}

cargo_workspace_expand_target() {
    local workspace_root=""
    local located_workspace_root=""

    if [[ "${TARGET_KIND}" != "dir" || ! -f "${TARGET_PATH}/Cargo.toml" ]]; then
        return 0
    fi

    located_workspace_root="$(find_cargo_workspace_root "${TARGET_PATH}" || true)"
    workspace_root="${located_workspace_root}"

    # `cargo locate-project --workspace` returns the package itself for
    # standalone packages and for some package-in-larger-tree layouts. Treat a
    # self-root as "no broader root found" so local path/workspace dependency
    # fallbacks still get a chance to expose sibling crates.
    if [[ "${workspace_root}" == "${TARGET_PATH}" ]]; then
        workspace_root=""
    fi

    if [[ -z "${workspace_root}" ]]; then
        workspace_root="$(find_cargo_path_dependency_root "${TARGET_PATH}" || true)"
    fi

    # Last-resort Cargo package heuristic for workspace dependency tables (for
    # example `foo = { workspace = true }`) where the target manifest may not
    # contain a literal sibling `path = "..."`, but Cargo still resolves to a
    # sibling package from surrounding workspace metadata.
    if [[ -z "${workspace_root}" ]] && grep -Eq 'workspace[[:space:]]*=[[:space:]]*true' "${TARGET_PATH}/Cargo.toml"; then
        workspace_root="${TARGET_PARENT_DIR}"
    fi

    if [[ -z "${workspace_root}" || "${workspace_root}" == "${TARGET_PATH}" ]]; then
        return 0
    fi

    if ! is_path_within "${workspace_root}" "${TARGET_PATH}"; then
        return 0
    fi

    PROJECT_DIR="${workspace_root}"
    SANDBOX_PROJECT_ROOT="${workspace_root}"
    SANDBOX_WORKDIR="${TARGET_PATH}"
    info "Detected Cargo workspace root: ${workspace_root}"
}

cleanup_file_mode_tmp_dir() {
    if [[ -n "${FILE_MODE_TMP_DIR:-}" && -d "${FILE_MODE_TMP_DIR}" ]]; then
        rm -rf "${FILE_MODE_TMP_DIR}"
    fi
}

add_custom_bind() {
    local bind_flag="$1"
    local requested_path="$2"
    local resolved_path

    if [[ ! -e "${requested_path}" ]]; then
        error "added path does not exist: ${requested_path}"
        exit 1
    fi

    resolved_path="$(realpath "${requested_path}")"
    add_parent_dirs_once "$(dirname "${resolved_path}")"
    SAFE_BINDS+=("${bind_flag}" "${resolved_path}" "${resolved_path}")
}

prepare_single_file_overlay() {
    local entry
    local target_parent_container
    local target_name
    local had_dotglob=0
    local had_nullglob=0

    target_name="$(basename "${TARGET_FILE}")"
    FILE_MODE_TMP_DIR="$(mktemp -d /tmp/scoder-filemode-XXXXXX)"
    FILE_MODE_PARENT_DIR="${FILE_MODE_TMP_DIR}/parent"
    FILE_MODE_TARGET_PATH="${FILE_MODE_PARENT_DIR}/${target_name}"
    FILE_MODE_RO_SOURCE_SANDBOX_PATH="/tmp/.scoder-ro-parent-$$"

    mkdir -p "${FILE_MODE_PARENT_DIR}"
    cp -p "${TARGET_FILE}" "${FILE_MODE_TARGET_PATH}"

    shopt -q dotglob && had_dotglob=1
    shopt -q nullglob && had_nullglob=1
    shopt -s dotglob nullglob
    for entry in "${TARGET_PARENT_DIR}"/*; do
        if [[ "$(basename "${entry}")" == "${target_name}" ]]; then
            continue
        fi
        ln -s "${FILE_MODE_RO_SOURCE_SANDBOX_PATH}/$(basename "${entry}")" "${FILE_MODE_PARENT_DIR}/$(basename "${entry}")"
    done
    ((had_dotglob)) || shopt -u dotglob
    ((had_nullglob)) || shopt -u nullglob

    add_parent_dirs_once "${TARGET_PARENT_DIR}"
    add_parent_dirs_once "${FILE_MODE_RO_SOURCE_SANDBOX_PATH}"
    FILE_MODE_BINDS=(--ro-bind "${TARGET_PARENT_DIR}" "${FILE_MODE_RO_SOURCE_SANDBOX_PATH}")

    target_parent_container="$(dirname "${TARGET_PARENT_DIR}")"
    if [[ "${target_parent_container}" != "/" ]]; then
        FILE_MODE_BINDS+=(--ro-bind "${target_parent_container}" "${target_parent_container}")
    fi

    FILE_MODE_BINDS+=(--bind "${FILE_MODE_PARENT_DIR}" "${TARGET_PARENT_DIR}")
}

sync_single_file_target_back() {
    local overlay_target_path

    overlay_target_path="${FILE_MODE_PARENT_DIR}/$(basename "${TARGET_FILE}")"
    if [[ ! -f "${overlay_target_path}" ]]; then
        error "single-file target disappeared during sandbox session: ${TARGET_FILE}"
        return 1
    fi

    cp -p "${overlay_target_path}" "${TARGET_FILE}"
}

run_validation() {
    local script_path="$0"
    local test_project="/tmp/scoder-validation-$$"
    local target_file_path
    local sibling_file_path
    local failed_tests=0
    local cmd_status
    local selected_opencode_bin

    info "=== Running scoder comprehensive validation tests ==="

    selected_opencode_bin="${OPENCODE_BIN:-${OPENCODE_BIN_DEFAULT}}"

    info "Test 0.1: bwrap availability"
    if command -v bwrap >/dev/null 2>&1; then
        echo "✅ Test 0.1 PASS: bwrap found at $(command -v bwrap)"
    else
        echo "❌ Test 0.1 FAIL: bwrap not found"
        ((failed_tests++))
    fi

    info "Test 0.2: opencode binary availability"
    if command -v "${selected_opencode_bin}" >/dev/null 2>&1; then
        echo "✅ Test 0.2 PASS: opencode binary found at $(command -v "${selected_opencode_bin}")"
    else
        echo "❌ Test 0.2 FAIL: opencode binary not found: ${selected_opencode_bin}"
        ((failed_tests++))
    fi

    # Setup test project
    mkdir -p "${test_project}"/{.git,node_modules,.venv/bin}
    mkdir -p "${test_project}/src/lib"
    echo "test content" >"${test_project}/test.py"
    echo "SCODER_VALIDATION=1" >"${test_project}/.env"
    echo '#!/bin/bash' >"${test_project}/.venv/bin/python"
    printf 'alpha\n' >"${test_project}/src/lib/target.txt"
    printf 'beta\n' >"${test_project}/src/lib/sibling.txt"
    chmod +x "${test_project}/.venv/bin/python"
    target_file_path="${test_project}/src/lib/target.txt"
    sibling_file_path="${test_project}/src/lib/sibling.txt"

    # Test A.1: HOME isolation
    echo ""
    info "Test A.1: HOME isolation"
    local home_result
    home_result=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc "printf '%s' \"\$HOME\"" || true)
    if [[ "${home_result}" == "${HOME}" ]]; then
        echo "✅ Test A.1 PASS: HOME mirrors host home path"
    else
        echo "❌ Test A.1 FAIL: HOME is ${home_result} (expected ${HOME})"
        ((failed_tests++))
    fi

    # Test A.1b: EDITOR default
    info "Test A.1b: EDITOR default"
    local editor_result
    editor_result=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc "printf '%s' \"\$EDITOR\"" || true)
    if [[ "${editor_result}" == "v_quickedit_hover" ]]; then
        echo "✅ Test A.1b PASS: EDITOR defaults to v_quickedit_hover"
    else
        echo "❌ Test A.1b FAIL: EDITOR is ${editor_result} (expected v_quickedit_hover)"
        ((failed_tests++))
    fi

    # Test A.1c: NVIM/XDG runtime propagation and socket visibility
    if [[ -n "${NVIM:-}" && -S "${NVIM}" ]]; then
        info "Test A.1c: active Neovim socket bridge"
        local nvim_result
        nvim_result=$(OPENCODE_BIN=/bin/bash NVIM="${NVIM}" XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc "printf '%s' \"\$NVIM\"" || true)
        if [[ "${nvim_result}" == "${NVIM}" ]]; then
            echo "✅ Test A.1c PASS: NVIM propagated into sandbox"
        else
            echo "❌ Test A.1c FAIL: NVIM is ${nvim_result} (expected ${NVIM})"
            ((failed_tests++))
        fi

        local nvim_socket_test
        nvim_socket_test=$(OPENCODE_BIN=/bin/bash NVIM="${NVIM}" XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'test -S "$NVIM" && printf SOCKET_OK' || true)
        if [[ "${nvim_socket_test}" == "SOCKET_OK" ]]; then
            echo "✅ Test A.1c PASS: active Neovim socket is visible"
        else
            echo "❌ Test A.1c FAIL: active Neovim socket not visible"
            ((failed_tests++))
        fi

        if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
            local xdg_runtime_result
            xdg_runtime_result=$(OPENCODE_BIN=/bin/bash NVIM="${NVIM}" XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR}" "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc "printf '%s' \"\$XDG_RUNTIME_DIR\"" || true)
            if [[ "${xdg_runtime_result}" == "${XDG_RUNTIME_DIR}" ]]; then
                echo "✅ Test A.1c PASS: XDG runtime dir propagated"
            else
                echo "❌ Test A.1c FAIL: XDG runtime dir is ${xdg_runtime_result} (expected ${XDG_RUNTIME_DIR})"
                ((failed_tests++))
            fi
        fi
    else
        echo "ℹ️  Test A.1c SKIP: No active NVIM socket in host environment"
    fi

    # Test A.2: bashrc write isolation (no leak to host)
    info "Test A.2: ~/.bashrc write isolation"
    local host_bashrc="${HOME}/.bashrc"
    OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'echo "SCODER_TEST" > ~/.bashrc' >/dev/null 2>&1 || true
    local leaked=0
    if [[ -f "${host_bashrc}" ]]; then
        if grep -q "SCODER_TEST" "${host_bashrc}" 2>/dev/null; then
            leaked=1
        fi
    fi
    if [[ "${leaked}" -eq 0 ]]; then
        echo "✅ Test A.2 PASS: ~/.bashrc writes do not leak to host"
    else
        echo "❌ Test A.2 FAIL: ~/.bashrc writes leaked to host"
        ((failed_tests++))
    fi

    # Test A.3: System file write protection
    info "Test A.3: System file write protection"
    local sys_write
    sys_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'touch /usr/bin/scoder-test 2>&1' 2>&1 || true)
    if echo "${sys_write}" | grep -qE "Read-only|Permission denied|cannot touch"; then
        echo "✅ Test A.3 PASS: System files are read-only"
    else
        echo "❌ Test A.3 FAIL: System files are writable"
        ((failed_tests++))
    fi

    # Test B.1: Workspace is writable
    info "Test B.1: Workspace writability"
    local workspace_write
    workspace_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'touch new_file.py && echo SUCCESS' 2>&1 || true)
    if echo "${workspace_write}" | grep -q "SUCCESS"; then
        echo "✅ Test B.1 PASS: Workspace is writable"
    else
        echo "❌ Test B.1 FAIL: Cannot write to workspace"
        ((failed_tests++))
    fi

    # Test B.2: .git writability for scoder-git managed commits
    info "Test B.2: .git directory writability"
    local git_write
    git_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'touch .git/test && echo SUCCESS' 2>&1 || true)
    if echo "${git_write}" | grep -q "SUCCESS"; then
        echo "✅ Test B.2 PASS: .git is writable for managed git operations"
    else
        echo "❌ Test B.2 FAIL: .git is not writable (${git_write})"
        ((failed_tests++))
    fi

    # Test B.3: node_modules writability
    info "Test B.3: node_modules directory writability"
    local nm_write
    nm_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'touch node_modules/test && echo SUCCESS' 2>&1 || true)
    if echo "${nm_write}" | grep -q "SUCCESS"; then
        echo "✅ Test B.3 PASS: node_modules is writable"
    else
        echo "❌ Test B.3 FAIL: node_modules is not writable"
        ((failed_tests++))
    fi

    # Test B.4: --allow-git remains accepted for compatibility
    info "Test B.4: --allow-git compatibility"
    if OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q --allow-git -x /bin/bash --noprofile --norc -lc 'true' >/dev/null 2>&1; then
        echo "✅ Test B.4 PASS: --allow-git is still accepted"
    else
        echo "❌ Test B.4 FAIL: --allow-git compatibility failed"
        ((failed_tests++))
    fi

    # Test B.5: project .env visibility
    info "Test B.5: project .env visibility"
    local env_visible
    env_visible=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'test -e .env && echo SUCCESS' 2>&1 || true)
    if echo "${env_visible}" | grep -q "SUCCESS"; then
        echo "✅ Test B.5 PASS: project .env is visible"
    else
        echo "❌ Test B.5 FAIL: project .env is not visible"
        ((failed_tests++))
    fi

    # Test B.6: --ro must not mutate project-local mise state
    info "Test B.6: --ro blocks project-local mise state writes"
    rm -rf "${test_project}/.local"
    OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q --ro -x /bin/bash --noprofile --norc -lc 'test ! -w . && echo RO' >/dev/null 2>&1 || true
    if [[ ! -e "${test_project}/.local/state/mise" ]]; then
        echo "✅ Test B.6 PASS: --ro does not create project-local mise state"
    else
        echo "❌ Test B.6 FAIL: --ro created project-local mise state"
        ((failed_tests++))
    fi

    # Test B.7: raw command execution after --
    info "Test B.7: raw command execution after --"
    local raw_command_test
    raw_command_test=$("${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'printf RAW_OK' || true)
    if [[ "${raw_command_test}" == "RAW_OK" ]]; then
        echo "✅ Test B.7 PASS: raw commands execute inside sandbox"
    else
        echo "❌ Test B.7 FAIL: raw command output was '${raw_command_test}'"
        ((failed_tests++))
    fi

    # Test C: Config bind (if opencode.json exists)
    if [[ -f "${OPENCODE_DEFAULT_CONFIG}" ]]; then
        info "Test C: Config bind verification"
        local config_read
        config_read=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'cat ~/.config/opencode/opencode.json' || true)
        local expected_content
        expected_content=$(cat "${OPENCODE_DEFAULT_CONFIG}" 2>/dev/null || echo "")
        if [[ "${config_read}" == "${expected_content}" ]]; then
            echo "✅ Test C PASS: Config bind works (opencode.json visible)"
        else
            echo "❌ Test C FAIL: Config bind mismatch"
            ((failed_tests++))
        fi
    else
        echo "ℹ️  Test C SKIP: No opencode.json found (${OPENCODE_DEFAULT_CONFIG})"
    fi

    # Test C.1: Symlinked config file target visibility
    info "Test C.1: Symlinked config file target visibility"
    local symlink_home="${test_project}/host-home"
    local symlink_target_dir="${test_project}/config-target"
    local symlink_expected='{"scoder":"symlink-config"}'
    mkdir -p "${symlink_home}/.config/opencode" "${symlink_target_dir}"
    printf '%s\n' "${symlink_expected}" >"${symlink_target_dir}/opencode.json"
    ln -s "${symlink_target_dir}/opencode.json" "${symlink_home}/.config/opencode/opencode.json"
    local symlink_config_read
    symlink_config_read=$(HOME="${symlink_home}" OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'cat ~/.config/opencode/opencode.json' || true)
    if [[ "${symlink_config_read}" == "${symlink_expected}" ]]; then
        echo "✅ Test C.1 PASS: Symlinked opencode.json target is visible"
    else
        echo "❌ Test C.1 FAIL: Symlinked opencode.json target is not visible"
        ((failed_tests++))
    fi

    # Test D: Tooling PATH
    info "Test D: .venv in PATH"
    local venv_path
    venv_path=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc "echo \"\$PATH\"" 2>&1 || true)
    if echo "${venv_path}" | grep -q ".venv/bin"; then
        echo "✅ Test D PASS: .venv/bin is in PATH"
    else
        echo "❌ Test D FAIL: .venv/bin not in PATH"
        ((failed_tests++))
    fi

    # Test E: DNS resolver configuration
    info "Test E: DNS resolver configuration"
    local dns_test
    dns_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'grep -q "^nameserver " /etc/resolv.conf && echo SUCCESS' 2>&1 || true)
    if echo "${dns_test}" | grep -q "SUCCESS"; then
        echo "✅ Test E PASS: DNS resolver config is available"
    else
        echo "❌ Test E FAIL: DNS resolver config unavailable"
        ((failed_tests++))
    fi

    info "Test E.1: DNS lookup works inside sandbox"
    local dns_lookup_test
    dns_lookup_test=$(timeout 10s env OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'getent hosts api.openai.com >/dev/null && echo SUCCESS' 2>&1 || true)
    if echo "${dns_lookup_test}" | grep -q "SUCCESS"; then
        echo "✅ Test E.1 PASS: DNS lookup works inside sandbox"
    else
        echo "❌ Test E.1 FAIL: DNS lookup timed out or failed (${dns_lookup_test})"
        ((failed_tests++))
    fi

    info "Test E.2: HTTPS connectivity works inside sandbox"
    local https_test
    https_test=$(timeout 10s env OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'curl --max-time 10 -I -sS https://api.openai.com 2>&1 | grep -m1 -E "^HTTP/"' 2>&1 || true)
    if echo "${https_test}" | grep -qE "^HTTP/"; then
        echo "✅ Test E.2 PASS: HTTPS connectivity works inside sandbox (${https_test})"
    else
        echo "❌ Test E.2 FAIL: HTTPS connectivity timed out or failed (${https_test})"
        ((failed_tests++))
    fi

    # Test F: OpenCode writable runtime state
    info "Test F: OpenCode writable runtime state"
    local oc_state_test
    oc_state_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'test -w "$HOME/.config/opencode" && test -w "$HOME/.cache/opencode" && test -w "$HOME/.local/share/opencode" && test -w "$HOME/.opencode" && test -w "$HOME/.agents" && echo SUCCESS' 2>&1 || true)
    if echo "${oc_state_test}" | grep -q "SUCCESS"; then
        echo "✅ Test F PASS: OpenCode runtime paths are writable"
    else
        echo "❌ Test F FAIL: OpenCode runtime paths are not writable"
        ((failed_tests++))
    fi

    # Test G: Bun writable runtime state
    info "Test G: Bun writable runtime state"
    local bun_state_test
    bun_state_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'test -w "$HOME/.bun" && test -w "$HOME/.cache/bun" && echo SUCCESS' 2>&1 || true)
    if echo "${bun_state_test}" | grep -q "SUCCESS"; then
        echo "✅ Test G PASS: Bun runtime paths are writable"
    else
        echo "❌ Test G FAIL: Bun runtime paths are not writable"
        ((failed_tests++))
    fi

    # Test H: TUI environment essentials
    info "Test H: TUI environment essentials"
    local tui_env_test
    tui_env_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc "test -n \"\$TERM\" && test -n \"\$LANG\" && test -n \"\$SHELL\" && test \"\$GIT_OPTIONAL_LOCKS\" = \"0\" && echo SUCCESS" 2>&1 || true)
    if echo "${tui_env_test}" | grep -q "SUCCESS"; then
        echo "✅ Test H PASS: TUI environment variables are present"
    else
        echo "❌ Test H FAIL: Missing required TUI environment variables"
        ((failed_tests++))
    fi

    # Test I: project path preserved inside sandbox
    info "Test I: project path preserved"
    local project_path_test
    project_path_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'pwd' || true)
    if [[ "${project_path_test}" == "${test_project}" ]]; then
        echo "✅ Test I PASS: project path preserved"
    else
        echo "❌ Test I FAIL: project path changed to ${project_path_test}"
        ((failed_tests++))
    fi

    # Test L.1: single-file mode keeps sibling files visible
    info "Test L.1: single-file mode keeps workspace visible"
    local file_mode_read
    file_mode_read=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${target_file_path}" -q -x /bin/bash --noprofile --norc -lc "cat '${sibling_file_path}'" 2>&1 || true)
    if [[ "${file_mode_read}" == "beta" ]]; then
        echo "✅ Test L.1 PASS: sibling files remain readable in file mode"
    else
        echo "❌ Test L.1 FAIL: sibling read output was '${file_mode_read}'"
        ((failed_tests++))
    fi

    # Test L.2: single-file mode allows target writes
    info "Test L.2: single-file mode allows target writes"
    local file_mode_target_write
    file_mode_target_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${target_file_path}" -q -x /bin/bash --noprofile --norc -lc "printf updated > '${target_file_path}' && cat '${target_file_path}'" 2>&1 || true)
    if [[ "${file_mode_target_write}" == "updated" ]]; then
        echo "✅ Test L.2 PASS: target file is writable"
    else
        echo "❌ Test L.2 FAIL: target write output was '${file_mode_target_write}'"
        ((failed_tests++))
    fi

    # Test L.3: single-file mode blocks sibling writes
    info "Test L.3: single-file mode blocks sibling writes"
    local file_mode_sibling_write
    file_mode_sibling_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${target_file_path}" -q -x /bin/bash --noprofile --norc -lc "printf nope > '${sibling_file_path}'" 2>&1 || true)
    if echo "${file_mode_sibling_write}" | grep -qE 'Read-only|Permission denied|cannot create|Operation not permitted'; then
        echo "✅ Test L.3 PASS: sibling files are protected"
    else
        echo "❌ Test L.3 FAIL: sibling write output was '${file_mode_sibling_write}'"
        ((failed_tests++))
    fi

    # Test L.4: single-file mode supports rename-over-target saves
    info "Test L.4: single-file mode supports atomic save"
    local file_mode_atomic_save
    file_mode_atomic_save=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${target_file_path}" -q -x /bin/bash --noprofile --norc -lc "printf swapped > '${test_project}/src/lib/.target.txt.tmp' && mv '${test_project}/src/lib/.target.txt.tmp' '${target_file_path}' && cat '${target_file_path}'" 2>&1 || true)
    if [[ "${file_mode_atomic_save}" == "swapped" ]]; then
        echo "✅ Test L.4 PASS: rename-over-target save works"
    else
        echo "❌ Test L.4 FAIL: atomic save output was '${file_mode_atomic_save}'"
        ((failed_tests++))
    fi

    # Test L.5: single-file mode blocks unrelated nested file creation
    info "Test L.5: single-file mode blocks unrelated nested file creation"
    local file_mode_nested_write
    file_mode_nested_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${target_file_path}" -q -x /bin/bash --noprofile --norc -lc "mkdir -p '${test_project}/src/other' && printf bad > '${test_project}/src/other/new.txt'" 2>&1 || true)
    if echo "${file_mode_nested_write}" | grep -qE 'Read-only|Permission denied|cannot create|Operation not permitted'; then
        echo "✅ Test L.5 PASS: unrelated nested writes are blocked"
    else
        echo "❌ Test L.5 FAIL: nested write output was '${file_mode_nested_write}'"
        ((failed_tests++))
    fi

    # Test L.6: --ro keeps the target file read-only in file mode
    info "Test L.6: --ro keeps target read-only in file mode"
    local file_mode_ro_write
    file_mode_ro_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${target_file_path}" -q --ro -x /bin/bash --noprofile --norc -lc "printf blocked > '${target_file_path}'" 2>&1 || true)
    if echo "${file_mode_ro_write}" | grep -qE 'Read-only|Permission denied|cannot create|Operation not permitted'; then
        echo "✅ Test L.6 PASS: --ro blocks target writes in file mode"
    else
        echo "❌ Test L.6 FAIL: --ro write output was '${file_mode_ro_write}'"
        ((failed_tests++))
    fi

    # Test J: browser plugin state bind
    if [[ -d "${HOME}/.opencode-browser" ]]; then
        info "Test J: browser plugin state bind"
        local browser_state_test
        browser_state_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'test -w "$HOME/.opencode-browser" && echo SUCCESS' 2>&1 || true)
        if echo "${browser_state_test}" | grep -q "SUCCESS"; then
            echo "✅ Test J PASS: browser plugin state is writable"
        else
            echo "❌ Test J FAIL: browser plugin state is not writable"
            ((failed_tests++))
        fi
    else
        echo "ℹ️  Test J SKIP: ~/.opencode-browser not present on host"
    fi

    # Test K: tool launcher status
    info "Test K: host tool and launcher status"
    for cmd_status in node npm npx bun uv uvx; do
        if command -v "${cmd_status}" >/dev/null 2>&1; then
            echo "✅ ${cmd_status}: $(command -v "${cmd_status}")"
        else
            echo "ℹ️  ${cmd_status}: unavailable on host"
        fi
    done

    if command -v npx >/dev/null 2>&1; then
        echo "✅ context7 launcher: npx available"
    else
        echo "❌ context7 launcher: npx unavailable"
        ((failed_tests++))
    fi

    if command -v uvx >/dev/null 2>&1; then
        echo "✅ fetch launcher: uvx available"
    else
        echo "❌ fetch launcher: uvx unavailable"
        ((failed_tests++))
    fi

    # Test M: scoder-git shadowing and safety policy
    info "Test M.1: /usr/bin/git is shadowed by scoder-git"
    local sandbox_git_identity
    sandbox_git_identity=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'readlink /usr/bin/git 2>/dev/null || /usr/bin/git --scoder-git-version 2>/dev/null' 2>&1 || true)
    if echo "${sandbox_git_identity}" | grep -q "scoder-git"; then
        echo "✅ Test M.1 PASS: /usr/bin/git is shadowed by scoder-git"
    else
        echo "❌ Test M.1 FAIL: /usr/bin/git is not shadowed (${sandbox_git_identity})"
        ((failed_tests++))
    fi

    info "Test M.2: scoder-git blocks network/destructive commands"
    local git_push_result
    git_push_result=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'git push 2>&1' 2>&1 || true)
    if echo "${git_push_result}" | grep -q "fatal: scoder blocked git push"; then
        echo "✅ Test M.2 PASS: git push is denied"
    else
        echo "❌ Test M.2 FAIL: git push was not denied by scoder-git (${git_push_result})"
        ((failed_tests++))
    fi

    info "Test M.3: scoder-git allows normal commits when --allow-git is set"
    git -C "${test_project}" init -q
    git -C "${test_project}" config user.email scoder-validation@example.invalid
    git -C "${test_project}" config user.name 'scoder validation'
    local git_commit_result
    git_commit_result=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q --allow-git -x /bin/bash --noprofile --norc -lc 'printf commit-ok > committed.txt && git add committed.txt && git commit -m "validation commit" >/dev/null && git log --oneline -1' 2>&1 || true)
    if echo "${git_commit_result}" | grep -q "validation commit"; then
        echo "✅ Test M.3 PASS: git add/commit works with --allow-git"
    else
        echo "❌ Test M.3 FAIL: git add/commit failed (${git_commit_result})"
        ((failed_tests++))
    fi

    info "Test M.4: scoder-git allows safe local branch switching"
    git -C "${test_project}" branch validation-switch-target >/dev/null 2>&1 || true
    local git_switch_result
    git_switch_result=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'git switch --quiet validation-switch-target >/dev/null && git branch --show-current' 2>&1 || true)
    if [[ "${git_switch_result}" == "validation-switch-target" ]]; then
        echo "✅ Test M.4 PASS: git switch existing branch works"
    else
        echo "❌ Test M.4 FAIL: git switch existing branch failed (${git_switch_result})"
        ((failed_tests++))
    fi

    info "Test M.5: scoder-git allows safe local branch creation"
    local git_switch_create_result
    git_switch_create_result=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'git switch --quiet -c validation-switch-created >/dev/null && git branch --show-current' 2>&1 || true)
    if [[ "${git_switch_create_result}" == "validation-switch-created" ]]; then
        echo "✅ Test M.5 PASS: git switch -c creates and switches branches"
    else
        echo "❌ Test M.5 FAIL: git switch -c failed (${git_switch_create_result})"
        ((failed_tests++))
    fi

    info "Test M.6: scoder-git blocks unsafe git switch flags"
    local git_switch_force_result
    git_switch_force_result=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'git switch --force validation-switch-target 2>&1' 2>&1 || true)
    if echo "${git_switch_force_result}" | grep -q "git switch unsafe option: --force"; then
        echo "✅ Test M.6 PASS: git switch --force is denied"
    else
        echo "❌ Test M.6 FAIL: git switch --force was not denied (${git_switch_force_result})"
        ((failed_tests++))
    fi

    info "Test M.7: scoder-git keeps destructive reset blocked"
    local git_reset_hard_result
    git_reset_hard_result=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -x /bin/bash --noprofile --norc -lc 'git reset --hard HEAD 2>&1' 2>&1 || true)
    if echo "${git_reset_hard_result}" | grep -q "fatal: scoder blocked git reset"; then
        echo "✅ Test M.7 PASS: git reset --hard remains denied"
    else
        echo "❌ Test M.7 FAIL: git reset --hard was not denied (${git_reset_hard_result})"
        ((failed_tests++))
    fi

    info "Test N.1: --add exposes extra path read-only"
    local shared_ro_dir="/tmp/scoder-shared-ro-$$"
    mkdir -p "${shared_ro_dir}"
    printf 'shared-ro\n' >"${shared_ro_dir}/note.txt"
    local add_ro_read
    add_ro_read=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -a "${shared_ro_dir}" -x /bin/bash --noprofile --norc -lc "cat '${shared_ro_dir}/note.txt'" 2>&1 || true)
    if [[ "${add_ro_read}" == "shared-ro" ]]; then
        echo "✅ Test N.1 PASS: --add exposes extra path"
    else
        echo "❌ Test N.1 FAIL: extra path read output was '${add_ro_read}'"
        ((failed_tests++))
    fi

    info "Test N.2: --add keeps extra path read-only"
    local add_ro_write
    add_ro_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -a "${shared_ro_dir}" -x /bin/bash --noprofile --norc -lc "printf blocked > '${shared_ro_dir}/note.txt'" 2>&1 || true)
    if echo "${add_ro_write}" | grep -qE 'Read-only|Permission denied|cannot create|Operation not permitted'; then
        echo "✅ Test N.2 PASS: --add blocks writes"
    else
        echo "❌ Test N.2 FAIL: extra path write output was '${add_ro_write}'"
        ((failed_tests++))
    fi

    info "Test N.3: --add-rw exposes extra path read-write"
    local shared_rw_dir="/tmp/scoder-shared-rw-$$"
    mkdir -p "${shared_rw_dir}"
    printf 'shared-rw\n' >"${shared_rw_dir}/note.txt"
    local add_rw_write
    add_rw_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -- "${test_project}" -q -A "${shared_rw_dir}" -x /bin/bash --noprofile --norc -lc "printf updated > '${shared_rw_dir}/note.txt' && cat '${shared_rw_dir}/note.txt'" 2>&1 || true)
    if [[ "${add_rw_write}" == "updated" ]]; then
        echo "✅ Test N.3 PASS: --add-rw allows writes"
    else
        echo "❌ Test N.3 FAIL: extra path rw output was '${add_rw_write}'"
        ((failed_tests++))
    fi

    info "Test O: OpenCode plugin preflight"
    local plugin_home="${test_project}/plugin home"
    local plugin_config_dir="${plugin_home}/.config/opencode"
    local plugin_cache_root="${plugin_home}/.cache/opencode/packages"
    local plugin_config="${plugin_config_dir}/opencode.json"
    local valid_wrapper="${plugin_cache_root}/valid-plugin@latest"
    local valid_package="${valid_wrapper}/node_modules/valid-plugin"
    local plugin_result
    local plugin_status

    capture_plugin_check() {
        local config_path="$1"
        local cache_root="$2"
        local jq_override="${3:-}"

        if [[ -n "${jq_override}" ]]; then
            if plugin_result="$(SCODER_JQ_BIN="${jq_override}" check_opencode_plugins "${config_path}" "${cache_root}" 2>&1)"; then
                plugin_status=0
            else
                plugin_status=$?
            fi
        elif plugin_result="$(check_opencode_plugins "${config_path}" "${cache_root}" 2>&1)"; then
            plugin_status=0
        else
            plugin_status=$?
        fi
    }

    mkdir -p "${plugin_config_dir}" "${valid_package}/dist"
    printf '%s\n' '{"plugin":[["valid-plugin",{"enabled":true}]]}' >"${plugin_config}"
    printf '%s\n' '{"dependencies":{"valid-plugin":"1.0.0"}}' >"${valid_wrapper}/package.json"
    printf '%s\n' '{"name":"valid-plugin","main":"dist/index.js"}' >"${valid_package}/package.json"
    printf '%s\n' 'export default {};' >"${valid_package}/dist/index.js"

    if check_opencode_plugins "${plugin_config}" "${plugin_cache_root}" >/dev/null 2>&1; then
        echo "PASS Test O.1: valid external plugin tuple accepted"
    else
        echo "FAIL Test O.1: valid external plugin tuple rejected"
        failed_tests=$((failed_tests + 1))
    fi

    printf '%s\n' '{"plugin":["missing-plugin"]}' >"${plugin_config}"
    capture_plugin_check "${plugin_config}" "${plugin_cache_root}"
    if [[ ${plugin_status} -ne 0 ]] &&
        grep -q "missing-plugin.*cache wrapper is missing" <<<"${plugin_result}" &&
        grep -q "opencode plugin --global --force missing-plugin" <<<"${plugin_result}"; then
        echo "PASS Test O.2: missing wrapper reports repair"
    else
        echo "FAIL Test O.2: missing wrapper diagnostic was '${plugin_result}'"
        failed_tests=$((failed_tests + 1))
    fi

    mkdir -p "${plugin_cache_root}/orphan-plugin@latest"
    printf '%s\n' '{"dependencies":{"orphan-plugin":"1.0.0"}}' >"${plugin_cache_root}/orphan-plugin@latest/package.json"
    printf '%s\n' '{"plugin":["orphan-plugin"]}' >"${plugin_config}"
    capture_plugin_check "${plugin_config}" "${plugin_cache_root}"
    if [[ ${plugin_status} -ne 0 ]] && grep -q "orphan-plugin.*installed package is missing" <<<"${plugin_result}"; then
        echo "PASS Test O.3: missing dependency rejected"
    else
        echo "FAIL Test O.3: missing dependency diagnostic was '${plugin_result}'"
        failed_tests=$((failed_tests + 1))
    fi

    mkdir -p "${plugin_cache_root}/broken-plugin@latest/node_modules/broken-plugin"
    printf '%s\n' '{"dependencies":{"broken-plugin":"1.0.0"}}' >"${plugin_cache_root}/broken-plugin@latest/package.json"
    printf '%s\n' '{"name":"broken-plugin","main":"dist/missing.js"}' >"${plugin_cache_root}/broken-plugin@latest/node_modules/broken-plugin/package.json"
    printf '%s\n' '{"plugin":["broken-plugin"]}' >"${plugin_config}"
    capture_plugin_check "${plugin_config}" "${plugin_cache_root}"
    if [[ ${plugin_status} -ne 0 ]] && grep -q "broken-plugin.*entry point is missing" <<<"${plugin_result}"; then
        echo "PASS Test O.4: missing entry point rejected"
    else
        echo "FAIL Test O.4: missing entry diagnostic was '${plugin_result}'"
        failed_tests=$((failed_tests + 1))
    fi

    mkdir -p "${plugin_home}/plugins"
    printf '%s\n' 'export default {};' >"${plugin_home}/plugins/local.js"
    printf '{"plugin":[%s]}\n' "$(printf '%s' "${plugin_home}/plugins/local.js" | jq -Rsa .)" >"${plugin_config}"
    if check_opencode_plugins "${plugin_config}" "${plugin_cache_root}" >/dev/null 2>&1; then
        echo "PASS Test O.5: valid local file accepted"
    else
        echo "FAIL Test O.5: valid local file rejected"
        failed_tests=$((failed_tests + 1))
    fi

    mkdir -p "${plugin_config_dir}/plugins/local-package/dist"
