#!/usr/bin/env bash

# scoder - Safe wrapper for OpenCode using bubblewrap
# Homepage: https://github.com/anomalyco/opencode
# Author: Andres Monge (aemonge)
# License: MIT

set -euo pipefail

readonly PROGRAM_NAME="scoder"
readonly PROGRAM_VERSION="0.9.0"
readonly OPENCODE_BIN_DEFAULT="opencode"

# Colors for output
readonly RED='\033[0;31m'
readonly YELLOW='\033[1;33m'
readonly GREEN='\033[0;32m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m' # No Color

usage() {
    cat <<'USAGE_EOF'
scoder 0.9.0
Safe OpenCode wrapper using bubblewrap.

Usage:
  scoder [options] [PROJECT_DIR] [-- [OPENCODE_ARGS...]]
  scoder [options] [PROJECT_DIR] -- COMMAND [ARG...]

Options:
  -h, --help              Show this help and exit
  -V, --version           Show version and exit
  -b, --bin PATH          Path to opencode binary (default: "opencode")
  -q, --quiet             Suppress informational output
      --validate          Run comprehensive validation tests and exit
      --ro                Mount project directory read-only (safe)
      --rw                Mount project directory read-write (default)
      --allow-git         Allow write access to .git directory (default: read-only)
      --allow-infra       Allow write access to all protected infra dirs
      --full-dev          Allow full /dev access inside sandbox
      --no-nvim-remote    Disable active Neovim socket bridge
  --allow-host-tools  Bind host user tools (~/.local/bin, mise, pyenv, uv, rustup/cargo, etc) (default)
  --no-host-tools     Disable binding host user tools
USAGE_EOF

    cat <<'USAGE_END'

Arguments:
  PROJECT_DIR             Project directory exposed at same absolute path (default: $PWD)
  OPENCODE_ARGS           Arguments passed verbatim to opencode when first arg after "--" starts with "-"
  COMMAND [ARG...]        Raw command executed inside the sandbox when first arg after "--" does not start with "-"

Environment:
  OPENCODE_BIN            Overrides default opencode binary
  SCODER_FS_MODE          "ro" (secure) or "rw" (default, allow writes)
  SCODER_DEFAULT_AGENT    Default OpenCode agent when none is provided (default: OpenAgent)

Protected Directories (read-only by default):
  .git, .github, .turbo, .cargo
  .gitignore, package-lock.json, poetry.lock, Cargo.lock, .github/

Writable Runtime State:
  - ~/.config/opencode
  - ~/.cache/opencode
  - ~/.local/share/opencode
  - ~/.opencode
  - ~/.bun
  - ~/.cache/bun

Examples:
  scoder                    # rw sandbox of $PWD, infra protected
  scoder --validate         # run comprehensive validation tests
  scoder --ro               # read-only sandbox of $PWD
  scoder --allow-git        # allow .git writes
  scoder --allow-host-tools # bind host dev tools (mise, cargo, etc)
  scoder . -- /bin/bash -lc 'env | grep HOME' # run raw command in sandbox
  scoder myproj -- --verbose # pass --verbose to opencode

Security Note:
  HOME mirrors your host home path on tmpfs with explicit binds.
  The active Neovim socket is exposed by default when NVIM points to a socket.
  OpenCode and Bun runtime state is persisted via explicit writable binds.
  Host tools are bound by default (use --no-host-tools to disable them).
  The project is writable by default, but critical infrastructure directories
  are protected read-only unless you explicitly opt in.
  When launching OpenCode without an explicit --agent, scoder prepends
  the default agent from SCODER_DEFAULT_AGENT.
USAGE_END
}

version() {
    echo "${PROGRAM_NAME} ${PROGRAM_VERSION}"
    echo "Sandbox mode: bubblewrap"
}

error() {
    echo -e "${RED}${PROGRAM_NAME}: $*${NC}" >&2
}

warning() {
    echo -e "${YELLOW}${PROGRAM_NAME}: $*${NC}" >&2
}

info() {
    if [[ "${QUIET}" -eq 0 ]]; then
        echo -e "${GREEN}${PROGRAM_NAME}: $*${NC}" >&2
    fi
}

info_blue() {
    if [[ "${QUIET}" -eq 0 ]]; then
        echo -e "${BLUE}${PROGRAM_NAME}: $*${NC}" >&2
    fi
}

json_escape() {
    local value="$1"
    value=${value//\\/\\\\}
    value=${value//\"/\\\"}
    value=${value//$'\n'/\\n}
    printf '%s' "${value}"
}

has_agent_argument() {
    local arg
    for arg in "$@"; do
        case "$arg" in
        --agent | --agent=*)
            return 0
            ;;
        esac
    done
    return 1
}

apply_default_agent_if_needed() {
    local opencode_bin_name
    opencode_bin_name=$(basename -- "$OPENCODE_BIN")
    case "$opencode_bin_name" in
    opencode | opencode-*) ;;
    *)
        return
        ;;
    esac

    if has_agent_argument "${OPENCODE_ARGS[@]}"; then
        return
    fi

    local default_agent="${SCODER_DEFAULT_AGENT:-OpenAgent}"
    OPENCODE_ARGS=(--agent "$default_agent" "${OPENCODE_ARGS[@]}")
}

normalize_raw_command_if_needed() {
    if [[ ${#RAW_COMMAND[@]} -lt 2 ]]; then
        return
    fi

    case "${RAW_COMMAND[0]}" in
    bash | /bin/bash)
        case "${RAW_COMMAND[1]}" in
        -c | -lc)
            RAW_COMMAND=("${RAW_COMMAND[0]}" --noprofile --norc "${RAW_COMMAND[1]}" "${RAW_COMMAND[@]:2}")
            ;;
        esac
        ;;
    esac
}

run_validation() {
    local script_path="$0"
    local test_project="/tmp/scoder-validation-$$"
    local failed_tests=0
    local cmd_status
    local selected_opencode_bin

    info "=== Running scoder comprehensive validation tests ==="

    selected_opencode_bin="${OPENCODE_BIN:-${OPENCODE_BIN_DEFAULT}}"

    info "Test 0.1: bwrap availability"
    if command -v bwrap >/dev/null 2>&1; then
        echo "✅ Test 0.1 PASS: bwrap found at $(command -v bwrap)"
    else
        echo "❌ Test 0.1 FAIL: bwrap not found"
        ((failed_tests++))
    fi

    info "Test 0.2: opencode binary availability"
    if command -v "${selected_opencode_bin}" >/dev/null 2>&1; then
        echo "✅ Test 0.2 PASS: opencode binary found at $(command -v "${selected_opencode_bin}")"
    else
        echo "❌ Test 0.2 FAIL: opencode binary not found: ${selected_opencode_bin}"
        ((failed_tests++))
    fi

    # Setup test project
    mkdir -p "${test_project}"/{.git,node_modules,.venv/bin}
    echo "test content" >"${test_project}/test.py"
    echo "SCODER_VALIDATION=1" >"${test_project}/.env"
    echo '#!/bin/bash' >"${test_project}/.venv/bin/python"
    chmod +x "${test_project}/.venv/bin/python"

    # Test A.1: HOME isolation
    echo ""
    info "Test A.1: HOME isolation"
    local home_result
    home_result=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc "printf '%s' \"\$HOME\"" || true)
    if [[ "${home_result}" == "${HOME}" ]]; then
        echo "✅ Test A.1 PASS: HOME mirrors host home path"
    else
        echo "❌ Test A.1 FAIL: HOME is ${home_result} (expected ${HOME})"
        ((failed_tests++))
    fi

    # Test A.1b: EDITOR default
    info "Test A.1b: EDITOR default"
    local editor_result
    editor_result=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc "printf '%s' \"\$EDITOR\"" || true)
    if [[ "${editor_result}" == "v_quickedit_hover" ]]; then
        echo "✅ Test A.1b PASS: EDITOR defaults to v_quickedit_hover"
    else
        echo "❌ Test A.1b FAIL: EDITOR is ${editor_result} (expected v_quickedit_hover)"
        ((failed_tests++))
    fi

    # Test A.1c: NVIM/XDG runtime propagation and socket visibility
    if [[ -n "${NVIM:-}" && -S "${NVIM}" ]]; then
        info "Test A.1c: active Neovim socket bridge"
        local nvim_result
        nvim_result=$(OPENCODE_BIN=/bin/bash NVIM="${NVIM}" XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc "printf '%s' \"\$NVIM\"" || true)
        if [[ "${nvim_result}" == "${NVIM}" ]]; then
            echo "✅ Test A.1c PASS: NVIM propagated into sandbox"
        else
            echo "❌ Test A.1c FAIL: NVIM is ${nvim_result} (expected ${NVIM})"
            ((failed_tests++))
        fi

        local nvim_socket_test
        nvim_socket_test=$(OPENCODE_BIN=/bin/bash NVIM="${NVIM}" XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'test -S "$NVIM" && printf SOCKET_OK' || true)
        if [[ "${nvim_socket_test}" == "SOCKET_OK" ]]; then
            echo "✅ Test A.1c PASS: active Neovim socket is visible"
        else
            echo "❌ Test A.1c FAIL: active Neovim socket not visible"
            ((failed_tests++))
        fi

        if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
            local xdg_runtime_result
            xdg_runtime_result=$(OPENCODE_BIN=/bin/bash NVIM="${NVIM}" XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR}" "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc "printf '%s' \"\$XDG_RUNTIME_DIR\"" || true)
            if [[ "${xdg_runtime_result}" == "${XDG_RUNTIME_DIR}" ]]; then
                echo "✅ Test A.1c PASS: XDG runtime dir propagated"
            else
                echo "❌ Test A.1c FAIL: XDG runtime dir is ${xdg_runtime_result} (expected ${XDG_RUNTIME_DIR})"
                ((failed_tests++))
            fi
        fi
    else
        echo "ℹ️  Test A.1c SKIP: No active NVIM socket in host environment"
    fi

    # Test A.2: bashrc write isolation (no leak to host)
    info "Test A.2: ~/.bashrc write isolation"
    local host_bashrc="${HOME}/.bashrc"
    OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'echo "SCODER_TEST" > ~/.bashrc' >/dev/null 2>&1 || true
    local leaked=0
    if [[ -f "${host_bashrc}" ]]; then
        if grep -q "SCODER_TEST" "${host_bashrc}" 2>/dev/null; then
            leaked=1
        fi
    fi
    if [[ "${leaked}" -eq 0 ]]; then
        echo "✅ Test A.2 PASS: ~/.bashrc writes do not leak to host"
    else
        echo "❌ Test A.2 FAIL: ~/.bashrc writes leaked to host"
        ((failed_tests++))
    fi

    # Test A.3: System file write protection
    info "Test A.3: System file write protection"
    local sys_write
    sys_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'touch /usr/bin/scoder-test 2>&1' 2>&1 || true)
    if echo "${sys_write}" | grep -qE "Read-only|Permission denied|cannot touch"; then
        echo "✅ Test A.3 PASS: System files are read-only"
    else
        echo "❌ Test A.3 FAIL: System files are writable"
        ((failed_tests++))
    fi

    # Test B.1: Workspace is writable
    info "Test B.1: Workspace writability"
    local workspace_write
    workspace_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'touch new_file.py && echo SUCCESS' 2>&1 || true)
    if echo "${workspace_write}" | grep -q "SUCCESS"; then
        echo "✅ Test B.1 PASS: Workspace is writable"
    else
        echo "❌ Test B.1 FAIL: Cannot write to workspace"
        ((failed_tests++))
    fi

    # Test B.2: .git protection
    info "Test B.2: .git directory protection"
    local git_write
    git_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'touch .git/test 2>&1' 2>&1 || true)
    if echo "${git_write}" | grep -qE "Read-only|Permission denied|cannot touch"; then
        echo "✅ Test B.2 PASS: .git is read-only"
    else
        echo "❌ Test B.2 FAIL: .git is writable"
        ((failed_tests++))
    fi

    # Test B.3: node_modules writability
    info "Test B.3: node_modules directory writability"
    local nm_write
    nm_write=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'touch node_modules/test && echo SUCCESS' 2>&1 || true)
    if echo "${nm_write}" | grep -q "SUCCESS"; then
        echo "✅ Test B.3 PASS: node_modules is writable"
    else
        echo "❌ Test B.3 FAIL: node_modules is not writable"
        ((failed_tests++))
    fi

    # Test B.4: --allow-git override
    info "Test B.4: --allow-git override functionality"
    local git_override
    git_override=$(OPENCODE_BIN=/bin/bash "${script_path}" -q --allow-git "${test_project}" -- /bin/bash --noprofile --norc -lc 'touch .git/test && echo SUCCESS' 2>&1 || true)
    if echo "${git_override}" | grep -q "SUCCESS"; then
        echo "✅ Test B.4 PASS: --allow-git override works"
    else
        echo "❌ Test B.4 FAIL: --allow-git override failed"
        ((failed_tests++))
    fi

    # Test B.5: project .env visibility
    info "Test B.5: project .env visibility"
    local env_visible
    env_visible=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'test -e .env && echo SUCCESS' 2>&1 || true)
    if echo "${env_visible}" | grep -q "SUCCESS"; then
        echo "✅ Test B.5 PASS: project .env is visible"
    else
        echo "❌ Test B.5 FAIL: project .env is not visible"
        ((failed_tests++))
    fi

    # Test B.6: --ro must not mutate project-local mise state
    info "Test B.6: --ro blocks project-local mise state writes"
    rm -rf "${test_project}/.local"
    OPENCODE_BIN=/bin/bash "${script_path}" -q --ro "${test_project}" -- /bin/bash --noprofile --norc -lc 'test ! -w . && echo RO' >/dev/null 2>&1 || true
    if [[ ! -e "${test_project}/.local/state/mise" ]]; then
        echo "✅ Test B.6 PASS: --ro does not create project-local mise state"
    else
        echo "❌ Test B.6 FAIL: --ro created project-local mise state"
        ((failed_tests++))
    fi

    # Test B.7: raw command execution after --
    info "Test B.7: raw command execution after --"
    local raw_command_test
    raw_command_test=$("${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'printf RAW_OK' || true)
    if [[ "${raw_command_test}" == "RAW_OK" ]]; then
        echo "✅ Test B.7 PASS: raw commands execute inside sandbox"
    else
        echo "❌ Test B.7 FAIL: raw command output was '${raw_command_test}'"
        ((failed_tests++))
    fi

    # Test C: Config bind (if opencode.json exists)
    if [[ -f "${OPENCODE_DEFAULT_CONFIG}" ]]; then
        info "Test C: Config bind verification"
        local config_read
        config_read=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'cat ~/.config/opencode/opencode.json' || true)
        local expected_content
        expected_content=$(cat "${OPENCODE_DEFAULT_CONFIG}" 2>/dev/null || echo "")
        if [[ "${config_read}" == "${expected_content}" ]]; then
            echo "✅ Test C PASS: Config bind works (opencode.json visible)"
        else
            echo "❌ Test C FAIL: Config bind mismatch"
            ((failed_tests++))
        fi
    else
        echo "ℹ️  Test C SKIP: No opencode.json found (${OPENCODE_DEFAULT_CONFIG})"
    fi

    # Test D: Tooling PATH
    info "Test D: .venv in PATH"
    local venv_path
    venv_path=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc "echo \"\$PATH\"" 2>&1 || true)
    if echo "${venv_path}" | grep -q ".venv/bin"; then
        echo "✅ Test D PASS: .venv/bin is in PATH"
    else
        echo "❌ Test D FAIL: .venv/bin not in PATH"
        ((failed_tests++))
    fi

    # Test E: DNS resolver configuration
    info "Test E: DNS resolver configuration"
    local dns_test
    dns_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'grep -q "^nameserver " /etc/resolv.conf && echo SUCCESS' 2>&1 || true)
    if echo "${dns_test}" | grep -q "SUCCESS"; then
        echo "✅ Test E PASS: DNS resolver config is available"
    else
        echo "❌ Test E FAIL: DNS resolver config unavailable"
        ((failed_tests++))
    fi

    # Test F: OpenCode writable runtime state
    info "Test F: OpenCode writable runtime state"
    local oc_state_test
    oc_state_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'test -w "$HOME/.config/opencode" && test -w "$HOME/.cache/opencode" && test -w "$HOME/.local/share/opencode" && test -w "$HOME/.opencode" && echo SUCCESS' 2>&1 || true)
    if echo "${oc_state_test}" | grep -q "SUCCESS"; then
        echo "✅ Test F PASS: OpenCode runtime paths are writable"
    else
        echo "❌ Test F FAIL: OpenCode runtime paths are not writable"
        ((failed_tests++))
    fi

    # Test G: Bun writable runtime state
    info "Test G: Bun writable runtime state"
    local bun_state_test
    bun_state_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'test -w "$HOME/.bun" && test -w "$HOME/.cache/bun" && echo SUCCESS' 2>&1 || true)
    if echo "${bun_state_test}" | grep -q "SUCCESS"; then
        echo "✅ Test G PASS: Bun runtime paths are writable"
    else
        echo "❌ Test G FAIL: Bun runtime paths are not writable"
        ((failed_tests++))
    fi

    # Test H: TUI environment essentials
    info "Test H: TUI environment essentials"
    local tui_env_test
    tui_env_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc "test -n \"\$TERM\" && test -n \"\$LANG\" && test -n \"\$SHELL\" && test \"\$GIT_OPTIONAL_LOCKS\" = \"0\" && echo SUCCESS" 2>&1 || true)
    if echo "${tui_env_test}" | grep -q "SUCCESS"; then
        echo "✅ Test H PASS: TUI environment variables are present"
    else
        echo "❌ Test H FAIL: Missing required TUI environment variables"
        ((failed_tests++))
    fi

    # Test I: project path preserved inside sandbox
    info "Test I: project path preserved"
    local project_path_test
    project_path_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'pwd' || true)
    if [[ "${project_path_test}" == "${test_project}" ]]; then
        echo "✅ Test I PASS: project path preserved"
    else
        echo "❌ Test I FAIL: project path changed to ${project_path_test}"
        ((failed_tests++))
    fi

    # Test J: browser plugin state bind
    if [[ -d "${HOME}/.opencode-browser" ]]; then
        info "Test J: browser plugin state bind"
        local browser_state_test
        browser_state_test=$(OPENCODE_BIN=/bin/bash "${script_path}" -q "${test_project}" -- /bin/bash --noprofile --norc -lc 'test -w "$HOME/.opencode-browser" && echo SUCCESS' 2>&1 || true)
        if echo "${browser_state_test}" | grep -q "SUCCESS"; then
            echo "✅ Test J PASS: browser plugin state is writable"
        else
            echo "❌ Test J FAIL: browser plugin state is not writable"
            ((failed_tests++))
        fi
    else
        echo "ℹ️  Test J SKIP: ~/.opencode-browser not present on host"
    fi

    # Test K: tool launcher status
    info "Test K: host tool and launcher status"
    for cmd_status in node npm npx bun uv uvx; do
        if command -v "${cmd_status}" >/dev/null 2>&1; then
            echo "✅ ${cmd_status}: $(command -v "${cmd_status}")"
        else
            echo "ℹ️  ${cmd_status}: unavailable on host"
        fi
    done

    if command -v npx >/dev/null 2>&1; then
        echo "✅ context7 launcher: npx available"
    else
        echo "❌ context7 launcher: npx unavailable"
        ((failed_tests++))
    fi

    if command -v uvx >/dev/null 2>&1; then
        echo "✅ fetch launcher: uvx available"
    else
        echo "❌ fetch launcher: uvx unavailable"
        ((failed_tests++))
    fi

    # Cleanup
    rm -rf "${test_project}"

    echo ""
    if [[ "${failed_tests}" -eq 0 ]]; then
        echo "🎉 All validation tests passed!"
        return 0
    else
        echo "⚠️  ${failed_tests} test(s) failed"
        return 1
    fi
}

# -------- defaults (SECURE BY DEFAULT, BUT WRITABLE) --------
OPENCODE_BIN="${OPENCODE_BIN:-${OPENCODE_BIN_DEFAULT}}"
FS_MODE="${SCODER_FS_MODE:-rw}"
QUIET=0
VALIDATE_MODE=0
ALLOW_HOST_TOOLS=1
ALLOW_HOST_TOOLS_SET=0
ALLOW_HOST_TOOLS_DISABLE_SET=0
ALLOW_NVIM_REMOTE=1
HOST_HOME="${HOME}"

# Config path
OPENCODE_DEFAULT_CONFIG="${HOME}/.config/opencode/opencode.json"

PROJECT_DIR=""
OPENCODE_ARGS=()
RAW_COMMAND=()

# -------- option parsing --------
RO_SET=0
RW_SET=0
ALLOW_GIT=0
ALLOW_INFRA=0
RESTRICT_DEV=1
PARSE_DONE=0

while [[ $# -gt 0 ]]; do
    if [[ "${PARSE_DONE}" -eq 1 ]]; then
        if [[ ${#OPENCODE_ARGS[@]} -eq 0 && ${#RAW_COMMAND[@]} -eq 0 && "$1" != -* ]]; then
            RAW_COMMAND=("$@")
            break
        fi
        OPENCODE_ARGS+=("$1")
        shift
        continue
    fi

    case "$1" in
    -h | --help)
        usage
        exit 0
        ;;
    -V | --version)
        version
        exit 0
        ;;
    -q | --quiet)
        QUIET=1
        shift
        ;;
    --validate)
        VALIDATE_MODE=1
        shift
        ;;
    -b | --bin)
        if [[ $# -lt 2 ]]; then
            error "missing argument for $1"
            exit 1
        fi
        OPENCODE_BIN="$2"
        shift 2
        ;;
    --ro)
        RO_SET=1
        FS_MODE="ro"
        shift
        ;;
    --rw)
        RW_SET=1
        FS_MODE="rw"
        shift
        ;;
    --allow-git)
        ALLOW_GIT=1
        shift
        ;;
    --allow-infra)
        ALLOW_INFRA=1
        shift
        ;;
    --allow-host-tools)
        ALLOW_HOST_TOOLS=1
        ALLOW_HOST_TOOLS_SET=1
        shift
        ;;
    --no-host-tools)
        ALLOW_HOST_TOOLS=0
        ALLOW_HOST_TOOLS_DISABLE_SET=1
        shift
        ;;
    --no-nvim-remote)
        ALLOW_NVIM_REMOTE=0
        shift
        ;;
    --full-dev)
        RESTRICT_DEV=0
        shift
        ;;
    --)
        PARSE_DONE=1
        shift
        ;;
    -*)
        error "unknown option: $1"
        echo "Try '${PROGRAM_NAME} --help' for more information." >&2
        exit 1
        ;;
    *)
        if [[ -z "${PROJECT_DIR}" ]]; then
            PROJECT_DIR="$1"
        else
            error "unexpected argument before '--': $1"
            echo "Try '${PROGRAM_NAME} --help' for more information." >&2
            exit 1
        fi
        shift
        ;;
    esac
done

# Handle validation mode
if [[ "${VALIDATE_MODE}" -eq 1 ]]; then
    run_validation
    exit $?
fi

# Check for conflicting flags
if [[ "${RO_SET}" -eq 1 && "${RW_SET}" -eq 1 ]]; then
    error "--ro and --rw are mutually exclusive"
    exit 1
fi

if [[ "${ALLOW_HOST_TOOLS_SET}" -eq 1 && "${ALLOW_HOST_TOOLS_DISABLE_SET}" -eq 1 ]]; then
    error "--allow-host-tools and --no-host-tools are mutually exclusive"
    exit 1
fi

# PROJECT_DIR default
if [[ -z "${PROJECT_DIR}" ]]; then
    PROJECT_DIR="${PWD}"
fi

# -------- validation --------
if ! command -v bwrap >/dev/null 2>&1; then
    error "bubblewrap (bwrap) not found in PATH"
    error "install: pacman -S bubblewrap  # Arch/Manjaro"
    error "         apt install bubblewrap  # Debian/Ubuntu"
    error "         dnf install bubblewrap  # Fedora/RHEL"
    exit 1
fi

BWRAP_DISABLE_USERNS_SUPPORTED=0
if bwrap --help 2>/dev/null | grep -q -- "--disable-userns"; then
    BWRAP_DISABLE_USERNS_SUPPORTED=1
fi

if ! command -v "${OPENCODE_BIN}" >/dev/null 2>&1; then
    error "opencode binary not found: ${OPENCODE_BIN}"
    exit 1
fi

if [[ ! -d "${PROJECT_DIR}" ]]; then
    error "project directory does not exist: ${PROJECT_DIR}"
    exit 1
fi

if [[ "${FS_MODE}" != "ro" && "${FS_MODE}" != "rw" ]]; then
    error "invalid FS mode '${FS_MODE}' (expected 'ro' or 'rw')"
    exit 1
fi

PROJECT_DIR="$(realpath "${PROJECT_DIR}")"
SANDBOX_WORKDIR="${PROJECT_DIR}"
SANDBOX_HOME="${HOST_HOME}"
SANDBOX_EDITOR="v_quickedit_hover"
SANDBOX_LOCAL_DIR="${SANDBOX_HOME}/.local"
SANDBOX_CONFIG_DIR="${SANDBOX_HOME}/.config"
SANDBOX_CACHE_DIR="${SANDBOX_HOME}/.cache"
SANDBOX_OPENCODE_ALT_DIR="${SANDBOX_HOME}/.opencode"
SANDBOX_BUN_HOME="${SANDBOX_HOME}/.bun"
SANDBOX_BROWSER_DIR="${SANDBOX_HOME}/.opencode-browser"
SANDBOX_LOCAL_SHARE_DIR="${SANDBOX_LOCAL_DIR}/share"
SANDBOX_LOCAL_STATE_DIR="${SANDBOX_LOCAL_DIR}/state"
SANDBOX_OPENCODE_CONFIG_DIR="${SANDBOX_CONFIG_DIR}/opencode"
SANDBOX_OPENCODE_CACHE_DIR="${SANDBOX_CACHE_DIR}/opencode"
SANDBOX_BUN_CACHE_DIR="${SANDBOX_CACHE_DIR}/bun"
SANDBOX_OPENCODE_DATA_DIR="${SANDBOX_LOCAL_SHARE_DIR}/opencode"

if [[ ${#RAW_COMMAND[@]} -eq 0 ]]; then
    apply_default_agent_if_needed
else
    normalize_raw_command_if_needed
fi

# Ensure OpenCode data/cache dirs exist (config handled separately)
OPENCODE_DATA="${HOME}/.local/share/opencode"
OPENCODE_CACHE="${HOME}/.cache/opencode"
OPENCODE_CONFIG_DIR="${HOME}/.config/opencode"
OPENCODE_ALT_DIR="${HOME}/.opencode"
BUN_HOME="${HOME}/.bun"
BUN_CACHE="${HOME}/.cache/bun"
mkdir -p "${OPENCODE_DATA}/sessions"
mkdir -p "${OPENCODE_DATA}/permissions"
mkdir -p "${OPENCODE_CACHE}"
mkdir -p "${OPENCODE_CONFIG_DIR}"
mkdir -p "${OPENCODE_ALT_DIR}"
mkdir -p "${BUN_HOME}"
mkdir -p "${BUN_CACHE}"

OPENCODE_DATA="$(realpath "${OPENCODE_DATA}")"
OPENCODE_CACHE="$(realpath "${OPENCODE_CACHE}")"
OPENCODE_CONFIG_DIR="$(realpath "${OPENCODE_CONFIG_DIR}")"
OPENCODE_ALT_DIR="$(realpath "${OPENCODE_ALT_DIR}")"
BUN_HOME="$(realpath "${BUN_HOME}")"
BUN_CACHE="$(realpath "${BUN_CACHE}")"

if [[ -d "${HOME}/.opencode-browser" ]]; then
    OPENCODE_BROWSER_DIR="$(realpath "${HOME}/.opencode-browser")"
fi

# FS bind mode
if [[ "${FS_MODE}" = "ro" ]]; then
    BIND_FLAG="--ro-bind"
else
    BIND_FLAG="--bind"
fi

# -------- OPTIMIZED path setup --------
SANDBOX_PATH="/usr/local/bin:""\
/usr/local/sbin:""\
/usr/bin:""\
/usr/sbin:""\
/bin:""\
/sbin:""\
/usr/bin/site_perl"
SANDBOX_PATH="${SANDBOX_BUN_HOME}/bin:${SANDBOX_PATH}"

EXTRA_BINDS=()
EXTRA_DIRS=()
SANDBOX_SYMLINKS=()

# Helper: opt_bind (used for optional host-path binds)
opt_bind() {
    local host_p="$1"
    local sand_p="$2"
    local resolved_host_p
    if [[ -d "${host_p}" ]]; then
        resolved_host_p="$(realpath "${host_p}")"
        EXTRA_BINDS+=(--ro-bind "${resolved_host_p}" "${sand_p}")
    fi
}

opt_bind_path() {
    local host_p="$1"
    local sand_p="$2"
    local resolved_host_p
    if [[ -e "${host_p}" ]]; then
        resolved_host_p="$(realpath "${host_p}")"
        EXTRA_BINDS+=(--bind "${resolved_host_p}" "${sand_p}")
    fi
}

add_extra_dir_once() {
    local dir_path="$1"
    local existing
    local index

    for ((index = 0; index < ${#EXTRA_DIRS[@]}; index += 2)); do
        existing="${EXTRA_DIRS[index + 1]}"
        if [[ "${existing}" == "${dir_path}" ]]; then
            return
        fi
    done

    EXTRA_DIRS+=(--dir "${dir_path}")
}

add_parent_dirs_once() {
    local dir_path="$1"
    local parent=""
    local segment

    IFS='/' read -r -a segments <<<"${dir_path}"
    for segment in "${segments[@]}"; do
        [[ -z "${segment}" ]] && continue
        parent="${parent}/${segment}"
        add_extra_dir_once "${parent}"
    done
}

map_host_path_to_sandbox() {
    local host_path="$1"

    if [[ "${host_path}" == "${HOST_HOME}"* ]]; then
        REPLY="${SANDBOX_HOME}${host_path#${HOST_HOME}}"
        return
    fi

    REPLY="${host_path}"
}

mirror_persistent_subpath_symlink() {
    local host_path="$1"
    local visible_sandbox_path="$2"
    local resolved_target
    local target_sandbox_path

    if [[ ! -L "${host_path}" ]]; then
        REPLY="${visible_sandbox_path}"
        return
    fi

    resolved_target="$(realpath "${host_path}")"
    map_host_path_to_sandbox "${resolved_target}"
    target_sandbox_path="${REPLY}"
    add_parent_dirs_once "$(dirname "${visible_sandbox_path}")"
    add_parent_dirs_once "$(dirname "${target_sandbox_path}")"
    SANDBOX_SYMLINKS+=(--symlink "${target_sandbox_path}" "${visible_sandbox_path}")
    REPLY="${target_sandbox_path}"
}

mirror_persistent_subpath_symlink "${HOST_HOME}/.config/opencode" "${SANDBOX_OPENCODE_CONFIG_DIR}"
SANDBOX_OPENCODE_CONFIG_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.local/share/opencode" "${SANDBOX_OPENCODE_DATA_DIR}"
SANDBOX_OPENCODE_DATA_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.cache/opencode" "${SANDBOX_OPENCODE_CACHE_DIR}"
SANDBOX_OPENCODE_CACHE_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.cache/bun" "${SANDBOX_BUN_CACHE_DIR}"
SANDBOX_BUN_CACHE_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.opencode" "${SANDBOX_OPENCODE_ALT_DIR}"
SANDBOX_OPENCODE_ALT_DIR="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.bun" "${SANDBOX_BUN_HOME}"
SANDBOX_BUN_HOME="${REPLY}"
mirror_persistent_subpath_symlink "${HOST_HOME}/.opencode-browser" "${SANDBOX_BROWSER_DIR}"
SANDBOX_BROWSER_DIR="${REPLY}"

# Bind host tools unless explicitly disabled
if [[ "${ALLOW_HOST_TOOLS}" -eq 1 ]]; then
    info "Binding host development tools"

    # User binaries
    if [[ -d "${HOME}/.local/bin" ]]; then
        EXTRA_BINDS+=(--ro-bind "$(realpath "${HOME}/.local/bin")" "${SANDBOX_HOME}/.local/bin")
        SANDBOX_PATH="${SANDBOX_HOME}/.local/bin:${SANDBOX_PATH}"
    fi

    # Mise
    opt_bind "${HOME}/.local/share/mise" "${SANDBOX_HOME}/.local/share/mise"
    opt_bind "${HOME}/.config/mise" "${SANDBOX_HOME}/.config/mise"
    if [[ -d "${HOME}/.local/share/mise/shims" ]]; then
        SANDBOX_PATH="${SANDBOX_HOME}/.local/share/mise/shims:${SANDBOX_PATH}"
    fi

    # uv
    if [[ -d "${HOME}/.local/share/uv" ]]; then
        EXTRA_BINDS+=(--ro-bind "$(realpath "${HOME}/.local/share/uv")" "${SANDBOX_HOME}/.local/share/uv")
    fi

    # Pyenv
    if [[ -d "${HOME}/.pyenv" ]]; then
        EXTRA_BINDS+=(--ro-bind "$(realpath "${HOME}/.pyenv")" "${SANDBOX_HOME}/.pyenv")
        SANDBOX_PATH="${SANDBOX_HOME}/.pyenv/shims:${SANDBOX_HOME}/.pyenv/bin:${SANDBOX_PATH}"
        PYENV_ROOT_SANDBOX="${SANDBOX_HOME}/.pyenv"
    fi

    # Rust
    if [[ -d "${HOME}/.rustup" ]]; then
        EXTRA_BINDS+=(--ro-bind "$(realpath "${HOME}/.rustup")" "${SANDBOX_HOME}/.rustup")
        RUSTUP_HOME_SANDBOX="${SANDBOX_HOME}/.rustup"
    fi
    if [[ -d "${HOME}/.cargo/bin" ]]; then
        EXTRA_BINDS+=(--ro-bind "$(realpath "${HOME}/.cargo/bin")" "${SANDBOX_HOME}/.cargo/bin")
        SANDBOX_PATH="${SANDBOX_HOME}/.cargo/bin:${SANDBOX_PATH}"
    fi
fi

# Project-local state for mise
if [[ -n "${PROJECT_DIR}" ]]; then
    if [[ "${FS_MODE}" = "ro" ]]; then
        MISE_STATE_DIR="${HOST_HOME}/.local/state/scoder/mise$(printf '%s' "${PROJECT_DIR}" | tr '/' '_')"
    else
        MISE_STATE_DIR="${PROJECT_DIR}/.local/state/mise"
    fi
    mkdir -p "${MISE_STATE_DIR}"
    EXTRA_BINDS+=(--bind "${MISE_STATE_DIR}" "${SANDBOX_HOME}/.local/state/mise")
fi

if [[ "${ALLOW_NVIM_REMOTE}" -eq 1 && -n "${NVIM:-}" && -S "${NVIM}" ]]; then
    NVIM_SOCKET_HOST="${NVIM}"
    NVIM_SOCKET_SANDBOX="${NVIM_SOCKET_HOST}"
    add_parent_dirs_once "$(dirname "${NVIM_SOCKET_SANDBOX}")"
    opt_bind_path "${NVIM_SOCKET_HOST}" "${NVIM_SOCKET_SANDBOX}"
fi

RESOLV_CONF_TARGET="$(readlink -f /etc/resolv.conf 2>/dev/null || true)"
if [[ -n "${RESOLV_CONF_TARGET}" && "${RESOLV_CONF_TARGET}" != "/etc/resolv.conf" && -f "${RESOLV_CONF_TARGET}" ]]; then
    add_parent_dirs_once "$(dirname "${RESOLV_CONF_TARGET}")"
    EXTRA_BINDS+=(--ro-bind "${RESOLV_CONF_TARGET}" "${RESOLV_CONF_TARGET}")
fi

# Project-local Cargo binaries
if [[ -d "${PROJECT_DIR}/.cargo/bin" ]]; then
    EXTRA_BINDS+=(--bind "${PROJECT_DIR}/.cargo/bin" "${SANDBOX_HOME}/.cargo/bin")
    SANDBOX_PATH="${SANDBOX_HOME}/.cargo/bin:${SANDBOX_PATH}"
fi

# Python virtual environments (project-local)
if [[ -d "${PROJECT_DIR}/.venv/bin" ]]; then
    EXTRA_BINDS+=(--bind "${PROJECT_DIR}/.venv/bin" "${SANDBOX_WORKDIR}/.venv/bin")
    SANDBOX_PATH="${SANDBOX_WORKDIR}/.venv/bin:${SANDBOX_PATH}"
fi

# Node.js project-local binaries
if [[ -d "${PROJECT_DIR}/node_modules/.bin" ]]; then
    EXTRA_BINDS+=(--bind "${PROJECT_DIR}/node_modules/.bin" "${SANDBOX_WORKDIR}/node_modules/.bin")
    SANDBOX_PATH="${SANDBOX_WORKDIR}/node_modules/.bin:${SANDBOX_PATH}"
fi

# Go project-local binaries
if [[ -d "${PROJECT_DIR}/bin" && -f "${PROJECT_DIR}/go.mod" ]]; then
    EXTRA_BINDS+=(--bind "${PROJECT_DIR}/bin" "${SANDBOX_WORKDIR}/bin")
    SANDBOX_PATH="${SANDBOX_WORKDIR}/bin:${SANDBOX_PATH}"
fi

# -------- Infrastructure Protection --------
PROTECTED_INFRA_DIRS=(
    ".git"
    ".github"
    ".turbo"
    ".cargo"
)

PROTECTED_INFRA_FILES=(
    ".gitignore"
    "package-lock.json"
    "poetry.lock"
    "Cargo.lock"
    "pnpm-lock.yaml"
    "yarn.lock"
)

SAFE_BINDS=()
if [[ "${ALLOW_INFRA}" -eq 0 ]]; then
    for dir in "${PROTECTED_INFRA_DIRS[@]}"; do
        if [[ "${dir}" == ".git" && "${ALLOW_GIT}" -eq 1 ]]; then
            continue
        fi

        if [[ -d "${PROJECT_DIR}/${dir}" ]]; then
            SAFE_BINDS+=(--ro-bind "${PROJECT_DIR}/${dir}" "${SANDBOX_WORKDIR}/${dir}")
            info "Protecting ${dir}/ (read-only)"
        fi
    done

    for file in "${PROTECTED_INFRA_FILES[@]}"; do
        if [[ -f "${PROJECT_DIR}/${file}" ]]; then
            SAFE_BINDS+=(--ro-bind "${PROJECT_DIR}/${file}" "${SANDBOX_WORKDIR}/${file}")
            info "Protecting ${file} (read-only)"
        fi
    done
fi

# -------- run sandbox --------
BWRAP_CMD=(
    bwrap
    --ro-bind /usr /usr
    --ro-bind /bin /bin
    --ro-bind /lib /lib
)

if [[ "${BWRAP_DISABLE_USERNS_SUPPORTED}" -eq 1 ]]; then
    BWRAP_CMD=(bwrap --unshare-user "${BWRAP_CMD[@]:1}")
    BWRAP_CMD+=(--disable-userns)
else
    BWRAP_CMD=(bwrap --unshare-user-try "${BWRAP_CMD[@]:1}")
fi

if [[ -d /lib64 ]]; then
    BWRAP_CMD+=(--ro-bind /lib64 /lib64)
fi

if [[ -d /sys ]]; then
    BWRAP_CMD+=(--ro-bind /sys /sys)
fi

BWRAP_CMD+=(--ro-bind /etc /etc)

if [[ "${RESTRICT_DEV}" -eq 1 ]]; then
    BWRAP_CMD+=(
        --dev-bind /dev/null /dev/null
        --dev-bind /dev/zero /dev/zero
        --dev-bind /dev/random /dev/random
        --dev-bind /dev/urandom /dev/urandom
        --dev-bind /dev/tty /dev/tty
        --tmpfs /dev/shm
    )
else
    BWRAP_CMD+=(--dev /dev)
fi

BWRAP_CMD+=(
    --proc /proc
    --tmpfs /tmp
    --tmpfs /home
    --dir "${SANDBOX_HOME}"
    --dir "${SANDBOX_LOCAL_DIR}"
    --dir "${SANDBOX_LOCAL_SHARE_DIR}"
    --dir "${SANDBOX_LOCAL_STATE_DIR}"
    --dir "${SANDBOX_CONFIG_DIR}"
    --dir "${SANDBOX_OPENCODE_CONFIG_DIR}"
    --dir "${SANDBOX_CACHE_DIR}"
    --dir "${SANDBOX_BUN_CACHE_DIR}"
)

BWRAP_CMD+=("${EXTRA_DIRS[@]}")
BWRAP_CMD+=("${SANDBOX_SYMLINKS[@]}")
BWRAP_CMD+=("${EXTRA_BINDS[@]}")
if [[ "${SANDBOX_WORKDIR}" != "/" ]]; then
    BWRAP_CMD+=(--dir "$(dirname "${SANDBOX_WORKDIR}")")
fi
if [[ "${SANDBOX_WORKDIR}" != "/" ]]; then
    BWRAP_CMD+=(--dir "${SANDBOX_WORKDIR}")
fi
BWRAP_CMD+=("${BIND_FLAG}" "${PROJECT_DIR}" "${SANDBOX_WORKDIR}")

if [[ ${#SAFE_BINDS[@]} -gt 0 ]]; then
    BWRAP_CMD+=("${SAFE_BINDS[@]}")
fi

# Data/cache binding (always for persistence)
BWRAP_CMD+=(
    --bind "${OPENCODE_CONFIG_DIR}" "${SANDBOX_OPENCODE_CONFIG_DIR}"
    --bind "${OPENCODE_DATA}" "${SANDBOX_OPENCODE_DATA_DIR}"
    --bind "${OPENCODE_CACHE}" "${SANDBOX_OPENCODE_CACHE_DIR}"
    --bind "${OPENCODE_ALT_DIR}" "${SANDBOX_OPENCODE_ALT_DIR}"
    --bind "${BUN_HOME}" "${SANDBOX_BUN_HOME}"
    --bind "${BUN_CACHE}" "${SANDBOX_BUN_CACHE_DIR}"
)

if [[ -n "${OPENCODE_BROWSER_DIR:-}" ]]; then
    BWRAP_CMD+=(--bind "${OPENCODE_BROWSER_DIR}" "${SANDBOX_BROWSER_DIR}")
fi

if [[ -f "${OPENCODE_CONFIG_DIR}/opencode.json" ]]; then
    info "Using config: ${OPENCODE_CONFIG_DIR}/opencode.json"
else
    info "No opencode.json found, OpenCode will use defaults"
fi

BWRAP_CMD+=(--chdir "${SANDBOX_WORKDIR}")
BWRAP_CMD+=(
    --die-with-parent
    --clearenv
    --setenv PATH "${SANDBOX_PATH}"
    --setenv HOME "${SANDBOX_HOME}"
    --setenv USER scoder
    --setenv LOGNAME scoder
    --setenv TERM "${TERM:-xterm-256color}"
    --setenv COLORTERM "${COLORTERM:-truecolor}"
    --setenv LANG "${LANG:-C.UTF-8}"
    --setenv LC_ALL "${LC_ALL:-C.UTF-8}"
    --setenv EDITOR "${SANDBOX_EDITOR}"
    --setenv VISUAL "${SANDBOX_EDITOR}"
    --setenv SHELL "${SHELL:-/bin/bash}"
    --setenv GIT_OPTIONAL_LOCKS 0
    --setenv MISE_SKIP_ACTIVATE 1
    --setenv UV_LINK_MODE copy
)

if [[ -n "${PYENV_ROOT_SANDBOX:-}" ]]; then
    BWRAP_CMD+=(--setenv PYENV_ROOT "${PYENV_ROOT_SANDBOX}")
fi

if [[ -n "${RUSTUP_HOME_SANDBOX:-}" ]]; then
    BWRAP_CMD+=(--setenv RUSTUP_HOME "${RUSTUP_HOME_SANDBOX}")
fi

if [[ "${ALLOW_NVIM_REMOTE}" -eq 1 && -n "${NVIM_SOCKET_SANDBOX:-}" ]]; then
    BWRAP_CMD+=(--setenv NVIM "${NVIM_SOCKET_SANDBOX}")
fi

if [[ "${ALLOW_NVIM_REMOTE}" -eq 1 && -n "${NVIM_LISTEN_ADDRESS:-}" ]]; then
    BWRAP_CMD+=(--setenv NVIM_LISTEN_ADDRESS "${NVIM_LISTEN_ADDRESS}")
fi

if [[ "${ALLOW_NVIM_REMOTE}" -eq 1 && -n "${XDG_RUNTIME_DIR:-}" ]]; then
    BWRAP_CMD+=(--setenv XDG_RUNTIME_DIR "${XDG_RUNTIME_DIR}")
fi

if [[ -n "${PYO3_PYTHON:-}" ]]; then
    BWRAP_CMD+=(--setenv PYO3_PYTHON "${SANDBOX_WORKDIR}/.venv/bin/python")
fi

if [[ ${#RAW_COMMAND[@]} -gt 0 ]]; then
    BWRAP_CMD+=("${RAW_COMMAND[@]}")
else
    BWRAP_CMD+=("${OPENCODE_BIN}" "${OPENCODE_ARGS[@]}")
fi

info "Launching scoder sandbox..."
exec "${BWRAP_CMD[@]}"
