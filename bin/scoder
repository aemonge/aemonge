while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
        usage
        exit 0
        ;;
    -V | --version)
        version
        exit 0
        ;;
    -a | --add)
        if [[ $# -lt 2 ]]; then
            error "missing argument for $1"
            exit 1
        fi
        ADD_RO_PATHS+=("$2")
        shift 2
        ;;
    -A | --add-rw)
        if [[ $# -lt 2 ]]; then
            error "missing argument for $1"
            exit 1
        fi
        ADD_RW_PATHS+=("$2")
        shift 2
        ;;
    -q | --quiet)
        QUIET=1
        shift
        ;;
    --validate)
        VALIDATE_MODE=1
        shift
        ;;
    --doctor | --docotr)
        DOCTOR_MODE=1
        shift
        ;;
    -b | --bin)
        if [[ $# -lt 2 ]]; then
            error "missing argument for $1"
            exit 1
        fi
        OPENCODE_BIN="$2"
        shift 2
        ;;
    --ro)
        RO_SET=1
        FS_MODE="ro"
        shift
        ;;
    --rw)
        RW_SET=1
        FS_MODE="rw"
        shift
        ;;
    --allow-git)
        ALLOW_GIT=1
        shift
        ;;
    --allow-infra)
        ALLOW_INFRA=1
        shift
        ;;
    --allow-host-tools)
        ALLOW_HOST_TOOLS=1
        ALLOW_HOST_TOOLS_SET=1
        shift
        ;;
    -g | --allow-gui)
        ALLOW_GUI=1
        shift
        ;;
    -w | --web-developer)
        WEB_DEVELOPER_MODE=1
        ALLOW_GUI=1
        shift
        ;;
    --no-host-tools)
        ALLOW_HOST_TOOLS=0
        ALLOW_HOST_TOOLS_DISABLE_SET=1
        shift
        ;;
    --no-nvim-remote)
        ALLOW_NVIM_REMOTE=0
        shift
        ;;
    --full-dev)
        RESTRICT_DEV=0
        shift
        ;;
    -x | --exec)
        shift
        if [[ $# -eq 0 ]]; then
            error "missing command for -x/--exec"
            exit 1
        fi
        RAW_COMMAND=("$@")
        break
        ;;
    -*)
        error "unknown option: $1"
        echo "Try '${PROGRAM_NAME} --help' for more information." >&2
        exit 1
        ;;
    *)
        if [[ -z "${PROJECT_TARGET}" ]]; then
            PROJECT_TARGET="$1"
        else
            error "unexpected scoder argument after target: $1"
            echo "Try '${PROGRAM_NAME} --help' for more information." >&2
            exit 1
        fi
        shift
        ;;
    esac
done

