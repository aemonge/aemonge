  "agent": {
    "build": {
      "permission": {
        "bash": {
          "python *.py": "ask",
          "python ./*.py": "ask",
          "python */*.py": "ask",
          "python -m pytest*": "ask",
          "python -m unittest*": "ask",
          "python -m *": "ask",
          "node *.js": "ask",
          "node ./*.js": "ask",
          "npm run *": "ask",
          "npm test": "ask",
          "pytest": "ask",
          "pytest *": "ask",
          "make": "ask",
          "make *": "ask",
          "npm *": "allow",
          "pip list": "allow",
          "pip show *": "allow",
          "pip *": "allow",
          "cargo build": "allow",
          "cargo test": "allow",
          "cargo check": "allow",
          "cargo run": "allow",
          "cargo clippy": "allow",
          "cargo fmt": "allow",
          "cargo *": "allow",
          "rustc": "allow",
          "rustc *": "allow",
          "git checkout *": "ask",
          "git stash": "ask",
          "git stash *": "ask",
          "git *": "ask",
          "*": "ask"
        },
        "task": "ask",
        "skill": "allow",
        "todowrite": "ask",
        "webfetch": "ask",
        "websearch": "ask"
      }
    },
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "ls": "allow",
          "ls *": "allow",
          "cat": "allow",
          "cat *": "allow",
          "grep": "allow",
          "grep *": "allow",
          "find": "allow",
          "find *": "allow",
          "tree": "allow",
          "tree *": "allow",
          "git status": "allow",
          "git log": "allow",
          "git log *": "allow",
          "git diff": "allow",
          "git diff *": "allow",
          "git show": "allow",
          "git show *": "allow"
        },
        "task": "deny",
        "skill": "deny",
        "todowrite": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  }
}
