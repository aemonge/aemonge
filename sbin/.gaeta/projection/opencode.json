{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "model": "openai/gpt-5.3-codex",
  "autoupdate": true,
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "bash*": "deny",
      "sh*": "deny",
      "zsh*": "deny",
      "source*": "deny",
      "eval*": "deny",
      "exec*": "deny",
      "*&&*": "deny",
      "*||*": "deny",
      "*;*": "deny",
      "*|*": "deny",
      "*>*": "deny",
      "*>>*": "deny",
      "*<<<*": "deny",
      "*<<*": "deny",
      "*<(*": "deny",
      "*>(*": "deny",
      "*$(*": "deny",
      "*`*": "deny",
      "sudo*": "deny",
      "su*": "deny",
      "doas*": "deny",
      "python -c*": "deny",
      "python -m pip*": "deny",
      "python -m http.server*": "deny",
      "python*": "deny",
      "node -e*": "deny",
      "node --eval*": "deny",
      "node*": "deny",
      "perl -e*": "deny",
      "perl*": "deny",
      "ruby -e*": "deny",
      "ruby*": "deny",
      "npm install*": "deny",
      "npm i*": "deny",
      "pip install*": "deny",
      "cargo install*": "deny",
      "cargo add*": "deny",
      "rm -rf /*": "deny",
      "rm -rf /": "deny",
      "rm /*": "deny",
      "mv /* *": "deny",
      "cp /* *": "deny",
      "chmod -R /*": "deny",
      "chown*": "deny",
      "chgrp*": "deny",
      "sed -i*": "deny",
      "sed *-i*": "deny",
      "awk * > *": "deny",
      "awk * >> *": "deny",
      "dd*": "deny",
      "mkfs*": "deny",
      "fdisk*": "deny",
      "parted*": "deny",
      "git add*": "deny",
      "git commit*": "deny",
      "git push*": "deny",
      "git pull*": "deny",
      "git clone*": "deny",
      "git fetch*": "deny",
      "git merge*": "deny",
      "git rebase*": "deny",
      "git reset*": "deny",
      "systemctl*": "deny",
      "service*": "deny",
      "reboot*": "deny",
      "shutdown*": "deny",
      "poweroff*": "deny",
      "init*": "deny",
      "ls": "allow",
      "ls *": "allow",
      "cat": "allow",
      "cat *": "allow",
      "grep": "allow",
      "grep *": "allow",
      "find": "allow",
      "find *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "less": "allow",
      "less *": "allow",
      "more": "allow",
      "more *": "allow",
      "file": "allow",
      "file *": "allow",
      "stat": "allow",
      "stat *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "du": "allow",
      "du *": "allow",
      "df": "allow",
      "df *": "allow",
      "pwd": "allow",
      "which": "allow",
      "which *": "allow",
      "whereis": "allow",
      "whereis *": "allow",
      "type": "allow",
      "type *": "allow",
      "echo": "allow",
      "echo *": "allow",
      "printf": "allow",
      "printf *": "allow",
      "tree": "allow",
      "tree *": "allow",
      "diff": "allow",
      "diff *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git branch *": "allow",
      "git remote": "allow",
      "git remote *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git rev-parse": "allow",
      "git rev-parse *": "allow",
      "git blame": "allow",
      "git blame *": "allow",
      "git stash list": "allow",
      "git reflog": "allow",
      "git reflog *": "allow",
      "*": "deny"
    },
    "task": "deny",
    "skill": "deny",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "codesearch": "allow",
    "external_directory": "allow",
    "doom_loop": "deny"
