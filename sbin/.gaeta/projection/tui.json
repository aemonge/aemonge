{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "gruvbox",
  "keybinds": {
    "leader": "ctrl+e",
    "app_exit": "ctrl+q",
    "editor_open": "<leader>e,ctrl+i",
    "scrollbar_toggle": "ctrl+s",
    "session_rename": "ctrl+r",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "messages_first": "home",
    "messages_last": "end",
    "messages_next": "ctrl+n",
    "messages_previous": "ctrl+p",
    "command_list": "ctrl+.",
    "agent_cycle": "ctrl+a",
    "agent_cycle_reverse": "ctrl+x",
    "input_clear": "ctrl+c",
    "input_paste": "ctrl+v",
    "input_submit": "ctrl+return",
    "input_newline": "return"
  }
}
